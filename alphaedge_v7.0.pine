        "🍯 Honey Gold"         => color.new(#1A0F00, 15)
        "🌶️ Guntur Karam"       => color.new(#241616, 18)
        "❄️ Arctic Aurora"      => color.new(#001418, 15)
        => color.new(#001418, 15)

