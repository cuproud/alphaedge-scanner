        "🍯 Honey Gold"         => color.new(#2E1A05, 30)
        "🌶️ Guntur Karam"       => color.new(#4A2E2E, 30)
        "❄️ Arctic Aurora"      => color.new(#002830, 30)
        => color.new(#002830, 30)

