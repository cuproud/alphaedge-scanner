f_tHeader(string t) =>
    switch t
        "💎 Ice Diamond"        => color.new(#546E7A, 0)
        "🎯 Bloomberg Classic"  => color.new(#212121, 0)
        "🍯 Honey Gold"         => color.new(#5D4037, 0)
        "🌶️ Guntur Karam"       => color.new(#8C3A3A, 0)
        "❄️ Arctic Aurora"      => color.new(#006064, 0)
        => color.new(#006064, 0)

