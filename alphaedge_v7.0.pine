        => color.new(#004D40, 30)

THEME_HEADER     = f_tHeader(themeChoice)
THEME_BG         = f_tBg(themeChoice)
THEME_BG_ALT     = f_tBgAlt(themeChoice)
THEME_BULL       = f_tBull(themeChoice)
THEME_BEAR       = f_tBear(themeChoice)
THEME_ACCENT     = f_tAccent(themeChoice)
THEME_TEXT       = f_tText(themeChoice)
THEME_TEXT_DIM   = f_tTextDim(themeChoice)
THEME_BORDER     = f_tBorder(themeChoice)
THEME_ACCENT_ROW = f_tAccentRow(themeChoice)

// ══════════════════════════════════════════════════════════════════════════════
// TP/SL COLORS
// ══════════════════════════════════════════════════════════════════════════════
C_SL     = color.new(#D32F2F, 5)
C_ENTRY  = color.new(#1E88E5, 5)
C_TP1    = color.new(#43A047, 10)
C_TP2    = color.new(#2E7D32, 20)
C_TP3    = color.new(#1B5E20, 10)
C_TRAIL  = color.new(#FB8C00, 15)

LC_SL     = color.new(#C62828, 10)
LC_ENTRY  = color.new(#1565C0, 10)
LC_TP1    = color.new(#2E7D32, 10)
LC_TP2    = color.new(#1B5E20, 8)
LC_TP3    = color.new(#0D3D14, 5)
LC_TRAIL  = color.new(#E65100, 10)

// HELPER FUNCTIONS
f_progressBar(int score, int maxScore) =>
    int filled = math.max(0, math.min(maxScore, score))
    int empty  = maxScore - filled
    string bar = ""
    for i = 0 to filled - 1
        bar := bar + "█"
    for i = 0 to empty - 1
        bar := bar + "░"
    bar
// RANGE FILTER (AE Core)
rngfilt_va(float src, float teth, float srng) =>
    rf = src
    if teth > nz(teth[1])
        rf := (src - srng) < nz(rf[1]) ? nz(rf[1]) : (src - srng)
    else
        rf := (src + srng) > nz(rf[1]) ? nz(rf[1]) : (src + srng)
    rf

int lEff  = timeframe.in_seconds() <= 900 ? 100 : l
volrng    = rngfilt_va(close, volume, utils.smoothrng(close, lEff, 3))
smoothrng = utils.smoothrng(close, lEff, 3)
basetype  = volrng
hband     = basetype + smoothrng
lowband   = basetype - smoothrng
uprngRaw  = utils.trendUp(basetype)
uprng     = uprngRaw > 0

// ══════════════════════════════════════════════════════════════════════════════
// ADX
[diPlus, diMinus, adxVal] = ta.dmi(lengthadx, lengthadx)
adxSafe       = nz(adxVal, 0.0)
diPlusSafe    = nz(diPlus, 0.0)
diMinusSafe   = nz(diMinus, 0.0)
adxGatePassed = not useADXGate or adxSafe > adxGateLevel

// ══════════════════════════════════════════════════════════════════════════════
// ATR
atrRaw = ta.atr(atrLen)
atrVal = math.max(nz(atrRaw, high - low), syminfo.mintick * 10)

// ── GAP RISK CALCULATION ─────────────────────────────────────────────────────
float gapPct1     = close[1] > 0 ? math.abs(open     - close[1]) / close[1] * 100 : 0.0
float gapPct2     = close[2] > 0 ? math.abs(open[1]  - close[2]) / close[2] * 100 : 0.0
float gapPct3     = close[3] > 0 ? math.abs(open[2]  - close[3]) / close[3] * 100 : 0.0
float maxRecentGap = math.max(gapPct1, math.max(gapPct2, gapPct3))
bool  gapRiskOk   = not useGapFilter or maxRecentGap < gapRiskThreshold

// RSI + DIVERGENCE
rsiVal = ta.rsi(close, rsiLen)

pLow  = ta.pivotlow(low, rsiDivLook, rsiDivLook)
pHigh = ta.pivothigh(high, rsiDivLook, rsiDivLook)
rLow  = ta.pivotlow(rsiVal, rsiDivLook, rsiDivLook)
rHigh = ta.pivothigh(rsiVal, rsiDivLook, rsiDivLook)

var float lastPLow  = na
var float prevPLow  = na
var float lastRLow  = na
var float prevRLow  = na
var float lastPHigh = na
var float prevPHigh = na
var float lastRHigh = na
var float prevRHigh = na

bool newBullPivot = false
bool newBearPivot = false

if not na(pLow)
    prevPLow := lastPLow
    lastPLow := pLow
    prevRLow := lastRLow
    lastRLow := not na(rLow) ? rLow : rsiVal[rsiDivLook]
    newBullPivot := true

if not na(pHigh)
    prevPHigh := lastPHigh
    lastPHigh := pHigh
    prevRHigh := lastRHigh
    lastRHigh := not na(rHigh) ? rHigh : rsiVal[rsiDivLook]
    newBearPivot := true

bullDiv = newBullPivot and not na(prevPLow) and not na(lastPLow) and lastPLow < prevPLow and lastRLow > prevRLow
bearDiv = newBearPivot and not na(prevPHigh) and not na(lastPHigh) and lastPHigh > prevPHigh and lastRHigh < prevRHigh

rsi_bull = useRSIDiv ? (rsiVal > 50 or (bullDiv and rsiVal >= rsiDivFloor)) : rsiVal > 50
rsi_bear = useRSIDiv ? (rsiVal < 50 or (bearDiv and rsiVal <= rsiBearCeil)) : rsiVal < 50
rsi_ob   = rsiVal >= 70
rsi_os   = rsiVal <= 30

// ══════════════════════════════════════════════════════════════════════════════
// MACD
// ══════════════════════════════════════════════════════════════════════════════
[macdOsc, macdSigOsc, _macdHist] = ta.macd(close, fa, sa, sig)
macdBull = macdOsc > macdSigOsc

// ══════════════════════════════════════════════════════════════════════════════
// EMA
// ══════════════════════════════════════════════════════════════════════════════
ema50       = ta.ema(close, 50)
ema200      = ta.ema(close, 200)
goldenCross = ta.crossover(ema50, ema200)
deathCross  = ta.crossunder(ema50, ema200)
ema_bull_table = ema50[1] > ema200[1]

float ema200Slope     = (ema200 - ema200[5]) / (atrVal * 5)
float ema200SlopeEff  = timeframe.in_seconds() >= 3600 ? ema200SlopeMin1H : timeframe.in_seconds() <= 900 ? ema200SlopeMin15m : ema200SlopeMin
bool  ema200SlopeBull = ema200Slope >  ema200SlopeEff
bool  ema200SlopeBear = ema200Slope < -ema200SlopeEff

bool ema200SlopeBullHard = timeframe.in_seconds() <= 1800 ? true : ema200SlopeBull
bool ema200SlopeBearHard = timeframe.in_seconds() <= 1800 ? true : ema200SlopeBear

// ══════════════════════════════════════════════════════════════════════════════
// VWAP + VOLUME
// ══════════════════════════════════════════════════════════════════════════════
vwapVal = nz(ta.vwap(hlc3), close)
volAvg  = ta.sma(volume, 20)
highVol = volume > volAvg * 1.1

// ══════════════════════════════════════════════════════════════════════════════
// VOLATILITY
// ══════════════════════════════════════════════════════════════════════════════
atrAvg     = ta.sma(atrVal, 50)
volRatio   = nz(atrVal / atrAvg, 1.0)

// ══════════════════════════════════════════════════════════════════════════════
// BB/KC SQUEEZE
// ══════════════════════════════════════════════════════════════════════════════
bbBasis = ta.sma(close, 20)
bbDev   = ta.stdev(close, 20)
bbUpper = bbBasis + sqBBMult * bbDev
bbLower = bbBasis - sqBBMult * bbDev
kcMid   = ta.ema(close, 20)
kcRange = ta.atr(20)
kcUpper = kcMid + sqKCMult * kcRange
kcLower = kcMid - sqKCMult * kcRange

inSqueeze    = bbUpper < kcUpper and bbLower > kcLower
sqzFired     = inSqueeze[1] and not inSqueeze
sqzBullBreak = sqzFired and close > bbBasis
sqzBearBreak = sqzFired and close < bbBasis

// ══════════════════════════════════════════════════════════════════════════════
// CHOPPINESS INDEX
// ══════════════════════════════════════════════════════════════════════════════
float chopTrueRange = nz(ta.atr(1), high - low)
float chopAtrSum    = ta.sma(chopTrueRange, chopIndexLen) * chopIndexLen
float chopHiLo      = ta.highest(high, chopIndexLen) - ta.lowest(low, chopIndexLen)
float chopIndex     = chopHiLo > 0 ? 100.0 * math.log10(chopAtrSum / chopHiLo) / math.log10(chopIndexLen) : 50.0
// Apply on 1H+ only — on 15m/30m pullback-resumption fires in consolidation
// where CHOP reads high, blocking valid entries. Regime ADX floor handles it there.
float chopThreshEff = timeframe.in_seconds() >= 3600 ? chopIndexThresh : 100.0
bool  chopIdxOk     = not useChopIndex or chopIndex < chopThreshEff
// ══════════════════════════════════════════════════════════════════════════════
// HTF BIAS
// ══════════════════════════════════════════════════════════════════════════════
f_htfData() =>
    [ta.ema(close, 50)[1], ta.ema(close, 200)[1]]

[htfEMA50, htfEMA200] = request.security(syminfo.tickerid, htfTF, f_htfData(), barmerge.gaps_off, barmerge.lookahead_off)
htfBull = nz(htfEMA50, ema50) > nz(htfEMA200, ema200)
htfBias = htfBull ? 1 : -1

// ══════════════════════════════════════════════════════════════════════════════
// RANGE ST FILTER / VWMA
// ══════════════════════════════════════════════════════════════════════════════

lowband_tf  = ta.lowest(lowband, lengthhl)
highband_tf = ta.highest(hband, lengthhl)

highband_tf_display = ta.highest(high, lengthhl)
lowband_tf_display  = ta.lowest(low, lengthhl)

in_uptrend  = ta.barssince(ta.crossover(close, highband_tf[1])) < ta.barssince(ta.crossunder(close, lowband_tf[1]))
hl_bull     = not usehl or in_uptrend
hl_bear     = not usehl or not in_uptrend

vwma_val  = ta.vwma(volrng, lengthvwma)
vwma_bull = not usevwma or volrng > vwma_val

// ══════════════════════════════════════════════════════════════════════════════
// SUPERTREND
// ══════════════════════════════════════════════════════════════════════════════
atrST  = changeATR ? ta.atr(stPeriods) : ta.sma(ta.tr, stPeriods)
stUp   = stSrc - stMultiplier * atrST
stUp1  = nz(stUp[1], stUp)
stUp  := close[1] > stUp1 ? math.max(stUp, stUp1) : stUp
stDn   = stSrc + stMultiplier * atrST
stDn1  = nz(stDn[1], stDn)
stDn  := close[1] < stDn1 ? math.min(stDn, stDn1) : stDn

var int stTrend = 1
stTrend := nz(stTrend[1], stTrend)
stTrend := stTrend == -1 and close > stDn1 ? 1 : stTrend
stTrend := stTrend == 1 and close < stUp1 ? -1 : stTrend

stBuy  = stTrend == 1 and stTrend[1] == -1
stSell = stTrend == -1 and stTrend[1] == 1

// Supertrend Highlighter
stHighlightBull = showST and showSTHL and stTrend == 1
stHighlightBear = showST and showSTHL and stTrend == -1

// ══════════════════════════════════════════════════════════════════════════════
// SWING LEVELS
// ══════════════════════════════════════════════════════════════════════════════
recentSwingLow  = ta.lowest(low[1], swingLookback)
recentSwingHigh = ta.highest(high[1], swingLookback)

// ══════════════════════════════════════════════════════════════════════════════
// ORDER BLOCKS
// ══════════════════════════════════════════════════════════════════════════════
var bool priceInBullOB  = false
var bool priceInBearOB  = false
var bool priceInBullFVG = false
var bool priceInBearFVG = false

priceInBullOB  := false
priceInBearOB  := false
priceInBullFVG := false
priceInBearFVG := false

obPivotHigh = ta.pivothigh(high, obLookback, obLookback)
obPivotLow  = ta.pivotlow(low, obLookback, obLookback)

var obBullTops    = array.new_float()
var obBullBottoms = array.new_float()
var obBullBoxes   = array.new_box()

var obBearTops    = array.new_float()
var obBearBottoms = array.new_float()
var obBearBoxes   = array.new_box()

if useOB and not na(obPivotLow)
    bool found = false
    for k = 0 to obLookback * 2
        if not found
            int checkIdx = obLookback + k
            if checkIdx < bar_index
                float cO = open[checkIdx]
                float cC = close[checkIdx]
                if cC < cO
                    float obTop = math.max(cO, cC)
                    float obBot = math.min(cO, cC)
                    array.push(obBullTops, obTop)
                    array.push(obBullBottoms, obBot)
                    b = box.new(bar_index - checkIdx, obTop, bar_index + 20, obBot, bgcolor=obBullColor, border_color=color.new(color.green, 50), border_width=1)
                    array.push(obBullBoxes, b)
                    found := true
    while array.size(obBullTops) > obMaxBoxes
        array.shift(obBullTops)
        array.shift(obBullBottoms)
        box.delete(array.shift(obBullBoxes))

if useOB and not na(obPivotHigh)
    bool found = false
    for k = 0 to obLookback * 2
        if not found
            int checkIdx = obLookback + k
            if checkIdx < bar_index
                float cO = open[checkIdx]
                float cC = close[checkIdx]
                if cC > cO
                    float obTop = math.max(cO, cC)
                    float obBot = math.min(cO, cC)
                    array.push(obBearTops, obTop)
                    array.push(obBearBottoms, obBot)
                    b = box.new(bar_index - checkIdx, obTop, bar_index + 20, obBot, bgcolor=obBearColor, border_color=color.new(color.red, 50), border_width=1)
                    array.push(obBearBoxes, b)
                    found := true
    while array.size(obBearTops) > obMaxBoxes
        array.shift(obBearTops)
        array.shift(obBearBottoms)
        box.delete(array.shift(obBearBoxes))

if useOB
    int bullSize = array.size(obBullTops)
    if bullSize > 0
        for i = bullSize - 1 to 0
            if i < array.size(obBullTops)
                float obBot = array.get(obBullBottoms, i)
                float obTop_b = array.get(obBullTops, i)
                float obMid_b = (obTop_b + obBot) / 2.0
                // Prune OBs more than 4 ATR away — irrelevant at that distance
                bool tooFar_b = math.abs(close - obMid_b) > atrVal * 4.0
                if low < obBot or tooFar_b
                    array.remove(obBullTops, i)
                    array.remove(obBullBottoms, i)
                    box.delete(array.get(obBullBoxes, i))
                    array.remove(obBullBoxes, i)
    int bearSize = array.size(obBearTops)
    if bearSize > 0
        for i = bearSize - 1 to 0
            if i < array.size(obBearTops)
                float obTop = array.get(obBearTops, i)
                float obBot_r = array.get(obBearBottoms, i)
                float obMid_r = (obTop + obBot_r) / 2.0
                // Prune OBs more than 4 ATR away
                bool tooFar_r = math.abs(close - obMid_r) > atrVal * 4.0
                if high > obTop or tooFar_r
                    array.remove(obBearTops, i)
                    array.remove(obBearBottoms, i)
                    box.delete(array.get(obBearBoxes, i))
                    array.remove(obBearBoxes, i)

if useOB and barstate.islast
    if array.size(obBullBoxes) > 0
        for i = 0 to array.size(obBullBoxes) - 1
            box.set_right(array.get(obBullBoxes, i), bar_index + 20)
    if array.size(obBearBoxes) > 0
        for i = 0 to array.size(obBearBoxes) - 1
            box.set_right(array.get(obBearBoxes, i), bar_index + 20)

if array.size(obBullTops) > 0
    for i = 0 to array.size(obBullTops) - 1
        if close >= array.get(obBullBottoms, i) and close <= array.get(obBullTops, i)
            priceInBullOB := true

if array.size(obBearTops) > 0
    for i = 0 to array.size(obBearTops) - 1
        if close >= array.get(obBearBottoms, i) and close <= array.get(obBearTops, i)
            priceInBearOB := true

// ══════════════════════════════════════════════════════════════════════════════
// FAIR VALUE GAPS
// ══════════════════════════════════════════════════════════════════════════════
var fvgBullTops    = array.new_float()
var fvgBullBottoms = array.new_float()
var fvgBullBoxes   = array.new_box()
var fvgBearTops    = array.new_float()
var fvgBearBottoms = array.new_float()
var fvgBearBoxes   = array.new_box()

fvgBullCondition = low > high[2] and (low - high[2]) > atrVal * fvgMinSize
fvgBearCondition = high < low[2] and (low[2] - high) > atrVal * fvgMinSize

if useFVG and fvgBullCondition
    float fTop = low
    float fBot = high[2]
    array.push(fvgBullTops, fTop)
    array.push(fvgBullBottoms, fBot)
    b = box.new(bar_index - 1, fTop, bar_index + 15, fBot, bgcolor=fvgBullColor, border_color=color.new(color.aqua, 40), border_width=1, text="Bull FVG", text_size=size.tiny, text_color=color.white, text_halign=text.align_left, text_valign=text.align_center)
    array.push(fvgBullBoxes, b)
    while array.size(fvgBullTops) > fvgMaxBoxes
        array.shift(fvgBullTops)
        array.shift(fvgBullBottoms)
        box.delete(array.shift(fvgBullBoxes))

if useFVG and fvgBearCondition
    float fTop = low[2]
    float fBot = high
    array.push(fvgBearTops, fTop)
    array.push(fvgBearBottoms, fBot)
    b = box.new(bar_index - 1, fTop, bar_index + 15, fBot, bgcolor=fvgBearColor, border_color=color.new(color.fuchsia, 40), border_width=1, text="Bear FVG", text_size=size.tiny, text_color=color.white, text_halign=text.align_left, text_valign=text.align_center)
    array.push(fvgBearBoxes, b)
    while array.size(fvgBearTops) > fvgMaxBoxes
        array.shift(fvgBearTops)
        array.shift(fvgBearBottoms)
        box.delete(array.shift(fvgBearBoxes))

if useFVG
    int bullFvgSize = array.size(fvgBullTops)
    if bullFvgSize > 0
        for i = bullFvgSize - 1 to 0
            if i < array.size(fvgBullTops)
                float fBot = array.get(fvgBullBottoms, i)
                if low < fBot
                    array.remove(fvgBullTops, i)
                    array.remove(fvgBullBottoms, i)
                    box.delete(array.get(fvgBullBoxes, i))
                    array.remove(fvgBullBoxes, i)
    int bearFvgSize = array.size(fvgBearTops)
    if bearFvgSize > 0
        for i = bearFvgSize - 1 to 0
            if i < array.size(fvgBearTops)
                float fTop = array.get(fvgBearTops, i)
                if high > fTop
                    array.remove(fvgBearTops, i)
                    array.remove(fvgBearBottoms, i)
                    box.delete(array.get(fvgBearBoxes, i))
                    array.remove(fvgBearBoxes, i)

if useFVG and barstate.islast
    if array.size(fvgBullBoxes) > 0
        for i = 0 to array.size(fvgBullBoxes) - 1
            box.set_right(array.get(fvgBullBoxes, i), bar_index + 15)
    if array.size(fvgBearBoxes) > 0
        for i = 0 to array.size(fvgBearBoxes) - 1
            box.set_right(array.get(fvgBearBoxes, i), bar_index + 15)

if array.size(fvgBullTops) > 0
    for i = 0 to array.size(fvgBullTops) - 1
        if close >= array.get(fvgBullBottoms, i) and close <= array.get(fvgBullTops, i)
            priceInBullFVG := true

if array.size(fvgBearTops) > 0
    for i = 0 to array.size(fvgBearTops) - 1
        if close >= array.get(fvgBearBottoms, i) and close <= array.get(fvgBearTops, i)
            priceInBearFVG := true

bool smcBullBonus = useSMCBonus and (priceInBullOB or priceInBullFVG)
bool smcBearBonus = useSMCBonus and (priceInBearOB or priceInBearFVG)

// ══════════════════════════════════════════════════════════════════════════════
// MARKET STRUCTURE (Non-Repainting BOS/CHoCH)
// ══════════════════════════════════════════════════════════════════════════════
msPivotHigh = ta.pivothigh(high, msLookback, msLookback)
msPivotLow  = ta.pivotlow(low, msLookback, msLookback)

var float msLastHigh = na
var float msPrevHigh = na
var float msLastLow  = na
var float msPrevLow  = na
var int   msTrend    = 0

var msLabels = array.new_label()
var msLines  = array.new_line()
int msMaxVisible = 20

msBOSBull   = useMS and not na(msLastHigh) and close > msLastHigh and msTrend != 1
msBOSBear   = useMS and not na(msLastLow)  and close < msLastLow  and msTrend != -1
msCHoCHBull = useMS and not na(msLastHigh) and close > msLastHigh and msTrend == -1
msCHoCHBear = useMS and not na(msLastLow)  and close < msLastLow  and msTrend == 1

if msBOSBull or msCHoCHBull
    if useMS
        lb_ms = label.new(bar_index, high + atrVal * 2, msCHoCHBull ? "CHoCH" : "BOS", style=label.style_label_down, color=color.new(color.green, 20), textcolor=color.white, size=size.small)
        ln_ms = line.new(bar_index - msLookback, msLastHigh, bar_index, msLastHigh, color=color.new(color.green, 30), width=1, style=line.style_dashed)
        array.push(msLabels, lb_ms)
        array.push(msLines, ln_ms)
    msTrend := 1

if msBOSBear or msCHoCHBear
    if useMS
        lb_ms = label.new(bar_index, low - atrVal * 2, msCHoCHBear ? "CHoCH" : "BOS", style=label.style_label_up, color=color.new(color.red, 20), textcolor=color.white, size=size.small)
        ln_ms = line.new(bar_index - msLookback, msLastLow, bar_index, msLastLow, color=color.new(color.red, 30), width=1, style=line.style_dashed)
        array.push(msLabels, lb_ms)
        array.push(msLines, ln_ms)
    msTrend := -1

if useMS and not na(msPivotHigh)
    msPrevHigh := msLastHigh
    msLastHigh := msPivotHigh

if useMS and not na(msPivotLow)
    msPrevLow := msLastLow
    msLastLow := msPivotLow

if useMS and not na(msPivotHigh)
    string hLabel = not na(msPrevHigh) and msPivotHigh > msPrevHigh ? "HH" : "LH"
    color hCol    = hLabel == "HH" ? color.lime : color.red
    lb_piv = label.new(bar_index - msLookback, msPivotHigh, hLabel, style=label.style_label_down, color=color.new(hCol, 70), textcolor=color.white, size=size.tiny)
    array.push(msLabels, lb_piv)

if useMS and not na(msPivotLow)
    string lLabel = not na(msPrevLow) and msPivotLow > msPrevLow ? "HL" : "LL"
    color lCol    = lLabel == "HL" ? color.lime : color.red
    lb_piv = label.new(bar_index - msLookback, msPivotLow, lLabel, style=label.style_label_up, color=color.new(lCol, 70), textcolor=color.white, size=size.tiny)
    array.push(msLabels, lb_piv)

while array.size(msLabels) > msMaxVisible
    label.delete(array.shift(msLabels))
while array.size(msLines) > msMaxVisible
    line.delete(array.shift(msLines))

// ══════════════════════════════════════════════════════════════════════════════
// LIQUIDITY SWEEP DETECTOR
// ══════════════════════════════════════════════════════════════════════════════
liqSwingHigh = ta.highest(high[1], liqSwingLen)
liqSwingLow  = ta.lowest(low[1], liqSwingLen)

float barRange_liq  = high - low
float upperWick_liq = high - math.max(open, close)
float lowerWick_liq = math.min(open, close) - low

bool wickBullOk = barRange_liq > 0 and (lowerWick_liq / barRange_liq) >= liqWickRatio
bool wickBearOk = barRange_liq > 0 and (upperWick_liq / barRange_liq) >= liqWickRatio

var int lastBullSweepBar = -999
var int lastBearSweepBar = -999

bool rawBullSweep = useLiqSweep and low < liqSwingLow and close > liqSwingLow and wickBullOk
bool rawBearSweep = useLiqSweep and high > liqSwingHigh and close < liqSwingHigh and wickBearOk

bool liqBullSweep = rawBullSweep and (bar_index - lastBullSweepBar) >= liqMinGap
bool liqBearSweep = rawBearSweep and (bar_index - lastBearSweepBar) >= liqMinGap

if liqBullSweep
    lastBullSweepBar := bar_index
if liqBearSweep
    lastBearSweepBar := bar_index

bool freshBullSweep = (bar_index - lastBullSweepBar) <= 3
bool freshBearSweep = (bar_index - lastBearSweepBar) <= 3

var sweepBoxes  = array.new_box()
var sweepLabels = array.new_label()
int sweepMaxVisible = 15

if liqBullSweep and liqShowBox
    b_sw = box.new(bar_index - 1, liqSwingLow, bar_index + 2, low, bgcolor=liqBullColor, border_color=color.new(#00E676, 30), border_width=1, text="SWEEP ⚡", text_size=size.tiny, text_color=color.white, text_halign=text.align_center, text_valign=text.align_center)
    l_sw = label.new(bar_index, low - atrVal * 0.5, "🎣 Bull Sweep", style=label.style_label_up, color=color.new(#00E676, 20), textcolor=color.white, size=size.small, tooltip="LIQUIDITY SWEEP (Bullish)")
    array.push(sweepBoxes, b_sw)
    array.push(sweepLabels, l_sw)

if liqBearSweep and liqShowBox
    b_sw = box.new(bar_index - 1, high, bar_index + 2, liqSwingHigh, bgcolor=liqBearColor, border_color=color.new(#FF1744, 30), border_width=1, text="SWEEP ⚡", text_size=size.tiny, text_color=color.white, text_halign=text.align_center, text_valign=text.align_center)
    l_sw = label.new(bar_index, high + atrVal * 0.5, "🎣 Bear Sweep", style=label.style_label_down, color=color.new(#FF1744, 20), textcolor=color.white, size=size.small, tooltip="LIQUIDITY SWEEP (Bearish)")
    array.push(sweepBoxes, b_sw)
    array.push(sweepLabels, l_sw)

while array.size(sweepBoxes) > sweepMaxVisible
    box.delete(array.shift(sweepBoxes))
while array.size(sweepLabels) > sweepMaxVisible
    label.delete(array.shift(sweepLabels))

// ══════════════════════════════════════════════════════════════════════════════
// ANCHORED VWAP
// ══════════════════════════════════════════════════════════════════════════════
avwapPivotH = ta.pivothigh(high, avwapPivotLen, 2)
avwapPivotL = ta.pivotlow(low, avwapPivotLen, 2)

var float avwapSumPV     = 0.0
var float avwapSumV      = 0.0
var int   avwapAnchorBar = 0
var int   avwapBarsSince = 0

bool newAnchor = false
if avwapAnchor == "Last Major Pivot" and (not na(avwapPivotH) or not na(avwapPivotL))
    newAnchor := true
else if avwapAnchor == "Session Start" and session.isfirstbar_regular
    newAnchor := true
else if avwapAnchor == "Weekly Open" and dayofweek == dayofweek.monday and dayofweek[1] != dayofweek.monday
    newAnchor := true

if newAnchor
    avwapSumPV     := hlc3 * volume
    avwapSumV      := volume
    avwapAnchorBar := bar_index
    avwapBarsSince := 0
else
    avwapSumPV := avwapSumPV + hlc3 * volume
    avwapSumV  := avwapSumV + volume
    avwapBarsSince := bar_index - avwapAnchorBar

avwapValue = avwapSumV > 0 ? avwapSumPV / avwapSumV : close

plot(useAVWAP ? avwapValue : na, "Anchored VWAP", color=color.new(#FFD700, 0), linewidth=2, style=plot.style_line)

// ══════════════════════════════════════════════════════════════════════════════
// CVD (Uses time("D") for rollover)
// ══════════════════════════════════════════════════════════════════════════════
var float cvdValue = 0.0

bool cvdReset = false
if cvdAnchor == "Session"
    cvdReset := session.isfirstbar_regular
else if cvdAnchor == "Daily"
    cvdReset := ta.change(time("D")) != 0
else if cvdAnchor == "Weekly"
    cvdReset := dayofweek == dayofweek.monday and dayofweek[1] != dayofweek.monday

if cvdReset
    cvdValue := 0.0

if useCVD
    float barRange_cvd = high - low
    float buyRatio_cvd = barRange_cvd > 0 ? (close - low) / barRange_cvd : 0.5
    float sellRatio_cvd = 1.0 - buyRatio_cvd
    float netVol_cvd = volume * (buyRatio_cvd - sellRatio_cvd)
    cvdValue := cvdValue + netVol_cvd

cvdHighArr = ta.highest(cvdValue, cvdLen)
cvdLowArr  = ta.lowest(cvdValue, cvdLen)
priceHighArr = ta.highest(high, cvdLen)
priceLowArr  = ta.lowest(low, cvdLen)

cvdBearDiv = useCVD and high >= priceHighArr[1] and cvdValue < cvdHighArr[1]
cvdBullDiv = useCVD and low <= priceLowArr[1] and cvdValue > cvdLowArr[1]

// ══════════════════════════════════════════════════════════════════════════════
// TIME FILTER
// ══════════════════════════════════════════════════════════════════════════════
int  nyHour    = hour(time,   "America/New_York")
int  nyMinute  = minute(time, "America/New_York")
int  nyDay     = dayofweek(time, "America/New_York")
bool isWeekend = nyDay == dayofweek.saturday or nyDay == dayofweek.sunday

int  minsAfterOpen   = (nyHour - 9)  * 60 + nyMinute - 30
int  minsBeforeClose = (16 * 60)     - (nyHour * 60 + nyMinute)

bool inOpenBlock  = blockOpen  and minsAfterOpen  >= 0 and minsAfterOpen  < 30
bool inCloseBlock = blockClose and minsBeforeClose >= 0 and minsBeforeClose < 15
bool hourOk       = not useTimeFilter or (nyHour >= allowedStart and nyHour < allowedEnd)
bool dayOk        = not (skipWeekends and isWeekend)

timeAllowed = not useTimeFilter or (hourOk and dayOk and not inOpenBlock and not inCloseBlock)
// ══════════════════════════════════════════════════════════════════════════════
// MARKET REGIME DETECTION
// ══════════════════════════════════════════════════════════════════════════════
string marketRegime = "RANGING"
color  regimeColor  = color.gray
string regimeEmoji  = "📊"

if volRatio >= regimeVolHigh
    marketRegime := "VOLATILE"
    regimeColor  := color.new(#FF6D00, 0)
    regimeEmoji  := "⚡"
else if adxSafe >= regimeAdxTrend
    marketRegime := "TRENDING"
    regimeColor  := color.new(#00C853, 0)
    regimeEmoji  := "🚀"
else if volRatio <= regimeVolLow and adxSafe < regimeAdxRange
    marketRegime := "QUIET"
    regimeColor  := color.new(#546E7A, 0)
    regimeEmoji  := "💤"
else if adxSafe < regimeAdxRange
    marketRegime := "RANGING"
    regimeColor  := color.new(#2196F3, 0)
    regimeEmoji  := "🔄"
else
    marketRegime := "TRANSITIONAL"
    regimeColor  := color.new(#9C27B0, 0)
    regimeEmoji  := "🔀"

bool regimeTrending    = marketRegime == "TRENDING"
bool regimeVolatile    = marketRegime == "VOLATILE"
bool regimeRanging     = marketRegime == "RANGING"
bool regimeQuiet       = marketRegime == "QUIET"
bool regimeTransitional = marketRegime == "TRANSITIONAL"

// ── HARD REGIME GATE ──────────────────────────────────────────────────────────
float regimeAdxFloor = timeframe.in_seconds() <= 900 ? 18.0 : timeframe.in_seconds() <= 1800 ? 20.0 : 22.0

bool regimeAllowsSignal = (regimeTrending or regimeVolatile or (regimeTransitional and timeframe.in_seconds() <= 900)) and adxSafe >= regimeAdxFloor

// MTF DATA
// ══════════════════════════════════════════════════════════════════════════════
f_mtfBundle() =>
    float e50  = ta.ema(close, 50)[1]
    float e200 = ta.ema(close, 200)[1]
    float rsi  = ta.rsi(close, rsiLen)[1]
    float cls  = close[1]
    [macdL, sigL, _h] = ta.macd(close, fa, sa, sig)
    float macdDiff = macdL[1] - sigL[1]
    [e50, e200, rsi, cls, macdDiff]

[mtf1_ema50, mtf1_ema200, mtf1_rsi, mtf1_close, mtf1_macd] = request.security(syminfo.tickerid, mtf1, f_mtfBundle(), barmerge.gaps_off, barmerge.lookahead_off)
[mtf2_ema50, mtf2_ema200, mtf2_rsi, mtf2_close, mtf2_macd] = request.security(syminfo.tickerid, mtf2, f_mtfBundle(), barmerge.gaps_off, barmerge.lookahead_off)
[mtf3_ema50, mtf3_ema200, mtf3_rsi, mtf3_close, mtf3_macd] = request.security(syminfo.tickerid, mtf3, f_mtfBundle(), barmerge.gaps_off, barmerge.lookahead_off)
[mtf4_ema50, mtf4_ema200, mtf4_rsi, mtf4_close, mtf4_macd] = request.security(syminfo.tickerid, mtf4, f_mtfBundle(), barmerge.gaps_off, barmerge.lookahead_off)

f_mtfScore(float c, float e50, float e200, float rsi) =>
    (e50 > e200 ? 1 : 0) + (rsi > 50 ? 1 : 0) + (c > e50 ? 1 : 0)

mtf1_bull    = f_mtfScore(mtf1_close, mtf1_ema50, mtf1_ema200, mtf1_rsi)
mtf2_bull    = f_mtfScore(mtf2_close, mtf2_ema50, mtf2_ema200, mtf2_rsi)
mtf3_bull    = f_mtfScore(mtf3_close, mtf3_ema50, mtf3_ema200, mtf3_rsi)
mtf4_bull    = f_mtfScore(mtf4_close, mtf4_ema50, mtf4_ema200, mtf4_rsi)
totalMTFBull = mtf1_bull + mtf2_bull + mtf3_bull + mtf4_bull

// ══════════════════════════════════════════════════════════════════════════════
// 🧪 SIGNAL QUALITY SCORE
// ══════════════════════════════════════════════════════════════════════════════
f_calcSQS(bool isBull, int bScore, int beScore) =>
    int score = isBull ? bScore : beScore

    float confPct = float(score) / 12.0 * 25.0

    // MTF alignment: 20% (reduced from 25%)
    float mtfPct = 0.0
    float mtfRangingPenalty = (adxSafe < regimeAdxRange) ? 0.5 : 1.0
    if isBull
        mtfPct := float(totalMTFBull) / 12.0 * 20.0 * mtfRangingPenalty
    else
        mtfPct := float(12 - totalMTFBull) / 12.0 * 20.0 * mtfRangingPenalty

    float regPct = 0.0
    if marketRegime == "TRENDING"
        regPct := 28.0
    else if marketRegime == "VOLATILE"
        // ADX-confirmed volatile = same quality as trending
        // Pure vol spike with no direction = penalized
        regPct := adxSafe >= regimeAdxTrend ? 28.0 : 18.0
    else if marketRegime == "TRANSITIONAL"
        regPct := 14.0
    else if marketRegime == "RANGING"
        regPct := 8.0
    else  // QUIET
        regPct := 3.0
    // Volume: 15% (raised from 10% — volume is independent price confirmation)
    float volRatioLive = volume > 0 and volAvg > 0 ? volume / volAvg : 1.0
    float volPct = volRatioLive >= 1.5 ? 15.0 :
                   volRatioLive >= 1.1 ? 12.0 :
                   volRatioLive >= 0.85 ? 8.0 : 3.0

    // Volatility fit: 10% (unchanged)
    float volatPct = 0.0
    if volRatio >= 0.8 and volRatio <= 1.5
        volatPct := 10.0
    else if volRatio >= 0.6 and volRatio <= 2.0
        volatPct := 7.0
    else
        volatPct := 3.0

    math.min(100.0, confPct + mtfPct + regPct + volPct + volatPct)

f_mtfSignal(int mtfScore, float macdDiff) =>
    float signalScore = float(mtfScore) + (macdDiff > 0 ? 0.5 : -0.5)
    string lbl = signalScore >= 3.0 ? "STRONG BUY" : signalScore >= 2.0 ? "BUY" : signalScore >= 1.0 ? "NEUTRAL" : signalScore >= 0.0 ? "SELL" : "STRONG SELL"
    lbl

f_mtfSignalColor(string sigStr) =>
    switch sigStr
        "STRONG BUY"  => color.new(#00C853, 0)
        "BUY"         => color.lime
        "NEUTRAL"     => color.gray
        "SELL"        => color.orange
        "STRONG SELL" => color.red
        => color.gray

mtf1_signal = f_mtfSignal(mtf1_bull, mtf1_macd)
mtf2_signal = f_mtfSignal(mtf2_bull, mtf2_macd)
mtf3_signal = f_mtfSignal(mtf3_bull, mtf3_macd)
mtf4_signal = f_mtfSignal(mtf4_bull, mtf4_macd)

f_mtfLabel(int sc) =>
    sc >= 3 ? "Strong Bull" : sc == 2 ? "Bullish" : sc == 1 ? "Bearish" : "Strong Bear"

f_mtfColor(int sc) =>
    sc >= 3 ? color.lime : sc == 2 ? color.new(color.lime, 50) : sc == 1 ? color.new(color.red, 50) : color.red

// ══════════════════════════════════════════════════════════════════════════════
// CONFLUENCE SCORES (max 12)
// ══════════════════════════════════════════════════════════════════════════════
bool cvdBullBonus = useCVD and cvdBullDiv
bool cvdBearBonus = useCVD and cvdBearDiv

bool bullBonusActive = cvdBullBonus or smcBullBonus or (liqBonusScore and freshBullSweep) or highVol
bool bearBonusActive = cvdBearBonus or smcBearBonus or (liqBonusScore and freshBearSweep) or highVol

// ── 5-PILLAR SCORE (v7.0 I1: AND-logic on P2/P3) ─────────────────────────────

// PILLAR 1: Structural trend (4H HTF)
bool p1Bull = htfBull
bool p1Bear = not htfBull

// PILLAR 2: Momentum confirmation — v7.0 AND-logic
//   Both true → 2pts (highest conviction)
//   Either true → 1pt (partial credit)
//   Neither → 0pts
bool p2BullMacd = macdBull
bool p2BullRsi  = rsiVal > 50 and rsiVal > rsiVal[2]
bool p2BearMacd = not macdBull
bool p2BearRsi  = rsiVal < 50 and rsiVal < rsiVal[2]

int p2BullPts = (p2BullMacd and p2BullRsi) ? 2 : ((p2BullMacd or p2BullRsi) ? 1 : 0)
int p2BearPts = (p2BearMacd and p2BearRsi) ? 2 : ((p2BearMacd or p2BearRsi) ? 1 : 0)

// Boolean flags for purity count (any momentum agreement counts as pillar present)
bool p2Bull = p2BullPts > 0
bool p2Bear = p2BearPts > 0

// PILLAR 3: Volume confirmation — v7.0 AND-logic
//   high vol AND CVD aligned → 3pts (institutional commit)
//   Either alone → 1pt (partial)
//   Neither → 0pts
bool p3BullVol = highVol
bool p3BullCvd = not useCVD ? false : (cvdBullDiv or cvdValue > cvdValue[3])
bool p3BearVol = highVol
bool p3BearCvd = not useCVD ? false : (cvdBearDiv or cvdValue < cvdValue[3])

// When CVD disabled, fall back to vol-only (1pt if true)
int p3BullPts = useCVD ?
                ((p3BullVol and p3BullCvd) ? 3 : ((p3BullVol or p3BullCvd) ? 1 : 0)) :
                (p3BullVol ? 2 : 0)  // CVD off: vol=2pts (not full 3)
int p3BearPts = useCVD ?
                ((p3BearVol and p3BearCvd) ? 3 : ((p3BearVol or p3BearCvd) ? 1 : 0)) :
                (p3BearVol ? 2 : 0)

bool p3Bull = p3BullPts > 0
bool p3Bear = p3BearPts > 0

// PILLAR 4: Regime environment
bool p4 = regimeTrending or regimeVolatile

// PILLAR 5: Candle body confirmation
float barBodyPct = (high - low) > 0 ? math.abs(close - open) / (high - low) : 0.0
bool p5Bull = useCandleGate and close > open and barBodyPct > 0.5
bool p5Bear = useCandleGate and close < open and barBodyPct > 0.5

// Composite score (0-12 scale: P1=3, P2=2, P3=3, P4=2, P5=2)
bullScore = 0
bullScore += p1Bull ? 3 : 0
bullScore += p2BullPts
bullScore += p3BullPts
bullScore += p4     ? 2 : 0
bullScore += p5Bull ? 2 : 0

bearScore = 0
bearScore += p1Bear ? 3 : 0
bearScore += p2BearPts
bearScore += p3BearPts
bearScore += p4     ? 2 : 0
bearScore += p5Bear ? 2 : 0

// Pillar purity — count how many of 5 pillars agree with direction
int bullPillarCount = (p1Bull ? 1 : 0) + (p2Bull ? 1 : 0) + (p3Bull ? 1 : 0) + (p4 ? 1 : 0) + (p5Bull ? 1 : 0)
int bearPillarCount = (p1Bear ? 1 : 0) + (p2Bear ? 1 : 0) + (p3Bear ? 1 : 0) + (p4 ? 1 : 0) + (p5Bear ? 1 : 0)
bool bullPurityOk = bullPillarCount >= 3
bool bearPurityOk = bearPillarCount >= 3

// Score trend — 3-bar rolling average for building/fading detection
float bullScoreAvg3  = (float(bullScore) + float(bullScore[1]) + float(bullScore[2])) / 3.0
float bearScoreAvg3  = (float(bearScore) + float(bearScore[1]) + float(bearScore[2])) / 3.0
bool  bullBuilding   = float(bullScore) > bullScoreAvg3 + 0.5
bool  bullFading     = float(bullScore) < bullScoreAvg3 - 0.5
bool  bearBuilding   = float(bearScore) > bearScoreAvg3 + 0.5
bool  bearFading     = float(bearScore) < bearScoreAvg3 - 0.5

f_scoreTrend(bool building, bool fading) =>
    building ? " ↑" : fading ? " ↓" : " →"

f_scoreTrendColor(bool building, bool fading, bool isBull) =>
    color result = THEME_BEAR
    if building
        result := isBull ? color.new(#00E676, 10) : color.new(#FF1744, 10)
    else if fading
        result := color.new(#9E9E9E, 20)
    else
        result := isBull ? THEME_BULL : THEME_BEAR
    result
// Grade helpers (display compatibility)
getGrade(int sc) =>
    sc >= 12 ? "A+" : sc >= 9 ? "A" : sc >= 6 ? "B" : "C"

passesGradeFilter(int sc) =>
    switch gradeFilter
        "A+ Only"      => sc >= 12
        "A+ and A"     => sc >= 9
        "B and better" => sc >= 6
        "All (incl C)" => true
        => true

float sqsBull = f_calcSQS(true, bullScore, bearScore)
float sqsBear = f_calcSQS(false, bullScore, bearScore)

var float sqsBullConfirmed = na
var float sqsBearConfirmed = na
if barstate.isconfirmed
    sqsBullConfirmed := sqsBull
    sqsBearConfirmed := sqsBear

f_sqsGrade(float sqs) =>
    sqs >= 90 ? "ELITE" : sqs >= 75 ? "STRONG" : sqs >= 60 ? "GOOD" : sqs >= 45 ? "FAIR" : "AVOID"

f_sqsColor(float sqs) =>
    sqs >= 90 ? color.new(#00E676, 0) : sqs >= 75 ? color.new(#66BB6A, 0) : sqs >= 60 ? color.new(#FFC107, 0) : sqs >= 45 ? color.new(#FF9800, 0) : color.new(#FF5252, 0)
// ══════════════════════════════════════════════════════════════════════════════
// SESSION VWAP + STANDARD DEVIATION BANDS
// ══════════════════════════════════════════════════════════════════════════════
var float svwapCumVol  = 0.0
var float svwapCumPV   = 0.0
var float svwapCumPV2  = 0.0

bool isNewDay = ta.change(time("D")) != 0

if isNewDay
    svwapCumVol  := 0.0
    svwapCumPV   := 0.0
    svwapCumPV2  := 0.0

svwapCumVol  += volume
svwapCumPV   += volume * hlc3
svwapCumPV2  += volume * hlc3 * hlc3

float svwapVal     = svwapCumVol > 0 ? svwapCumPV / svwapCumVol : na
float svwapVar     = svwapCumVol > 0 ? svwapCumPV2 / svwapCumVol - svwapVal * svwapVal : na
float svwapSD      = not na(svwapVar) and svwapVar > 0 ? math.sqrt(svwapVar) : na

float svwapU1      = not na(svwapVal) and not na(svwapSD) ? svwapVal + svwapSD       : na
float svwapL1      = not na(svwapVal) and not na(svwapSD) ? svwapVal - svwapSD       : na
float svwapU2      = not na(svwapVal) and not na(svwapSD) ? svwapVal + svwapSD * 2.0 : na
float svwapL2      = not na(svwapVal) and not na(svwapSD) ? svwapVal - svwapSD * 2.0 : na

// Distance from session VWAP for info table
float svwapDistPct = not na(svwapVal) and svwapVal > 0 ? (close - svwapVal) / svwapVal * 100.0 : 0.0
float svwapDistSD  = not na(svwapSD) and svwapSD > 0 ? (close - svwapVal) / svwapSD : 0.0

// pocPrice forward declaration — used in signal engine gates; assigned in VP section below
var float pocPrice = na

// ══════════════════════════════════════════════════════════════════════════════
// SIGNAL ENGINE — v6.10
// ══════════════════════════════════════════════════════════════════════════════
var bool  inBuyLeg      = false
var bool  inSellLeg     = false
var int   lastSigBar    = -999
var float lastSigPrice  = na
var int   lastSigDir    = 0
var float atrAtLastSig  = na

var float  frozenScore = na
var string frozenGrade = "—"
var string frozenDir   = "—"

var int lastBuyAlertBar  = -9999
var int lastSellAlertBar = -9999

barsSinceSig = bar_index - lastSigBar

// ADX bypass — TRENDING regime only
adxBypassBull     = adxReversalBypass and bullScore >= adxBypassMinScore and regimeTrending
adxBypassBear     = adxReversalBypass and bearScore >= adxBypassMinScore and regimeTrending
adxGatePassedBull = adxGatePassed or adxBypassBull
adxGatePassedBear = adxGatePassed or adxBypassBear

bool htfOpposesBuy  = useTrendGradeFilter and not htfBull
bool htfOpposesSell = useTrendGradeFilter and htfBull

// HTF/LTF conflict detection
bool ltfBullStructure = uprng and stTrend == 1
bool ltfBearStructure = not uprng and stTrend == -1
bool htfLtfConflictBull = not htfBull and ltfBullStructure  // HTF says bear, LTF says bull
bool htfLtfConflictBear = htfBull and ltfBearStructure       // HTF says bull, LTF says bear


int htfDisagreeCount = 0
htfDisagreeCount += htfOpposesBuy ? 1 : 0
htfDisagreeCount += htfLtfConflictBull ? 1 : 0
htfDisagreeCount += (useMTFGate and totalMTFBull <= mtfGateBear) ? 1 : 0

int htfDisagreeCountSell = 0
htfDisagreeCountSell += htfOpposesSell ? 1 : 0
htfDisagreeCountSell += htfLtfConflictBear ? 1 : 0
htfDisagreeCountSell += (useMTFGate and totalMTFBull >= mtfGateBull) ? 1 : 0

// 0 disagreements: no block. 1: block only weak scores (<8). 2: block <10. 3 (unanimous): block <11.
int counterTrendMinScoreBuy  = htfDisagreeCount == 0 ? 0 : htfDisagreeCount == 1 ? 8 : htfDisagreeCount == 2 ? 10 : 11
int counterTrendMinScoreSell = htfDisagreeCountSell == 0 ? 0 : htfDisagreeCountSell == 1 ? 8 : htfDisagreeCountSell == 2 ? 10 : 11

counterTrendBuy  = htfDisagreeCount > 0 and bullScore < counterTrendMinScoreBuy
counterTrendSell = htfDisagreeCountSell > 0 and bearScore < counterTrendMinScoreSell

bool conflictBlockBuy  = false
bool conflictBlockSell = false
mtfBlockSell = false
mtfBlockBuy  = false

chopRefAtr  = nz(atrAtLastSig, atrVal)
priceDelta  = close - nz(lastSigPrice, close)
float tfChopScale     = timeframe.in_seconds() <= 900 ? 0.7 : 1.0
float chopScaleFactor = useRegimeChopScale ? (regimeVolatile ? 1.5 : regimeTrending ? 0.8 : 1.0) * tfChopScale : tfChopScale
float chopMultEff     = chopAtrMult * chopScaleFactor
bool chopOkBuy  = not useChopFilter or na(lastSigPrice) or (priceDelta >= chopRefAtr * chopMultEff)
bool chopOkSell = not useChopFilter or na(lastSigPrice) or (priceDelta <= -(chopRefAtr * chopMultEff))

// ── ENTRY TRIGGER — Pullback-resumption ───────────────
// Raw crossover events
crossover_hband    = ta.crossover(close, hband)
crossunder_lowband = ta.crossunder(close, lowband)

int hbandLookback    = timeframe.in_seconds() <= 900 ? 12 : 8
bool wasBelowhband   = ta.lowest(close, hbandLookback) < hband[4]
bool wasAboveLowband = ta.highest(close, 8) > lowband[4]
bool pullbackResumeBull = crossover_hband and wasBelowhband
bool pullbackResumeBear = crossunder_lowband and wasAboveLowband

bool crossoverBase  = ta.crossover(close, basetype)
bool crossunderBase = ta.crossunder(close, basetype)

int  baseRefShift   = timeframe.in_seconds() <= 900 ? 1 : 2  
bool wasBelowhBase  = ta.lowest(close, 5) < basetype[baseRefShift]
bool wasAboveBase   = ta.highest(close, 5) > basetype[baseRefShift]

bool baseResumeBull = uprng and crossoverBase and wasBelowhBase
bool baseResumeBear = not uprng and crossunderBase and wasAboveBase

// Direction flip trigger
var bool prevUprng = false
ptDirectionFlip    = bar_index > 0 and uprng != prevUprng
prevUprng         := uprng
isHigherTF      = timeframe.isweekly or timeframe.isdaily or (timeframe.isintraday and timeframe.multiplier >= 240)
flipAllowed     = allowFlipAllTF or isHigherTF
flipTriggerBull = ptDirectionFlip and uprng and flipAllowed
flipTriggerBear = ptDirectionFlip and not uprng and flipAllowed

crossover_hband_eff    = pullbackResumeBull or baseResumeBull or flipTriggerBull
crossunder_lowband_eff = pullbackResumeBear or baseResumeBear or flipTriggerBear

// ── SUPERTREND CONFIRMATION GATE ─────────────────────────────────────────────

bool stConfirmBull = stTrend == 1
bool stConfirmBear = stTrend == -1

bool stConfirmBullHard = timeframe.in_seconds() <= 900 ? true : stConfirmBull
bool stConfirmBearHard = timeframe.in_seconds() <= 900 ? true : stConfirmBear   

// ── VWAP POSITION GATE ───────────────────────────────────────────────────────
bool vwapConfirmBull = close > vwapVal
bool vwapConfirmBear = close < vwapVal

bool volSpikeOk      = not useVolSpikeGate or volume >= volAvg * volSpikeMult
float pocDistATR     = not na(pocPrice) and pocPrice > 0 and atrVal > 0 ? math.abs(close - pocPrice) / atrVal : 0.0
float pocDistPct     = not na(pocPrice) and pocPrice > 0 ? math.abs(close - pocPrice) / pocPrice * 100.0 : 0.0
float ema200DistATR  = (close - ema200) / atrVal

bool pocDistOk       = not usePOCDistGate or na(pocPrice) or pocDistATR <= maxPOCDistATR
bool ema200ExtOk     = not useEMA200ExtGate or math.abs(ema200DistATR) <= maxEMA200ExtATR

// On 15m VWAP is advisory — pullback entries legitimately dip below VWAP
bool vwapHardGate    = timeframe.in_seconds() <= 900 ? true : vwapConfirmBull
bool qualityGateBull = regimeAllowsSignal and ema200SlopeBullHard and stConfirmBullHard and vwapHardGate and volSpikeOk and ema200ExtOk and chopIdxOk and gapRiskOk
bool vwapHardGateBear = timeframe.in_seconds() <= 900 ? true : vwapConfirmBear  
bool qualityGateBear  = regimeAllowsSignal and ema200SlopeBearHard and stConfirmBearHard and vwapHardGateBear and volSpikeOk and ema200ExtOk and chopIdxOk and gapRiskOk
// ── RAW SIGNAL CONDITIONS ────────────────────────────────────────────────────
bool gradeOkBull = timeframe.in_seconds() <= 900 ? bullScore >= 7 : timeframe.in_seconds() >= 3600 ? bullScore >= 9 : passesGradeFilter(bullScore)
bool gradeOkBear = timeframe.in_seconds() <= 900 ? bearScore >= 7 : timeframe.in_seconds() >= 3600 ? bearScore >= 9 : passesGradeFilter(bearScore)

rawBuy  = uprng and crossover_hband_eff and hl_bull and vwma_bull and adxGatePassedBull and bullScore >= minConfScore and gradeOkBull and not counterTrendBuy  and not mtfBlockBuy  and not conflictBlockBuy  and bullPurityOk and qualityGateBull
rawSell = not uprng and crossunder_lowband_eff and hl_bear and adxGatePassedBear and bearScore >= minConfScore and gradeOkBear and not counterTrendSell and not mtfBlockSell and not conflictBlockSell and bearPurityOk and qualityGateBear
bool legOkBuy  = not inBuyLeg
bool legOkSell = not inSellLeg

var int  consecutiveLosses = 0
var int  circuitBreakerBar = -999
int circuitBreakerCooldown = 10 + math.max(0, consecutiveLosses - 3) * 10
bool circuitBreakerOn = consecutiveLosses >= 3 and (bar_index - circuitBreakerBar) < circuitBreakerCooldown

int minBarsBetweenEff = timeframe.in_seconds() <= 900 ? 1 : minBarsBetween

float sqsGate15m   = timeframe.in_seconds() <= 900 ? 70.0 : 0.0
bool  sqsGate15mOk = timeframe.in_seconds() <= 900 ? (sqsBull >= sqsGate15m or sqsBear >= sqsGate15m) : true
bool buyCondition  = rawBuy  and legOkBuy  and barsSinceSig >= minBarsBetweenEff and chopOkBuy  and timeAllowed and not circuitBreakerOn and (timeframe.in_seconds() > 900 or sqsBull >= 70.0)
bool sellCondition = rawSell and legOkSell and barsSinceSig >= minBarsBetweenEff and chopOkSell and timeAllowed and not circuitBreakerOn and (timeframe.in_seconds() > 900 or sqsBear >= 70.0)
bool confirmedBuy  = buyCondition  and barstate.isconfirmed
bool confirmedSell = sellCondition and barstate.isconfirmed

if confirmedBuy
    inBuyLeg      := true
    inSellLeg     := false
    lastSigBar    := bar_index
    lastSigPrice  := close
    lastSigDir    := 1
    atrAtLastSig  := atrVal
    frozenScore   := float(bullScore)
    frozenGrade   := getGrade(bullScore)
    frozenDir     := "LONG"

if confirmedSell
    inSellLeg     := true
    inBuyLeg      := false
    lastSigBar    := bar_index
    lastSigPrice  := close
    lastSigDir    := -1
    atrAtLastSig  := atrVal
    frozenScore   := float(bearScore)
    frozenGrade   := getGrade(bearScore)
    frozenDir     := "SHORT"

// ══════════════════════════════════════════════════════════════════════════════
// 🔬 GATE FUNNEL AUDIT (additive only, zero effect on signal logic)
// Answers "raw trigger fire rate" — counts bars surviving each gate stage.
// ══════════════════════════════════════════════════════════════════════════════
bool funnelTriggerBull = uprng and crossover_hband_eff
bool funnelTriggerBear = not uprng and crossunder_lowband_eff

var int fnPullbackBullN = 0
var int fnPullbackBearN = 0
var int fnBaseBullN     = 0
var int fnBaseBearN     = 0
var int fnFlipBullN     = 0
var int fnFlipBearN     = 0
if showSignalAudit and barstate.isconfirmed
    fnPullbackBullN += pullbackResumeBull ? 1 : 0
    fnPullbackBearN += pullbackResumeBear ? 1 : 0
    fnBaseBullN     += baseResumeBull     ? 1 : 0
    fnBaseBearN     += baseResumeBear     ? 1 : 0
    fnFlipBullN     += flipTriggerBull    ? 1 : 0
    fnFlipBearN     += flipTriggerBear    ? 1 : 0
bool funnelADXBull     = funnelTriggerBull and adxGatePassedBull
bool funnelADXBear     = funnelTriggerBear and adxGatePassedBear
bool funnelScoreBull   = funnelADXBull and bullScore >= minConfScore and gradeOkBull
bool funnelScoreBear   = funnelADXBear and bearScore >= minConfScore and gradeOkBear
bool funnelPurityBull  = funnelScoreBull and bullPurityOk
bool funnelPurityBear  = funnelScoreBear and bearPurityOk
bool funnelCTBull      = funnelPurityBull and not counterTrendBuy
bool funnelCTBear      = funnelPurityBear and not counterTrendSell
bool funnelQGBull      = funnelCTBull and qualityGateBull
bool funnelQGBear      = funnelCTBear and qualityGateBear

var int fnTriggerBullN = 0
var int fnTriggerBearN = 0
var int fnADXBullN     = 0
var int fnADXBearN     = 0
var int fnScoreBullN   = 0
var int fnScoreBearN   = 0
var int fnPurityBullN  = 0
var int fnPurityBearN  = 0
var int fnCTBullN      = 0
var int fnCTBearN      = 0
var int fnQGBullN      = 0
var int fnQGBearN      = 0
var int fnConfirmBullN = 0
var int fnConfirmBearN = 0
var int fnQGRegimeBullN  = 0
var int fnQGSlopeBullN   = 0
var int fnQGSTBullN      = 0
var int fnQGVWAPBullN    = 0
var int fnQGPOCBullN     = 0
var int fnQGEMAExtBullN  = 0

if showSignalAudit and barstate.isconfirmed
    fnTriggerBullN += funnelTriggerBull ? 1 : 0
    fnTriggerBearN += funnelTriggerBear ? 1 : 0
    if funnelCTBull
        fnQGRegimeBullN  += regimeAllowsSignal  ? 1 : 0
        fnQGSlopeBullN   += ema200SlopeBullHard ? 1 : 0
        fnQGSTBullN      += stConfirmBull       ? 1 : 0
        fnQGVWAPBullN    += vwapConfirmBull     ? 1 : 0
        fnQGPOCBullN     += pocDistOk           ? 1 : 0
        fnQGEMAExtBullN  += ema200ExtOk         ? 1 : 0
    fnADXBullN     += funnelADXBull     ? 1 : 0
    fnADXBearN     += funnelADXBear     ? 1 : 0
    fnScoreBullN   += funnelScoreBull   ? 1 : 0
    fnScoreBearN   += funnelScoreBear   ? 1 : 0
    fnPurityBullN  += funnelPurityBull  ? 1 : 0
    fnPurityBearN  += funnelPurityBear  ? 1 : 0
    fnCTBullN      += funnelCTBull      ? 1 : 0
    fnCTBearN      += funnelCTBear      ? 1 : 0
    fnQGBullN      += funnelQGBull      ? 1 : 0
    fnQGBearN      += funnelQGBear      ? 1 : 0
    fnConfirmBullN += confirmedBuy      ? 1 : 0
    fnConfirmBearN += confirmedSell     ? 1 : 0

var table fnTable = table.new(position.middle_left, 3, 17, bgcolor=color.new(#000000, 15), border_width=1, border_color=color.new(#80DEEA, 40))
if showSignalAudit and barstate.islast
    table.cell(fnTable, 0, 0, "GATE FUNNEL",     text_color=color.white, text_size=size.small, bgcolor=color.new(#263238, 0))
    table.cell(fnTable, 1, 0, "BULL",            text_color=color.new(#00E676, 0), text_size=size.small, bgcolor=color.new(#263238, 0))
    table.cell(fnTable, 2, 0, "BEAR",            text_color=color.new(#FF5252, 0), text_size=size.small, bgcolor=color.new(#263238, 0))
    table.cell(fnTable, 0, 1, "1. Trigger",       text_color=color.white, text_size=size.small)
    table.cell(fnTable, 1, 1, str.tostring(fnTriggerBullN), text_color=color.white, text_size=size.small)
    table.cell(fnTable, 2, 1, str.tostring(fnTriggerBearN), text_color=color.white, text_size=size.small)
    table.cell(fnTable, 0, 2, "2. +ADX",          text_color=color.white, text_size=size.small)
    table.cell(fnTable, 1, 2, str.tostring(fnADXBullN), text_color=color.white, text_size=size.small)
    table.cell(fnTable, 2, 2, str.tostring(fnADXBearN), text_color=color.white, text_size=size.small)
    table.cell(fnTable, 0, 3, "3. +Score/Grade",  text_color=color.white, text_size=size.small)
    table.cell(fnTable, 1, 3, str.tostring(fnScoreBullN), text_color=color.white, text_size=size.small)
    table.cell(fnTable, 2, 3, str.tostring(fnScoreBearN), text_color=color.white, text_size=size.small)
    table.cell(fnTable, 0, 4, "4. +Purity",       text_color=color.white, text_size=size.small)
    table.cell(fnTable, 1, 4, str.tostring(fnPurityBullN), text_color=color.white, text_size=size.small)
    table.cell(fnTable, 2, 4, str.tostring(fnPurityBearN), text_color=color.white, text_size=size.small)
    table.cell(fnTable, 0, 5, "5. +CounterTrend", text_color=color.white, text_size=size.small)
    table.cell(fnTable, 1, 5, str.tostring(fnCTBullN), text_color=color.white, text_size=size.small)
    table.cell(fnTable, 2, 5, str.tostring(fnCTBearN), text_color=color.white, text_size=size.small)
    table.cell(fnTable, 0, 6, "6. +QualityGate",  text_color=color.white, text_size=size.small)
    table.cell(fnTable, 1, 6, str.tostring(fnQGBullN), text_color=color.white, text_size=size.small)
    table.cell(fnTable, 2, 6, str.tostring(fnQGBearN), text_color=color.white, text_size=size.small)
    table.cell(fnTable, 0, 7, "7. Confirmed",     text_color=color.yellow, text_size=size.small)
    table.cell(fnTable, 1, 7, str.tostring(fnConfirmBullN), text_color=color.yellow, text_size=size.small)
    table.cell(fnTable, 2, 7, str.tostring(fnConfirmBearN), text_color=color.yellow, text_size=size.small)
    table.cell(fnTable, 0, 8, "raw: hband-pullback", text_color=color.new(#80DEEA, 0), text_size=size.small)
    table.cell(fnTable, 1, 8, str.tostring(fnPullbackBullN), text_color=color.new(#80DEEA, 0), text_size=size.small)
    table.cell(fnTable, 2, 8, str.tostring(fnPullbackBearN), text_color=color.new(#80DEEA, 0), text_size=size.small)
    table.cell(fnTable, 0, 9, "raw: base-resume",    text_color=color.new(#80DEEA, 0), text_size=size.small)
    table.cell(fnTable, 1, 9, str.tostring(fnBaseBullN), text_color=color.new(#80DEEA, 0), text_size=size.small)
    table.cell(fnTable, 2, 9, str.tostring(fnBaseBearN), text_color=color.new(#80DEEA, 0), text_size=size.small)
    table.cell(fnTable, 0, 10, "raw: dir-flip",       text_color=color.new(#80DEEA, 0), text_size=size.small)
    table.cell(fnTable, 1, 10, str.tostring(fnFlipBullN), text_color=color.new(#80DEEA, 0), text_size=size.small)
    table.cell(fnTable, 2, 10, str.tostring(fnFlipBearN), text_color=color.new(#80DEEA, 0), text_size=size.small)
    table.cell(fnTable, 0, 11, "── QG sub-conditions (bull, of CT-passing signals) ──", text_color=color.yellow, text_size=size.small)
    table.merge_cells(fnTable, 0, 11, 2, 11)
    table.cell(fnTable, 0, 12, "QG: regime ok",    text_color=color.new(#80DEEA, 0), text_size=size.small)
    table.cell(fnTable, 1, 12, str.tostring(fnQGRegimeBullN),  text_color=color.new(#80DEEA, 0), text_size=size.small)
    table.cell(fnTable, 2, 12, "/" + str.tostring(fnCTBullN),  text_color=color.new(#80DEEA, 0), text_size=size.small)
    table.cell(fnTable, 0, 13, "QG: ema slope ok", text_color=color.new(#80DEEA, 0), text_size=size.small)
    table.cell(fnTable, 1, 13, str.tostring(fnQGSlopeBullN),   text_color=color.new(#80DEEA, 0), text_size=size.small)
    table.cell(fnTable, 2, 13, "/" + str.tostring(fnCTBullN),  text_color=color.new(#80DEEA, 0), text_size=size.small)
    table.cell(fnTable, 0, 14, "QG: ST ok",        text_color=color.new(#80DEEA, 0), text_size=size.small)
    table.cell(fnTable, 1, 14, str.tostring(fnQGSTBullN),      text_color=color.new(#80DEEA, 0), text_size=size.small)
    table.cell(fnTable, 2, 14, "/" + str.tostring(fnCTBullN),  text_color=color.new(#80DEEA, 0), text_size=size.small)
    table.cell(fnTable, 0, 15, "QG: VWAP ok",      text_color=color.new(#80DEEA, 0), text_size=size.small)
    table.cell(fnTable, 1, 15, str.tostring(fnQGVWAPBullN),    text_color=color.new(#80DEEA, 0), text_size=size.small)
    table.cell(fnTable, 2, 15, "/" + str.tostring(fnCTBullN),  text_color=color.new(#80DEEA, 0), text_size=size.small)
    table.cell(fnTable, 0, 16, "QG: POC dist ok",  text_color=color.new(#80DEEA, 0), text_size=size.small)
    table.cell(fnTable, 1, 16, str.tostring(fnQGPOCBullN),     text_color=color.new(#80DEEA, 0), text_size=size.small)
    table.cell(fnTable, 2, 16, "/" + str.tostring(fnCTBullN),  text_color=color.new(#80DEEA, 0), text_size=size.small)
// ══════════════════════════════════════════════════════════════════════════════
// VISIBLE INPUT VALIDATION
// ══════════════════════════════════════════════════════════════════════════════
var label validationLabel = na

if barstate.isfirst
    string warnMsg = ""
    if tp1Mult >= tp2Mult
        warnMsg := warnMsg + "⚠ TP1 ≥ TP2! Auto-clamped.\n"
        log.warning("TP1 Mult must be < TP2 Mult. Auto-clamping.")
    if tp2Mult >= tp3Mult
        warnMsg := warnMsg + "⚠ TP2 ≥ TP3! Auto-clamped.\n"
        log.warning("TP2 Mult must be < TP3 Mult. Auto-clamping.")
    if accountRiskPct > 5.0
        warnMsg := warnMsg + "⚠ Risk " + str.tostring(accountRiskPct) + "% is aggressive.\n"
        log.warning("Risk " + str.tostring(accountRiskPct) + "% is aggressive.")
    if allowedStart >= allowedEnd and useTimeFilter
        warnMsg := warnMsg + "⚠ Time filter: start ≥ end blocks ALL signals!\n"
        log.warning("Time filter: start hour >= end hour will block ALL signals.")
    if str.length(warnMsg) > 0
        validationLabel := label.new(bar_index + 5, high, "ALPHAEDGE v6.10 CONFIG WARNINGS:\n" + warnMsg, style=label.style_label_left, color=color.new(#FF6D00, 10), textcolor=color.white, size=size.normal, tooltip="Fix these settings in the indicator inputs panel.")

// ══════════════════════════════════════════════════════════════════════════════
// TRADE MANAGEMENT (Structure-first SL + early breakeven trail)
// ══════════════════════════════════════════════════════════════════════════════
var float entryPrice = na
var float slPrice    = na
var float tp1Price   = na
var float tp2Price   = na
var float tp3Price   = na
var float trailPrice = na
var bool  tp1Hit     = false
var bool  tp2Hit     = false
var bool  tp3Hit     = false
var bool  slHit      = false
var int   tradeDir   = 0
var float tradeRisk  = na
var int   entryBar   = 0
var string lastExitReason = "—"

var int exitDirSnapshot = 0

var bool reEntryArmed    = false
var float reEntryTrigger = na
var int originalEntryBar = 0
var int reEntryArmedBar  = 0

var float activeTradeSQS    = na
var string activeTradeGrade = "—"

// ── STRUCTURE-FIRST SL CALCULATION ───────────────────────────────────────────
// ─────────────────────────────────────────────────────────────────────────────
f_calcSL(bool isLong, float entry) =>
    float effSLMult = slMult
    if useDynamicRR
        if regimeVolatile
            effSLMult := dynRRSLHighMult
        else if regimeQuiet
            effSLMult := dynRRSLLowMult
    float atrStop = isLong ? entry - atrVal * effSLMult : entry + atrVal * effSLMult
    float result  = atrStop
    if useStructSL
        float sStop  = isLong ? recentSwingLow - atrVal * structBuffer : recentSwingHigh + atrVal * structBuffer
        float merged = isLong ? math.min(atrStop, sStop) : math.max(atrStop, sStop)
        float minD   = atrVal * minSLDistance
        float effMaxSL = regimeVolatile ? maxSLDistVol : maxSLDistance
        float maxD   = atrVal * effMaxSL
        float dist   = math.abs(entry - merged)
        result := dist < minD ? (isLong ? entry - minD : entry + minD) :
                  dist > maxD ? (isLong ? entry - maxD : entry + maxD) : merged
    float safeMin = atrVal * 0.5
    float finalDist = math.abs(entry - result)
    result := finalDist < safeMin ? (isLong ? entry - safeMin : entry + safeMin) : result
    result

f_effTP1Mult() =>
    float result = tp1MultSafe
    if useDynamicRR
        if regimeVolatile
            result := dynVolTP1Mult
        else if regimeQuiet
            result := dynQtTP1Mult
    result

f_effTP2Mult() =>
    float result = tp2MultSafe
    if useDynamicRR
        if regimeVolatile
            result := dynVolTP2Mult
        else if regimeQuiet
            result := dynQtTP2Mult
    result

var string lastSLMode = "—"

f_effTP3Mult() =>
    float result = tp3MultSafe
    if useDynamicRR
        if regimeVolatile
            result := dynVolTP3Mult
        else if regimeQuiet
            result := dynQtTP3Mult
    result

if confirmedBuy
    tp1Hit         := false
    tp2Hit         := false
    tp3Hit         := false
    slHit          := false
    entryPrice     := close
    tradeDir       := 1
    slPrice        := f_calcSL(true, close)
    tradeRisk      := math.abs(close - slPrice)
    // Determine which SL branch fired for display
    float _slNative_b = recentSwingLow - atrVal * structBuffer
    float _slDist_b   = math.abs(close - _slNative_b)
    float _effMax_b = regimeVolatile ? maxSLDistVol : maxSLDistance
    lastSLMode     := _slDist_b > atrVal * _effMax_b ? "⚠ Capped (" + str.tostring(_effMax_b) + "×ATR)" : _slDist_b < atrVal * minSLDistance ? "▲ Floored (" + str.tostring(minSLDistance) + "×ATR)" : "✓ Structure"
    tp1Price       := close + tradeRisk * f_effTP1Mult()
    tp2Price       := close + tradeRisk * f_effTP2Mult()
    tp3Price       := close + tradeRisk * f_effTP3Mult()
    trailPrice     := slPrice
    entryBar       := bar_index
    originalEntryBar := bar_index
    lastExitReason := "—"
    activeTradeSQS := sqsBull
    activeTradeGrade := getGrade(bullScore)
    reEntryArmed   := false
    exitDirSnapshot := 1

if confirmedSell
    tp1Hit         := false
    tp2Hit         := false
    tp3Hit         := false
    slHit          := false
    entryPrice     := close
    tradeDir       := -1
    slPrice        := f_calcSL(false, close)
    tradeRisk      := math.abs(close - slPrice)
    // Determine which SL branch fired for display
    float _slNative_s = recentSwingHigh + atrVal * structBuffer
    float _slDist_s   = math.abs(close - _slNative_s)
    float _effMax_s = regimeVolatile ? maxSLDistVol : maxSLDistance
    lastSLMode     := _slDist_s > atrVal * _effMax_s ? "⚠ Capped (" + str.tostring(_effMax_s) + "×ATR)" : _slDist_s < atrVal * minSLDistance ? "▲ Floored (" + str.tostring(minSLDistance) + "×ATR)" : "✓ Structure"
    tp1Price       := close - tradeRisk * f_effTP1Mult()
    tp2Price       := close - tradeRisk * f_effTP2Mult()
    tp3Price       := close - tradeRisk * f_effTP3Mult()
    trailPrice     := slPrice
    entryBar       := bar_index
    originalEntryBar := bar_index
    lastExitReason := "—"
    activeTradeSQS := sqsBear
    activeTradeGrade := getGrade(bearScore)
    reEntryArmed   := false
    exitDirSnapshot := -1

bool canCheck = bar_index > (entryBar + 2) and tradeDir != 0 and not slHit

// ══════════════════════════════════════════════════════════════════════════════
// DYNAMIC ATR TRAILING STOP — v6.10
// ──────────────────────────────────────────────────────────────────────────────
float trailAtrMultEff = nz(trailAtrMult, slMult)

bool rsiExhaustLong  = rsiVal > 72 and rsiVal < rsiVal[1] and rsiVal[1] < rsiVal[2]
bool rsiExhaustShort = rsiVal < 28 and rsiVal > rsiVal[1] and rsiVal[1] > rsiVal[2]
// ── EARLY BREAKEVEN DETECTION ─────────────────────────────────────────────────
var bool earlyBEArmed = false

if confirmedBuy or confirmedSell
    earlyBEArmed := false

if canCheck and tradeDir == 1
    float profitR = not na(entryPrice) and not na(tradeRisk) and tradeRisk > 0 ? (high - entryPrice) / tradeRisk : 0.0
    if profitR >= 0.75 and not earlyBEArmed
        earlyBEArmed := true

if canCheck and tradeDir == -1
    float profitR = not na(entryPrice) and not na(tradeRisk) and tradeRisk > 0 ? (entryPrice - low) / tradeRisk : 0.0
    if profitR >= 0.75 and not earlyBEArmed
        earlyBEArmed := true

if canCheck and tradeDir == 1
    float trailFloor = slPrice
    // Early BE: once 0.75R reached, floor moves to entry + 0.3R
    if earlyBEArmed
        trailFloor := math.max(trailFloor, entryPrice + tradeRisk * 0.3)
    // TP stage floors (override early BE with better levels as trade progresses)
    if tp1Hit
        trailFloor := math.max(trailFloor, entryPrice + tradeRisk * 0.5)
    if tp2Hit
        trailFloor := math.max(trailFloor, tp1Price)
    if tp3Hit
        trailFloor := math.max(trailFloor, tp2Price)
    bool trailEngaged = timeframe.in_seconds() >= 3600 ? (regimeTrending ? tp1Hit : earlyBEArmed) : earlyBEArmed
    float newTrail = trailFloor
    if trailEngaged
        float atrTrailLevel = high - atrVal * trailAtrMultEff
        newTrail := math.max(atrTrailLevel, trailFloor)
    trailPrice := math.max(trailPrice, newTrail)

    if low <= trailPrice
        slHit := true
    else
        if high >= tp1Price and not tp1Hit
            tp1Hit := true
            if useReEntry
                reEntryArmed    := true
                reEntryArmedBar := bar_index
                reEntryTrigger  := entryPrice + (tp1Price - entryPrice) * (1.0 - reEntryPullbackPct)
        if high >= tp2Price and not tp2Hit
            tp2Hit := true
        if high >= tp3Price and not tp3Hit
            tp3Hit := true
        if rsiExhaustLong and tp2Hit and not tp3Hit and not slHit
            slHit := true

if canCheck and tradeDir == -1
    float trailFloor = slPrice
    // Early BE: once 0.75R reached, floor moves to entry - 0.3R
    if earlyBEArmed
        trailFloor := math.min(trailFloor, entryPrice - tradeRisk * 0.3)
    // TP stage floors
    if tp1Hit
        trailFloor := math.min(trailFloor, entryPrice - tradeRisk * 0.5)
    if tp2Hit
        trailFloor := math.min(trailFloor, tp1Price)
    if tp3Hit
        trailFloor := math.min(trailFloor, tp2Price)
    bool trailEngaged = timeframe.in_seconds() >= 3600 ? (regimeTrending ? tp1Hit : earlyBEArmed) : earlyBEArmed
    float newTrail = trailFloor
    if trailEngaged
        float atrTrailLevel = low + atrVal * trailAtrMultEff
        newTrail := math.min(atrTrailLevel, trailFloor)
    trailPrice := math.min(trailPrice, newTrail)

    if high >= trailPrice
        slHit := true
    else
        if low <= tp1Price and not tp1Hit
            tp1Hit := true
            if useReEntry
                reEntryArmed    := true
                reEntryArmedBar := bar_index
                reEntryTrigger  := entryPrice - (entryPrice - tp1Price) * (1.0 - reEntryPullbackPct)
        if low <= tp2Price and not tp2Hit
            tp2Hit := true
        if low <= tp3Price and not tp3Hit
            tp3Hit := true
        if rsiExhaustShort and tp2Hit and not tp3Hit and not slHit
            slHit := true

bool protectiveExitArmed = tp1Hit or earlyBEArmed
bool trueSLHit       = slHit and not slHit[1] and not protectiveExitArmed
bool trailProfitExit = slHit and not slHit[1] and protectiveExitArmed

if trueSLHit or trailProfitExit
    exitDirSnapshot := tradeDir

// ── Signal label arrays — declared here so exit blocks can access them ──
var sigLabels = array.new_label()
var sigBars   = array.new_int()

// ══════════════════════════════════════════════════════════════════════════════
// TRADE EXIT PROCESSING
// ══════════════════════════════════════════════════════════════════════════════
if trueSLHit
    // Stamp loss outcome into signal label immediately
    if array.size(sigLabels) > 0
        for _i = 0 to array.size(sigLabels) - 1
            if _i < array.size(sigLabels) and _i < array.size(sigBars)
                if array.get(sigBars, _i) == entryBar
                    label _lbl = array.get(sigLabels, _i)
                    string _txt = label.get_text(_lbl)
                    _txt := str.replace_all(_txt, "⚡ LIVE ", "")
                    _txt := str.replace_all(_txt, "🟢 LIVE ", "")
                    _txt := str.replace_all(_txt, "🔴 LIVE ", "")
                    label.set_text(_lbl, "❌ SL -1R\n" + _txt)
                    label.set_color(_lbl, color.new(#B71C1C, 0))
                    label.set_textcolor(_lbl, color.white)
    inBuyLeg       := false
    inSellLeg      := false
    lastSigPrice   := close
    lastExitReason := "SL Hit"
    tradeDir       := 0
    reEntryArmed   := false
    activeTradeSQS := na
    activeTradeGrade := "—"
    consecutiveLosses := consecutiveLosses + 1
    if consecutiveLosses >= 3
        circuitBreakerBar := bar_index

if trailProfitExit
    float exitR = exitDirSnapshot == 1 ? (trailPrice - entryPrice) / tradeRisk : (entryPrice - trailPrice) / tradeRisk
    if tp3Hit
        lastExitReason := "Closed Trail TP3 (+" + str.tostring(math.round(exitR, 2)) + "R)"
    else if tp2Hit
        lastExitReason := "Closed Trail TP2 (+" + str.tostring(math.round(exitR, 2)) + "R)"
    else if tp1Hit
        if math.abs(trailPrice - entryPrice) < syminfo.mintick * 5
            lastExitReason := "Closed BE (TP1 hit, trail→BE)"
        else
            lastExitReason := "Closed Trail TP1 (+" + str.tostring(math.round(exitR, 2)) + "R)"
    else
        lastExitReason := "Closed Early BE (+" + str.tostring(math.round(exitR, 2)) + "R)"
    // Stamp outcome into the active signal label immediately at exit
    if array.size(sigLabels) > 0
        for _i = 0 to array.size(sigLabels) - 1
            if _i < array.size(sigLabels) and _i < array.size(sigBars)
                if array.get(sigBars, _i) == entryBar
                    label _lbl = array.get(sigLabels, _i)
                    string _txt = label.get_text(_lbl)
                    _txt := str.replace_all(_txt, "⚡ LIVE ", "")
                    _txt := str.replace_all(_txt, "🟢 LIVE ", "")
                    _txt := str.replace_all(_txt, "🔴 LIVE ", "")
                    bool _isWin = exitR > 0
                    string _outcome = tp3Hit ? "🏆 TP3 +" + str.tostring(math.round(exitR, 2)) + "R" : tp2Hit ? "✅ TP2 +" + str.tostring(math.round(exitR, 2)) + "R" : tp1Hit ? "✅ TP1 +" + str.tostring(math.round(exitR, 2)) + "R" : exitR > 0 ? "✅ BE+ +" + str.tostring(math.round(exitR, 2)) + "R" : "⚠️ BE"
                    label.set_text(_lbl, _outcome + "\n" + _txt)
                    label.set_color(_lbl, tp3Hit ? color.new(#00C853, 0) : tp2Hit ? color.new(#2E7D32, 0) : tp1Hit ? color.new(#388E3C, 0) : color.new(#F9A825, 0))
                    label.set_textcolor(_lbl, color.white)
    inBuyLeg  := false
    inSellLeg := false
    tradeDir  := 0
    reEntryArmed := false
    activeTradeSQS := na
    activeTradeGrade := "—"
    consecutiveLosses := 0

// Ensure sigLabels/sigBars are accessible in this scope
bool   tradeActive = tradeDir != 0 and not slHit
string tradeStatus = lastExitReason
if tradeActive and tp3Hit
    tradeStatus := "TP3 ✓ — Trailing"
else if tradeActive and tp2Hit
    tradeStatus := "TP2 ✓ — Trailing"
else if tradeActive and tp1Hit
    tradeStatus := "TP1 ✓ — Trailing"
else if tradeActive
    tradeStatus := "Active"

// ══════════════════════════════════════════════════════════════════════════════
// SMART RE-ENTRY DETECTION (Leg state locked on execution)
// ══════════════════════════════════════════════════════════════════════════════
if useReEntry and reEntryArmed and (bar_index - reEntryArmedBar) > 20
    reEntryArmed    := false
    reEntryTrigger  := na

bool reEntrySignal = false

// Quality gate for re-entries (regime + ST + VWAP must still agree)
bool reEntryGateActive    = useReEntryGate and not tp2Hit
bool reEntryQualGateLong  = not reEntryGateActive or (regimeAllowsSignal and stConfirmBull and vwapConfirmBull)
bool reEntryQualGateShort = not reEntryGateActive or (regimeAllowsSignal and stConfirmBear and vwapConfirmBear)
if useReEntry and reEntryArmed and not slHit and barstate.isconfirmed
    if tradeDir == 1 and low <= reEntryTrigger and close > reEntryTrigger and bullScore >= reEntryMinScore and reEntryQualGateLong
        reEntrySignal := true
    else if tradeDir == -1 and high >= reEntryTrigger and close < reEntryTrigger and bearScore >= reEntryMinScore and reEntryQualGateShort
        reEntrySignal := true

if reEntrySignal
    bool isLongReEntry = tradeDir == 1
    tp1Hit := false
    tp2Hit := false
    tp3Hit := false
    slHit  := false
    earlyBEArmed := false
    entryPrice := close
    slPrice    := f_calcSL(isLongReEntry, close)
    tradeRisk  := math.abs(close - slPrice)
    if isLongReEntry
        tp1Price := close + tradeRisk * f_effTP1Mult()
        tp2Price := close + tradeRisk * f_effTP2Mult()
        tp3Price := close + tradeRisk * f_effTP3Mult()
    else
        tp1Price := close - tradeRisk * f_effTP1Mult()
        tp2Price := close - tradeRisk * f_effTP2Mult()
        tp3Price := close - tradeRisk * f_effTP3Mult()
    trailPrice := slPrice
    entryBar   := bar_index
    lastExitReason := "—"
    activeTradeSQS := isLongReEntry ? sqsBull : sqsBear
    activeTradeGrade := getGrade(isLongReEntry ? bullScore : bearScore)

    // Lock leg state to prevent duplicate entries on next bar
    if isLongReEntry
        inBuyLeg  := true
        inSellLeg := false
    else
        inSellLeg := true
        inBuyLeg  := false

    lastSigBar   := bar_index
    lastSigPrice := close
    lastSigDir   := tradeDir
    atrAtLastSig := atrVal
    reEntryArmed    := false
    reEntryTrigger  := na

// ══════════════════════════════════════════════════════════════════════════════
// REALISTIC BACKTEST (Mark-to-market open trade DD)
// ══════════════════════════════════════════════════════════════════════════════
var int   btTrades    = 0
var int   btWins      = 0
var int   btLosses    = 0
var float btTotalR    = 0.0
var float btGrossWin  = 0.0
var float btGrossLoss = 0.0
var bool  btActive    = false
var int   btDir       = 0
var float btEntry     = na
var float btRisk      = na
var bool  btTP1       = false
var bool  btTP2       = false
var bool  btTP3       = false

var float btPeakR         = 0.0
var float btMaxDD         = 0.0
var float btCurrentDD     = 0.0
var int   btWinStreak     = 0
var int   btLossStreak    = 0
var int   btMaxWinStreak  = 0
var int   btMaxLossStreak = 0
var float btBestTrade     = 0.0
var float btWorstTrade    = 0.0

// Mark-to-market uses updated position split (40/35/25)
float btOpenUnrealizedR = 0.0
if btActive and not na(btEntry) and not na(btRisk) and btRisk > 0
    float rawMTM = btDir == 1 ? (close - btEntry) / btRisk : (btEntry - close) / btRisk
    float realizedSoFar = 0.0
    realizedSoFar += btTP1 ? tp1MultSafe * 0.40 : 0.0
    realizedSoFar += btTP2 ? tp2MultSafe * 0.35 : 0.0
    realizedSoFar += btTP3 ? tp3MultSafe * 0.25 : 0.0
    float openPortion = 1.0 - realizedSoFar / (tp3MultSafe > 0 ? tp3MultSafe : 1.0)
    openPortion := math.max(0.0, math.min(1.0, openPortion))
    btOpenUnrealizedR := rawMTM * openPortion

float btEffectiveTotalR = btTotalR + btOpenUnrealizedR
if btEffectiveTotalR > btPeakR
    btPeakR := btEffectiveTotalR
btCurrentDD := math.max(0.0, btPeakR - btEffectiveTotalR)
if btCurrentDD > btMaxDD
    btMaxDD := btCurrentDD

// Correct weighted split R calculation.
// Each TP closes its fraction at the *marginal* gain from the prior level:
// TP1 closes 40% at tp1Mult R from entry.
// TP2 closes 35% at tp2Mult R from entry (marginal from TP1→TP2 was already earned on that 35%).
// TP3 closes 25% at tp3Mult R from entry.
// Total realized when all 3 hit: 0.40×R1 + 0.35×R2 + 0.25×R3
// EV at 40% WR: 0.40×(0.40×1 + 0.35×2 + 0.25×3.5) - 0.60×1 = +0.222R/trade
f_realizedR() =>
    float r = 0.0
    r += btTP1 ? tp1MultSafe * 0.40 : 0.0
    r += btTP2 ? tp2MultSafe * 0.35 : 0.0
    r += btTP3 ? tp3MultSafe * 0.25 : 0.0
    r

f_openPortion() =>
    float p = 1.0
    p -= btTP1 ? 0.40 : 0.0
    p -= btTP2 ? 0.35 : 0.0
    p -= btTP3 ? 0.25 : 0.0
    p

bool btCloseReversal = btActive and ((confirmedBuy and btDir == -1) or (confirmedSell and btDir == 1))
bool btCloseStop     = btActive and (trueSLHit or trailProfitExit)

float btClosedR = 0.0
bool  btClosed  = false

if btCloseReversal
    float realized = f_realizedR()
    float openP    = f_openPortion()
    float exitMove = btDir == 1 ? (close - btEntry) / btRisk : (btEntry - close) / btRisk
    btClosedR := realized + exitMove * openP
    btClosed  := true

if btCloseStop and not btClosed
    float realized = f_realizedR()
    float openP    = f_openPortion()
    float trailR = exitDirSnapshot == 1 ? (trailPrice - entryPrice) / tradeRisk : (entryPrice - trailPrice) / tradeRisk
    btClosedR := realized + trailR * openP
    btClosed  := true

if btClosed
    btTrades += 1
    btTotalR += btClosedR
    if btClosedR > 0
        btWins       += 1
        btGrossWin   += btClosedR
        btWinStreak  += 1
        btLossStreak := 0
        btMaxWinStreak := math.max(btMaxWinStreak, btWinStreak)
        btBestTrade := math.max(btBestTrade, btClosedR)
    else if btClosedR < 0
        btLosses      += 1
        btGrossLoss   += math.abs(btClosedR)
        btLossStreak  += 1
        btWinStreak   := 0
        btMaxLossStreak := math.max(btMaxLossStreak, btLossStreak)
        btWorstTrade := math.min(btWorstTrade, btClosedR)
    else
        btWinStreak  := 0
        btLossStreak := 0

    btOpenUnrealizedR := 0.0

    btActive := false
    btTP1    := false
    btTP2    := false
    btTP3    := false

if confirmedBuy
    btActive := true
    btDir    := 1
    btEntry  := close
    btRisk   := tradeRisk
    btTP1    := false
    btTP2    := false
    btTP3    := false
    
if confirmedSell
    btActive := true
    btDir    := -1
    btEntry  := close
    btRisk   := tradeRisk
    btTP1    := false
    btTP2    := false
    btTP3    := false
    
if btActive and tp1Hit and not btTP1
    btTP1 := true
if btActive and tp2Hit and not btTP2
    btTP2 := true
if btActive and tp3Hit and not btTP3
    btTP3 := true

btWinRate = btTrades > 0 ? btWins * 100.0 / btTrades : 0.0
btPF      = btGrossLoss > 0 ? btGrossWin / btGrossLoss : btGrossWin > 0 ? 999.0 : 0.0
btAvgR    = btTrades > 0 ? btTotalR / btTrades : 0.0

// ══════════════════════════════════════════════════════════════════════════════
// POSITION SIZING
// ══════════════════════════════════════════════════════════════════════════════
f_positionSize() =>
    float dollarRisk = accountSize * accountRiskPct / 100.0
    float slDist     = na(slPrice) or na(entryPrice) or tradeDir == 0 ? float(na) : math.abs(entryPrice - slPrice)
    float units      = na(slDist) or slDist <= 0 ? float(na) : dollarRisk / slDist
    [dollarRisk, units]

[posDollarRisk, posUnits] = f_positionSize()

// ══════════════════════════════════════════════════════════════════════════════
// GRADE-LEVEL PERFORMANCE
// ══════════════════════════════════════════════════════════════════════════════
var int aPlusTrades = 0
var int aPlusWins   = 0
var int aTrades     = 0
var int aWins       = 0
var int bTrades     = 0
var int bWins       = 0
var string btTradeGrade = "—"

var int trendingTrades = 0
var int trendingWins   = 0
var int volatileTrades = 0
var int volatileWins   = 0
var string btEntryRegime = "—"

if confirmedBuy
    btTradeGrade  := getGrade(bullScore)
    btEntryRegime := marketRegime
if confirmedSell
    btTradeGrade  := getGrade(bearScore)
    btEntryRegime := marketRegime

if btClosed
    if btTradeGrade == "A+"
        aPlusTrades += 1
        if btClosedR > 0
            aPlusWins += 1
    else if btTradeGrade == "A"
        aTrades += 1
        if btClosedR > 0
            aWins += 1
    else if btTradeGrade == "B"
        bTrades += 1
        if btClosedR > 0
            bWins += 1
    if btEntryRegime == "TRENDING"
        trendingTrades += 1
        if btClosedR > 0
            trendingWins += 1
    else if btEntryRegime == "VOLATILE"
        volatileTrades += 1
        if btClosedR > 0
            volatileWins += 1

aPlusWR = aPlusTrades > 0 ? aPlusWins * 100.0 / aPlusTrades : 0.0
aWR     = aTrades > 0 ? aWins * 100.0 / aTrades : 0.0
bWR     = bTrades > 0 ? bWins * 100.0 / bTrades : 0.0
float trendingWR = trendingTrades > 0 ? trendingWins * 100.0 / trendingTrades : 0.0
float volatileWR = volatileTrades > 0 ? volatileWins * 100.0 / volatileTrades : 0.0
// ══════════════════════════════════════════════════════════════════════════════
// COMPOSITE SCORE
// ══════════════════════════════════════════════════════════════════════════════
netScore  = bullScore - bearScore
compScore = float(netScore) + (totalMTFBull - 6) * 0.75

f_finalLabel(float cs) =>
    cs >= 9 ? "STRONG BUY" : cs >= 4 ? "BUY" : cs >= -3 ? "NEUTRAL" : cs >= -8 ? "SELL" : "STRONG SELL"

f_finalColor(float cs) =>
    cs >= 9 ? color.new(#00C853, 0) : cs >= 4 ? color.lime : cs >= -3 ? color.gray : cs >= -8 ? color.orange : color.red

// ══════════════════════════════════════════════════════════════════════════════
// ALERT COOLDOWN
// ══════════════════════════════════════════════════════════════════════════════
bool buyAlertOK  = true
bool sellAlertOK = true

if useAlertCooldown
    buyAlertOK  := (bar_index - lastBuyAlertBar)  >= alertCooldownBars
    sellAlertOK := (bar_index - lastSellAlertBar) >= alertCooldownBars

if useSQS
    float sqsBase = float(sqsMinForAlert)
    float sqsMinEff = timeframe.in_seconds() >= 3600 ? 
                      (regimeTrending ? sqsBase + 3.0 : 
                       regimeVolatile ? sqsBase - 5.0 : sqsBase) : 
                      sqsBase
    buyAlertOK  := buyAlertOK  and sqsBull >= sqsMinEff
    sellAlertOK := sellAlertOK and sqsBear >= sqsMinEff

bool confirmedBuyAlert  = confirmedBuy  and buyAlertOK
bool confirmedSellAlert = confirmedSell and sellAlertOK

if confirmedBuyAlert
    lastBuyAlertBar := bar_index
if confirmedSellAlert
    lastSellAlertBar := bar_index

// ══════════════════════════════════════════════════════════════════════════════
// SESSION DETECTION
// ══════════════════════════════════════════════════════════════════════════════
isNY     = not na(time("1", "0930-1600", "America/New_York"))
isLondon = not na(time("1", "0800-1630", "Europe/London"))
isAsia   = not na(time("1", "0900-1530", "Asia/Tokyo"))

// ── MOMENTUM / BIG MOVER CALCULATION ─────────────────────────────────────────
// Uses request.security to get yesterday's close cleanly
// dayClose[1] = confirmed prior session close, not intraday
float prevDayClose  = request.security(syminfo.tickerid, "D", close[1], 
                      barmerge.gaps_off, barmerge.lookahead_off)
float dayMovePct    = not na(prevDayClose) and prevDayClose > 0 ? 
                      (close - prevDayClose) / prevDayClose * 100.0 : 0.0

bool momoUpMove     = dayMovePct >=  momoThreshPct
bool momoDownMove   = dayMovePct <= -momoThreshPct
bool momoTriggered  = useMomoAlert and (momoUpMove or (not momoDirectional and momoDownMove))

// Once-per-day gate — resets when a new day starts
var bool momoFiredToday = false
var int  momoLastDay    = 0
int      todayInt       = year * 10000 + month * 100 + dayofmonth
if todayInt != momoLastDay
    momoFiredToday := false
    momoLastDay    := todayInt

bool momoAlertFire = momoTriggered and barstate.isconfirmed and
                     (not momoAlertOnce or not momoFiredToday)

if momoAlertFire
    momoFiredToday := true

// ══════════════════════════════════════════════════════════════════════════════
// VOLUME PROFILE
// ══════════════════════════════════════════════════════════════════════════════
vpPeriodBase = vpDepth == "Shallow" ? 100 : vpDepth == "Deep" ? 600 : 300
vpPeriodAdj  = timeframe.isweekly ? math.min(vpPeriodBase, 52) : timeframe.isdaily ? math.min(vpPeriodBase, 60) : vpPeriodBase
vpBins = 24

// pocPrice declared above signal engine (forward declaration)
var vpBoxes         = array.new_box()
var line  pocLine   = na
var label pocLabel  = na
var int   lastVPBar = na

vpH_global = ta.highest(high, vpPeriodAdj)
vpL_global = ta.lowest(low, vpPeriodAdj)

bool vpShouldDraw = showVP and barstate.islast and tradeDir == 0 and (na(lastVPBar) or bar_index != lastVPBar)
if vpShouldDraw
    lastVPBar := bar_index
    float vpH = vpH_global
    float vpL = vpL_global
    if not na(vpH) and not na(vpL) and vpH > vpL
        float vpStep = (vpH - vpL) / vpBins
        levels  = array.new_float(vpBins + 1, 0.0)
        volBins = array.new_float(vpBins, 0.0)
        for i = 0 to vpBins - 1
            array.set(levels, i, vpL + vpStep * i)
        array.set(levels, vpBins, vpH)
        int lookbackLen = math.min(vpPeriodAdj, bar_index + 1)
        for k = 0 to lookbackLen - 1
            float c      = nz(close[k], close)
            float v      = nz(volume[k], 0.0)
            float binRaw = (c - vpL) / vpStep
            int   bi     = int(math.max(0, math.min(vpBins - 1, math.floor(binRaw))))
            array.set(volBins, bi, array.get(volBins, bi) + v)
        float maxVol    = array.max(volBins)
        int   pocBin    = 0
        float pocBinVol = 0.0
        for i = 0 to vpBins - 1
            float v = array.get(volBins, i)
            if v > pocBinVol
                pocBinVol := v
                pocBin    := i
        float pocLow  = array.get(levels, pocBin)
        int   hiIdx   = pocBin + 1 < vpBins ? pocBin + 1 : vpBins
        float pocHigh = array.get(levels, hiIdx)
        pocPrice := (pocLow + pocHigh) / 2.0
        if array.size(vpBoxes) > 0
            for b2 in vpBoxes
                box.delete(b2)
            array.clear(vpBoxes)
        line.delete(pocLine)
        label.delete(pocLabel)
        int   baseX = bar_index + 2
        float currentPrice = close
        float currentPriceBinRaw = (currentPrice - vpL) / vpStep
        int   currentPriceBin = int(math.max(0, math.min(vpBins - 1, math.floor(currentPriceBinRaw))))
        for i = 0 to vpBins - 1
            float ll  = array.get(levels, i)
            int   hix = i + 1 < vpBins ? i + 1 : vpBins
            float hh  = array.get(levels, hix)
            float vol = array.get(volBins, i)
            float relV = maxVol > 0 ? vol / maxVol : 0.0
            int   barsWide = int(math.max(1, math.round(relV * vpWidth)))
            bool isActive = vpHideActive and currentPrice >= ll and currentPrice <= hh
            bool isPOC    = vol == maxVol
            color baseCol = currentPrice >= hh ? color.new(#9C27B0, 0) : color.new(#00BCD4, 0)
            int distFromPrice = math.abs(i - currentPriceBin)
            int distFadeBoost = math.min(30, distFromPrice * 3)
            int baseTransp = isPOC ? 15 : int(math.max(30, 85 - relV * 55))
            int finalTransp = math.min(92, baseTransp + distFadeBoost)
            color fillC = isActive ? color.new(THEME_TEXT_DIM, 80) : color.new(baseCol, finalTransp)
            color bordC = isPOC ? THEME_ACCENT : na
            int   bordW = isPOC ? 3 : 0
            b3 = box.new(baseX, hh, baseX + barsWide, ll, bgcolor=fillC, border_color=bordC, border_width=bordW)
            array.push(vpBoxes, b3)
        if showPOCLine and not na(pocPrice)
            int pocX2 = bar_index + vpWidth + 5
            float pocYAdjusted = pocPrice
            if tradeDir != 0 and not na(entryPrice)
                float distToEntry = math.abs(pocPrice - entryPrice)
                float distToTP1   = na(tp1Price) ? 999.0 : math.abs(pocPrice - tp1Price)
                float distToSL    = na(slPrice) ? 999.0 : math.abs(pocPrice - slPrice)
                float minSafeDist = atrVal * 0.4
                if distToEntry < minSafeDist or distToTP1 < minSafeDist or distToSL < minSafeDist
                    pocYAdjusted := pocPrice < entryPrice ? pocPrice - atrVal * 0.5 : pocPrice + atrVal * 0.5
            pocLabel := label.new(pocX2, pocYAdjusted, "◆ POC " + str.tostring(math.round(pocPrice, 2)), color=color.new(THEME_ACCENT, 0), textcolor=color.white, style=label.style_label_left, size=size.normal, tooltip="◆ POINT OF CONTROL\nHighest-volume price in " + str.tostring(vpPeriodAdj) + "-bar lookback.")

// ══════════════════════════════════════════════════════════════════════════════
// MULTI-TIMEFRAME POC
// ══════════════════════════════════════════════════════════════════════════════
pocLookback = 100

f_pocProxyFast() =>
    ta.vwma(hlc3, pocLookback)[1]

poc15m    = request.security(syminfo.tickerid, "15", f_pocProxyFast(), barmerge.gaps_off, barmerge.lookahead_off)
poc1H     = request.security(syminfo.tickerid, "60", f_pocProxyFast(), barmerge.gaps_off, barmerge.lookahead_off)
poc4H     = request.security(syminfo.tickerid, "240", f_pocProxyFast(), barmerge.gaps_off, barmerge.lookahead_off)
pocDaily  = request.security(syminfo.tickerid, "D", f_pocProxyFast(), barmerge.gaps_off, barmerge.lookahead_off)
pocWeekly = request.security(syminfo.tickerid, "W", f_pocProxyFast(), barmerge.gaps_off, barmerge.lookahead_off)

curTFMin   = timeframe.in_seconds() / 60.0
is15mTF    = curTFMin == 15
is1HTF     = curTFMin == 60
is4HTF     = curTFMin == 240
isDailyTF  = timeframe.isdaily
isWeeklyTF = timeframe.isweekly

hide15m    = hidePOCCurrentTF and is15mTF
hide1H     = hidePOCCurrentTF and is1HTF
hide4H     = hidePOCCurrentTF and is4HTF
hideDaily  = hidePOCCurrentTF and isDailyTF
hideWeekly = hidePOCCurrentTF and isWeeklyTF

f_labelSize(string s) =>
    s == "Tiny" ? size.tiny : s == "Small" ? size.small : s == "Large" ? size.large : size.normal

f_getPOCForTF(string tfStr) =>
    float result = na
    if tfStr == "15"
        result := poc15m
    else if tfStr == "60"
        result := poc1H
    else if tfStr == "240"
        result := poc4H
    else if tfStr == "D"
        result := pocDaily
    else if tfStr == "W"
        result := pocWeekly
    result

f_pctDist(float pocVal) =>
    na(pocVal) or close <= 0 ? 0.0 : (close - pocVal) / pocVal * 100

f_distColor(float pct) =>
    color result = color.gray
    if colorCodePOCDist
        if pct >= 5.0
            result := color.new(#00E676, 0)
        else if pct >= 2.0
            result := color.new(#4CAF50, 0)
        else if pct >= 1.0
            result := color.new(#81C784, 10)
        else if pct >= -1.0
            result := color.new(#9E9E9E, 20)
        else if pct >= -3.0
            result := color.new(#FFB300, 10)
        else if pct >= -6.0
            result := color.new(#FF5722, 0)
        else
            result := color.new(#D32F2F, 0)
    else
        result := pct > 2 ? color.lime : pct > 0 ? color.new(color.lime, 30) : pct > -2 ? color.new(color.red, 30) : color.red
    result

f_distStr(float pct) =>
    (pct > 0 ? "▲ +" : "▼ ") + str.tostring(math.round(pct, 1)) + "%"

var line ln_15m     = na
var line ln_1H      = na
var line ln_4H      = na
var line ln_Daily   = na
var line ln_Weekly  = na
var label lb_15m    = na
var label lb_1H     = na
var label lb_4H     = na
var label lb_Daily  = na
var label lb_Weekly = na

f_pocLabel(string tfName, float pocValue) =>
    string baseTxt = tfName + " POC " + str.tostring(math.round(pocValue, 2))
    if showPOCDistance and not na(pocValue) and close > 0
        float distPct = (close - pocValue) / pocValue * 100
        string arrow = distPct > 0 ? " ▲" : " ▼"
        baseTxt := baseTxt + arrow + str.tostring(math.round(math.abs(distPct), 1)) + "%"
    baseTxt

if useMultiPOC and barstate.islast
    line.delete(ln_15m)
    line.delete(ln_1H)
    line.delete(ln_4H)
    line.delete(ln_Daily)
    line.delete(ln_Weekly)
    label.delete(lb_15m)
    label.delete(lb_1H)
    label.delete(lb_4H)
    label.delete(lb_Daily)
    label.delete(lb_Weekly)
    int xStart = bar_index - 50
    int xEnd   = bar_index + pocExtendRight
    if showPOC15m and not hide15m and not na(poc15m)
        ln_15m := line.new(xStart, poc15m, xEnd, poc15m, color=color15m, width=pocLineWidth, style=line.style_dotted)
        lb_15m := label.new(xEnd, poc15m, f_pocLabel("15m", poc15m), color=color.new(color15m, 80), textcolor=color15m, style=label.style_label_left, size=f_labelSize(pocLabelSize))
    if showPOC1H and not hide1H and not na(poc1H)
        ln_1H := line.new(xStart, poc1H, xEnd, poc1H, color=color1H, width=pocLineWidth, style=line.style_dashed)
        lb_1H := label.new(xEnd, poc1H, f_pocLabel("1H", poc1H), color=color.new(color1H, 80), textcolor=color1H, style=label.style_label_left, size=f_labelSize(pocLabelSize))
    if showPOC4H and not hide4H and not na(poc4H)
        ln_4H := line.new(xStart, poc4H, xEnd, poc4H, color=color4H, width=pocLineWidth, style=line.style_dashed)
        lb_4H := label.new(xEnd, poc4H, f_pocLabel("4H", poc4H), color=color.new(color4H, 80), textcolor=color4H, style=label.style_label_left, size=f_labelSize(pocLabelSize))
    if showPOCDaily and not hideDaily and not na(pocDaily)
        ln_Daily := line.new(xStart, pocDaily, xEnd, pocDaily, color=colorDaily, width=pocLineWidth + 1, style=line.style_solid)
        lb_Daily := label.new(xEnd, pocDaily, f_pocLabel("D", pocDaily), color=color.new(colorDaily, 70), textcolor=colorDaily, style=label.style_label_left, size=f_labelSize(pocLabelSize))
    if showPOCWeekly and not hideWeekly and not na(pocWeekly)
        ln_Weekly := line.new(xStart, pocWeekly, xEnd, pocWeekly, color=colorWeekly, width=pocLineWidth + 1, style=line.style_solid)
        lb_Weekly := label.new(xEnd, pocWeekly, f_pocLabel("W", pocWeekly), color=color.new(colorWeekly, 70), textcolor=colorWeekly, style=label.style_label_left, size=f_labelSize(pocLabelSize))

// ══════════════════════════════════════════════════════════════════════════════
// S/R LEVELS
// ══════════════════════════════════════════════════════════════════════════════
swingHigh_SR = ta.pivothigh(high, srLookback, srLookback)
swingLow_SR  = ta.pivotlow(low, srLookback, srLookback)

var line srRes = na
var line srSup = na

if showSR and not na(swingHigh_SR)
    line.delete(srRes)
    srRes := line.new(bar_index - srLookback, swingHigh_SR, bar_index - srLookback + srExtend, swingHigh_SR, color=color.new(color.red, 50), width=1, style=line.style_dashed)

if showSR and not na(swingLow_SR)
    line.delete(srSup)
    srSup := line.new(bar_index - srLookback, swingLow_SR, bar_index - srLookback + srExtend, swingLow_SR, color=color.new(color.lime, 50), width=1, style=line.style_dashed)
// ══════════════════════════════════════════════════════════════════════════════
// AE BAND PLOTS
// ══════════════════════════════════════════════════════════════════════════════
// ── SESSION VWAP BAND PLOTS ───────────────────────────────────────────────────
svwapPlot  = plot(showSVWAP ? svwapVal : na, "Session VWAP",  color=svwapCol,    linewidth=svwapLineWidth, style=plot.style_line)
svwapU1Plot = plot(showSVWAP and showSVWAPBands ? svwapU1 : na, "VWAP +1SD", color=svwap1SDCol, linewidth=1, style=plot.style_line)
svwapL1Plot = plot(showSVWAP and showSVWAPBands ? svwapL1 : na, "VWAP -1SD", color=svwap1SDCol, linewidth=1, style=plot.style_line)
svwapU2Plot = plot(showSVWAP and showSVWAPBands ? svwapU2 : na, "VWAP +2SD", color=svwap2SDCol, linewidth=1, style=plot.style_line)
svwapL2Plot = plot(showSVWAP and showSVWAPBands ? svwapL2 : na, "VWAP -2SD", color=svwap2SDCol, linewidth=1, style=plot.style_line)

fill(svwapU1Plot, svwapL1Plot, color=svwapFillBands and showSVWAP and showSVWAPBands ? color.new(svwap1SDCol, 92) : na, title="VWAP ±1SD Fill")
fill(svwapU2Plot, svwapU1Plot, color=svwapFillBands and showSVWAP and showSVWAPBands ? color.new(svwap2SDCol, 94) : na, title="VWAP +1/2SD Fill")
fill(svwapL1Plot, svwapL2Plot, color=svwapFillBands and showSVWAP and showSVWAPBands ? color.new(svwap2SDCol, 94) : na, title="VWAP -1/2SD Fill")

plot(basetype, color=color.white, title="AE Base")
plot(usehl and showhl ? highband_tf_display : na, title="HL High Band", color=color.new(color.yellow, 40), linewidth=1, style=plot.style_line)
plot(usehl and showhl ? lowband_tf_display : na,  title="HL Low Band",  color=color.new(color.yellow, 40), linewidth=1, style=plot.style_line)
plot(usevwma and showvwma ? vwma_val : na, title="VWMA Filter", color=color.new(color.orange, 20), linewidth=2, style=plot.style_line)

// ══════════════════════════════════════════════════════════════════════════════
// SIGNAL LABELS (no glow effects — single label per signal)
// ══════════════════════════════════════════════════════════════════════════════

f_drawSignalLabels() =>
    if confirmedBuy and showPTLabels
        string gs = showGrade ? " " + getGrade(bullScore) : ""
        string priceStr = " @ " + str.tostring(close, format.mintick)
        string sqsStr = useSQS ? " • SQS " + str.tostring(math.round(sqsBull)) : ""
        string tt = "BUY SIGNAL FIRED\nScore: " + str.tostring(bullScore) + "/12\nGrade: " + getGrade(bullScore) + (useSQS ? "\nSQS: " + str.tostring(math.round(sqsBull)) + "/100 (" + f_sqsGrade(sqsBull) + ")" : "") + "\nEntry: " + str.tostring(close, format.mintick)
        float labelY = low - atrVal * labelAtrClear
        lbl = label.new(bar_index, labelY, "BUY" + gs + " " + str.tostring(bullScore) + "/12" + priceStr + sqsStr, style=label.style_label_up, color=color.new(#1565C0, 0), textcolor=color.white, size=size.normal, tooltip=tt)
        array.push(sigLabels, lbl)
        array.push(sigBars, bar_index)
        if showSignalAudit
            string auditTxt = marketRegime + " | SQS " + str.tostring(math.round(sqsBull)) + " | Pur " + str.tostring(bullPillarCount) + "/5 | POC " + (pocDistOk ? "✓" : "✗") + " | EXT " + (ema200ExtOk ? "✓" : "✗") + " | CTR " + (conflictBlockBuy ? "BLK" : "✓")
            lbl_audit_buy = label.new(bar_index, labelY - atrVal * 1.2, auditTxt, style=label.style_label_up, color=color.new(#263238, 85), textcolor=color.new(#80DEEA, 0), size=size.tiny)
            array.push(sigLabels, lbl_audit_buy)
            array.push(sigBars, bar_index)
        if showMiniMarker
            float miniY_buy = low - atrVal * (labelAtrClear + 1.5)
            string scoreTag_buy = str.tostring(bullScore) + "/10"
            color miniCol_buy = bullScore >= 8 ? color.new(#00E676, 10) : bullScore >= 6 ? color.new(#66BB6A, 20) : color.new(#FFA726, 20)
            lbl_mini_buy = label.new(bar_index, miniY_buy, scoreTag_buy, style=label.style_label_up, color=miniCol_buy, textcolor=color.white, size=size.tiny, tooltip="Confluence Score: " + str.tostring(bullScore) + "/10")
            array.push(sigLabels, lbl_mini_buy)
            array.push(sigBars, bar_index)

    if confirmedSell and showPTLabels
        string gs = showGrade ? " " + getGrade(bearScore) : ""
        string priceStr = " @ " + str.tostring(close, format.mintick)
        string sqsStr = useSQS ? " • SQS " + str.tostring(math.round(sqsBear)) : ""
        string tt = "SELL SIGNAL FIRED\nScore: " + str.tostring(bearScore) + "/12\nGrade: " + getGrade(bearScore) + (useSQS ? "\nSQS: " + str.tostring(math.round(sqsBear)) + "/100 (" + f_sqsGrade(sqsBear) + ")" : "") + "\nEntry: " + str.tostring(close, format.mintick)
        float labelY = high + atrVal * labelAtrClear
        lbl = label.new(bar_index, labelY, "SELL" + gs + " " + str.tostring(bearScore) + "/12" + priceStr + sqsStr, style=label.style_label_down, color=color.new(#B71C1C, 0), textcolor=color.white, size=size.normal, tooltip=tt)
        array.push(sigLabels, lbl)
        array.push(sigBars, bar_index)
        if showSignalAudit
            string auditTxt = marketRegime + " | SQS " + str.tostring(math.round(sqsBear)) + " | Pur " + str.tostring(bearPillarCount) + "/5 | POC " + (pocDistOk ? "✓" : "✗") + " | EXT " + (ema200ExtOk ? "✓" : "✗") + " | CTR " + (conflictBlockSell ? "BLK" : "✓")
            lbl_audit_sell = label.new(bar_index, labelY + atrVal * 1.2, auditTxt, style=label.style_label_down, color=color.new(#263238, 85), textcolor=color.new(#80DEEA, 0), size=size.tiny)
            array.push(sigLabels, lbl_audit_sell)
            array.push(sigBars, bar_index)
        if showMiniMarker
            float miniY_sell = high + atrVal * (labelAtrClear + 1.5)
            string scoreTag_sell = str.tostring(bearScore) + "/10"
            color miniCol_sell = bearScore >= 8 ? color.new(#FF1744, 10) : bearScore >= 6 ? color.new(#EF5350, 20) : color.new(#FFA726, 20)
            lbl_mini_sell = label.new(bar_index, miniY_sell, scoreTag_sell, style=label.style_label_down, color=miniCol_sell, textcolor=color.white, size=size.tiny, tooltip="Confluence Score: " + str.tostring(bearScore) + "/10")
            array.push(sigLabels, lbl_mini_sell)
            array.push(sigBars, bar_index)

    // Cleanup
    while array.size(sigLabels) > sigMaxVisibleInput
        label.delete(array.shift(sigLabels))
        array.shift(sigBars)

// ── Call it in the main body ──
f_drawSignalLabels()

if barstate.islast and array.size(sigLabels) > 0
    int loopSize = array.size(sigLabels)
    for i = 0 to loopSize - 1
        if i >= array.size(sigLabels)
            break
        int sigBar = array.get(sigBars, i)
        label lbl_fade = array.get(sigLabels, i)
        int ageBars = bar_index - sigBar
        string txt = label.get_text(lbl_fade)
        bool isBuyLbl = str.contains(txt, "BUY")
        string cleanTxt = txt
        cleanTxt := str.replace_all(cleanTxt, "⚡ LIVE ⚡\n", "")
        cleanTxt := str.replace_all(cleanTxt, "🟢 LIVE 🟢\n", "")
        cleanTxt := str.replace_all(cleanTxt, "🔴 LIVE 🔴\n", "")
        cleanTxt := str.replace_all(cleanTxt, "✓ CLOSED\n", "")
        cleanTxt := str.replace_all(cleanTxt, "🟢 LIVE ", "")
        cleanTxt := str.replace_all(cleanTxt, "🔴 LIVE ", "")
        cleanTxt := str.replace_all(cleanTxt, "⚡ LIVE ", "")
        bool isActiveTrade = tradeDir != 0 and sigBar == entryBar
        if isActiveTrade
            bool pulseState = (bar_index / 2) % 2 == 0
            string liveEmoji = isBuyLbl ? (pulseState ? "🟢" : "⚡") : (pulseState ? "🔴" : "⚡")
            color activeBg = isBuyLbl ? color.new(#00C853, 0) : color.new(#D50000, 0)
            string priceTag = not na(entryPrice) and not str.contains(cleanTxt, "@") ? " @ " + str.tostring(entryPrice, format.mintick) : ""
            label.set_text(lbl_fade, liveEmoji + " LIVE " + cleanTxt + priceTag)
            label.set_color(lbl_fade, activeBg)
            label.set_textcolor(lbl_fade, color.white)
            label.set_size(lbl_fade, size.normal)
        else if fadeOldSignals and ageBars > fadeAfterBars and not showHistoricalSignals
            label.set_color(lbl_fade, color.new(color.black, 100))
            label.set_textcolor(lbl_fade, color.new(color.black, 100))
            label.set_text(lbl_fade, "")
            label.set_size(lbl_fade, size.tiny)
        else if fadeOldSignals and ageBars > fadeAfterBars * 3
            color fadeBg = isBuyLbl ? color.new(#1565C0, 75) : color.new(#B71C1C, 75)
            label.set_text(lbl_fade, "✓ CLOSED\n" + cleanTxt)
            label.set_color(lbl_fade, fadeBg)
            label.set_textcolor(lbl_fade, color.new(color.white, 50))
            label.set_size(lbl_fade, size.tiny)
        else if fadeOldSignals and ageBars > fadeAfterBars
            color fadeBg = isBuyLbl ? color.new(#1565C0, 55) : color.new(#B71C1C, 55)
            label.set_text(lbl_fade, "✓ CLOSED\n" + cleanTxt)
            label.set_color(lbl_fade, fadeBg)
            label.set_textcolor(lbl_fade, color.new(color.white, 25))
            label.set_size(lbl_fade, size.small)
        else
            if tradeDir != 0
                color dimBg = isBuyLbl ? color.new(#1565C0, 60) : color.new(#B71C1C, 60)
                label.set_text(lbl_fade, "✓ CLOSED\n" + cleanTxt)
                label.set_color(lbl_fade, dimBg)
                label.set_textcolor(lbl_fade, color.new(color.white, 30))
                label.set_size(lbl_fade, size.small)
            else
                color freshBg = isBuyLbl ? color.new(#1565C0, 0) : color.new(#B71C1C, 0)
                label.set_text(lbl_fade, cleanTxt)
                label.set_color(lbl_fade, freshBg)
                label.set_textcolor(lbl_fade, color.white)
                label.set_size(lbl_fade, size.normal)

bgcolor(highlightEntryBar and tradeDir != 0 and bar_index == entryBar ? color.new(#00E5FF, 90) : na, title="Entry Bar Highlight")
// Momentum move highlight — orange background when big mover threshold crossed
bgcolor(useMomoAlert and momoUpMove ? color.new(#FF6D00, 92) : useMomoAlert and momoDownMove and not momoDirectional ? color.new(#AA00FF, 92) : na, title="Big Mover Day Highlight")
// Raised transparency so candles dominate over background fills
bgcolor(stHighlightBull ? color.new(THEME_BULL, 96) : na, title="ST Bull Highlight")
bgcolor(stHighlightBear ? color.new(THEME_BEAR, 96) : na, title="ST Bear Highlight")

// ══════════════════════════════════════════════════════════════════════════════
// BARS + SUPERTREND + MACD + EMA
// ══════════════════════════════════════════════════════════════════════════════
barcolor(barcolors ? (uprng ? bullBarCol : bearBarCol) : na)

var int lastSTFlipBar = 0
if stBuy or stSell
    lastSTFlipBar := bar_index

int stSegAge = bar_index - lastSTFlipBar
int stTransp = 0
if fadeSTOld and stSegAge > fadeSTAfterBars
    stTransp := math.min(70, int((stSegAge - fadeSTAfterBars) * 70 / fadeSTAfterBars))

int stFinalTransp = math.min(90, stTransp + stBaseTransp)
color stUpColor = color.new(color.green, stFinalTransp)
color stDnColor = color.new(color.red, stFinalTransp)

plot(showST and stTrend == 1 ? stUp : na, title="ST Up", style=plot.style_linebr, linewidth=stLineWidth, color=stUpColor)
plot(showST and stTrend == -1 ? stDn : na, title="ST Down", style=plot.style_linebr, linewidth=stLineWidth, color=stDnColor)

plotshape(showSTSig and stBuy ? stUp : na, title="ST Buy", text="▲", location=location.absolute, style=shape.labelup, size=size.tiny, color=color.new(#00897B, 30), textcolor=color.new(color.white, 20))
plotshape(showSTSig and stSell ? stDn : na, title="ST Sell", text="▼", location=location.absolute, style=shape.labeldown, size=size.tiny, color=color.new(#E65100, 30), textcolor=color.new(color.white, 20))

macdOverlay   = ta.ema(close, sa - fa)
signalOverlay = ta.sma(macdOverlay, sig)
smaOverlay    = ta.sma(close, smaLen)

macdColor = macdOverlay > macdOverlay[1] ? color.green : macdOverlay < macdOverlay[1] ? color.red : color.black
sigColor  = signalOverlay > signalOverlay[1] ? color.green : signalOverlay < signalOverlay[1] ? color.red : color.black
smaColor  = smaOverlay > smaOverlay[1] ? color.green : smaOverlay < smaOverlay[1] ? color.red : color.black

p1 = plot(showMACD ? macdOverlay : na, color=macdColor, linewidth=2, title="MACD", style=plot.style_line)
p2 = plot(showMACD ? signalOverlay : na, color=sigColor, linewidth=2, title="SIGNAL", style=plot.style_line)
fill(p1, p2, color=showMACD ? (macdOverlay > signalOverlay ? color.new(color.green, 50) : color.new(color.red, 50)) : na, title="MACD Fill")
plot(showMACD and showSMA ? smaOverlay : na, color=smaColor, linewidth=2, title="SMA 89", style=plot.style_line)

plot(showEMA ? ema50 : na, title="EMA 50", color=color.aqua, linewidth=1)
plot(showEMA ? ema200 : na, title="EMA 200", color=color.purple, linewidth=1)

// ══════════════════════════════════════════════════════════════════════════════
// GOLDEN / DEATH CROSS
// ══════════════════════════════════════════════════════════════════════════════
plotshape(showEMACross and not showGXDate and goldenCross ? ema50 : na, title="GX", location=location.absolute, style=shape.labelup, size=size.small, color=color.new(#FFD700, 0), textcolor=color.black, text="GX")
plotshape(showEMACross and not showGXDate and deathCross ? ema50 : na, title="DX", location=location.absolute, style=shape.labeldown, size=size.small, color=color.maroon, textcolor=color.white, text="DX")

var gxLabels = array.new_label()
var gxBars   = array.new_int()

if showEMACross and showGXDate and goldenCross
    string dateStr = str.tostring(month) + "/" + str.tostring(dayofmonth)
    lbl_gx = label.new(bar_index, ema50, "GX " + dateStr, style=label.style_label_up, color=color.new(#FFD700, 0), textcolor=color.black, size=size.small)
    array.push(gxLabels, lbl_gx)
    array.push(gxBars, bar_index)

if showEMACross and showGXDate and deathCross
    string dateStr = str.tostring(month) + "/" + str.tostring(dayofmonth)
    lbl_dx = label.new(bar_index, ema50, "DX " + dateStr, style=label.style_label_down, color=color.maroon, textcolor=color.white, size=size.small)
    array.push(gxLabels, lbl_dx)
    array.push(gxBars, bar_index)

while array.size(gxLabels) > gxMaxVisible
    label.delete(array.shift(gxLabels))
    array.shift(gxBars)

if showEMACross and showGXDate and fadeOldSignals and barstate.islast and array.size(gxLabels) > 0
    for i = 0 to array.size(gxLabels) - 1
        label gxLbl = array.get(gxLabels, i)
        int gxBarIdx = array.get(gxBars, i)
        int gxAge = bar_index - gxBarIdx
        string gxTxt = label.get_text(gxLbl)
        bool isGX = str.contains(gxTxt, "GX")
        if gxAge > fadeAfterBars * 3
            color fadeBg  = isGX ? color.new(#FFD700, 75) : color.new(color.maroon, 75)
            color fadeTxt = isGX ? color.new(color.black, 50) : color.new(color.white, 50)
            label.set_color(gxLbl, fadeBg)
            label.set_textcolor(gxLbl, fadeTxt)
            label.set_size(gxLbl, size.tiny)
        else if gxAge > fadeAfterBars
            color fadeBg  = isGX ? color.new(#FFD700, 55) : color.new(color.maroon, 55)
            color fadeTxt = isGX ? color.new(color.black, 30) : color.new(color.white, 30)
            label.set_color(gxLbl, fadeBg)
            label.set_textcolor(gxLbl, fadeTxt)
            label.set_size(gxLbl, size.tiny)
        else
            color freshBg  = isGX ? color.new(#FFD700, 0) : color.maroon
            color freshTxt = isGX ? color.black : color.white
            label.set_color(gxLbl, freshBg)
            label.set_textcolor(gxLbl, freshTxt)
            label.set_size(gxLbl, size.small)

// ══════════════════════════════════════════════════════════════════════════════
// TP/SL LINES (simple solid/dashed — no gradients)
// ══════════════════════════════════════════════════════════════════════════════
var line  ln_entry       = na
var line  ln_sl          = na
var line  ln_tp1         = na
var line  ln_tp2         = na
var line  ln_tp3         = na
var line  ln_trail       = na
var line  ln_entryBar    = na
var label lb_entry       = na
var label lb_sl          = na
var label lb_tp1         = na
var label lb_tp2         = na
var label lb_tp3         = na
var label lb_trail       = na
var label lb_entryMark   = na
var label lb_slMark      = na
var label lb_tp1Mark     = na
var label lb_tp2Mark     = na
var label lb_tp3Mark     = na
var label lb_elapsedTime = na
var bool  hasLines       = false

f_markerSize(string s) =>
    s == "Small"  ? size.small  : s == "Normal" ? size.normal : s == "Huge" ? size.huge : size.large

f_elapsedString(int barsElapsed) =>
    int tfSec    = timeframe.in_seconds()
    int totalSec = barsElapsed * tfSec
    int hours    = totalSec / 3600
    int mins     = (totalSec % 3600) / 60
    int days     = hours / 24
    int hoursRem = hours % 24
    string timeStr = ""
    if days > 0
        timeStr := str.tostring(days) + "d " + str.tostring(hoursRem) + "h"
    else if hours > 0
        timeStr := str.tostring(hours) + "h " + str.tostring(mins) + "m"
    else
        timeStr := str.tostring(mins) + "m"
    string result = ""
    if elapsedTimeStyle == "Bars Only"
        result := "⏱ " + str.tostring(barsElapsed) + (barsElapsed == 1 ? " bar" : " bars")
    else if elapsedTimeStyle == "Time Only"
        result := "⏱ " + timeStr
    else
        result := "⏱ " + str.tostring(barsElapsed) + "b • " + timeStr
    result

f_shouldShowTrail() =>
    useTrail and showTrailLine and not na(trailPrice) and not na(entryPrice) and math.abs(trailPrice - entryPrice) > syminfo.mintick * 5

if showTPSL and (trueSLHit or trailProfitExit) and hasLines
    line.delete(ln_entry)
    line.delete(ln_sl)
    line.delete(ln_tp1)
    line.delete(ln_tp2)
    line.delete(ln_tp3)
    line.delete(ln_trail)
    line.delete(ln_entryBar)
    label.delete(lb_entry)
    label.delete(lb_sl)
    label.delete(lb_tp1)
    label.delete(lb_tp2)
    label.delete(lb_tp3)
    label.delete(lb_trail)
    label.delete(lb_entryMark)
    label.delete(lb_slMark)
    label.delete(lb_tp1Mark)
    label.delete(lb_tp2Mark)
    label.delete(lb_tp3Mark)
    label.delete(lb_elapsedTime)
    hasLines := false

if (confirmedBuy or confirmedSell) and showTPSL
    hasLines := false
    line.delete(ln_entry)
    line.delete(ln_sl)
    line.delete(ln_tp1)
    line.delete(ln_tp2)
    line.delete(ln_tp3)
    line.delete(ln_trail)
    line.delete(ln_entryBar)
    label.delete(lb_entry)
    label.delete(lb_sl)
    label.delete(lb_tp1)
    label.delete(lb_tp2)
    label.delete(lb_tp3)
    label.delete(lb_trail)
    label.delete(lb_entryMark)
    label.delete(lb_slMark)
    label.delete(lb_tp1Mark)
    label.delete(lb_tp2Mark)
    label.delete(lb_tp3Mark)
    label.delete(lb_elapsedTime)

    int x2       = bar_index + labelOffset
    int xlb      = bar_index + labelOffset + 2
    int xlbTrail = bar_index + labelOffset + 35

    ln_entry := line.new(bar_index, entryPrice, x2, entryPrice, color=C_ENTRY, width=2)
    ln_sl    := line.new(bar_index, slPrice, x2, slPrice, color=C_SL, width=3)

    // Simple lines — no gradient segments
    ln_tp1 := line.new(bar_index, tp1Price, x2, tp1Price, color=C_TP1, width=1, style=line.style_dashed)
    ln_tp2 := line.new(bar_index, tp2Price, x2, tp2Price, color=C_TP2, width=2, style=line.style_dashed)
    ln_tp3 := line.new(bar_index, tp3Price, x2, tp3Price, color=C_TP3, width=3, style=line.style_dashed)

    if showEntryMarker
        float topY = tradeDir == 1 ? tp3Price : slPrice
        float botY = tradeDir == 1 ? slPrice : tp3Price
        ln_entryBar := line.new(entryBar, topY, entryBar, botY, color=color.new(#00E5FF, 0), width=2, style=line.style_solid)
        string markTooltip = "★ TRADE START ★\nDirection: " + (tradeDir == 1 ? "LONG" : "SHORT") + "\nEntry: " + str.tostring(entryPrice, format.mintick) + "\nSL: " + str.tostring(slPrice, format.mintick) + (useSQS ? "\nSQS: " + str.tostring(math.round(activeTradeSQS)) : "")
        lb_entryMark := label.new(entryBar, entryPrice, "◆", xloc=xloc.bar_index, yloc=yloc.price, style=label.style_label_center, color=color.new(color.black, 100), textcolor=C_ENTRY, size=f_markerSize(entryMarkerSize), tooltip=markTooltip)
        if showTPSLMarkers
            lb_slMark  := label.new(entryBar, slPrice, "◆", xloc=xloc.bar_index, yloc=yloc.price, style=label.style_label_center, color=color.new(color.black, 100), textcolor=C_SL, size=size.normal)
            lb_tp1Mark := label.new(entryBar, tp1Price, "◆", xloc=xloc.bar_index, yloc=yloc.price, style=label.style_label_center, color=color.new(color.black, 100), textcolor=C_TP1, size=size.normal)
            lb_tp2Mark := label.new(entryBar, tp2Price, "◆", xloc=xloc.bar_index, yloc=yloc.price, style=label.style_label_center, color=color.new(color.black, 100), textcolor=C_TP2, size=size.normal)
            lb_tp3Mark := label.new(entryBar, tp3Price, "◆", xloc=xloc.bar_index, yloc=yloc.price, style=label.style_label_center, color=color.new(color.black, 100), textcolor=C_TP3, size=size.normal)

    if showElapsedTime and showEntryMarker
        float counterY = tradeDir == 1 ? entryPrice + atrVal * 0.3 : entryPrice - atrVal * 0.3
        string initText = elapsedTimeStyle == "Bars Only" ? "⏱ 0 bars" : elapsedTimeStyle == "Time Only" ? "⏱ 0m" : "⏱ NEW"
        lb_elapsedTime := label.new(bar_index, counterY, initText, style=label.style_label_center, color=color.new(C_ENTRY, 75), textcolor=color.white, size=size.small)

    // Trail label shows "ATR Trail" when showTrailType=true
    if f_shouldShowTrail()
        string trailTypeTxt = showTrailType ? "ATR Trail " : "Trail "
        ln_trail := line.new(bar_index, trailPrice, x2, trailPrice, color=C_TRAIL, width=1, style=line.style_dotted)
        lb_trail := label.new(xlbTrail, trailPrice, trailTypeTxt + str.tostring(trailPrice, format.mintick), color=LC_TRAIL, textcolor=color.white, style=label.style_label_left, size=size.small)

    lb_entry := label.new(xlb, entryPrice, "ENTRY " + str.tostring(entryPrice, format.mintick), color=LC_ENTRY, textcolor=color.white, style=label.style_label_left, size=size.small)
    lb_sl    := label.new(xlb, slPrice, "SL " + str.tostring(slPrice, format.mintick), color=LC_SL, textcolor=color.white, style=label.style_label_left, size=size.small)
    lb_tp1   := label.new(xlb, tp1Price, "TP1 " + str.tostring(tp1Price, format.mintick), color=LC_TP1, textcolor=color.white, style=label.style_label_left, size=size.small)
    lb_tp2   := label.new(xlb, tp2Price, "TP2 " + str.tostring(tp2Price, format.mintick), color=LC_TP2, textcolor=color.white, style=label.style_label_left, size=size.small)
    lb_tp3   := label.new(xlb, tp3Price, "TP3 " + str.tostring(tp3Price, format.mintick), color=LC_TP3, textcolor=color.white, style=label.style_label_left, size=size.small)
    hasLines := true

if showTPSL and hasLines and not (confirmedBuy or confirmedSell) and not trueSLHit
    int ne       = bar_index + labelOffset
    int nlp      = bar_index + labelOffset + 2
    int nlpTrail = bar_index + labelOffset + 35

    if not na(ln_entry)
        line.set_x2(ln_entry, ne)
    if not na(ln_sl)
        line.set_x2(ln_sl, ne)
    if not na(ln_tp1)
        line.set_x2(ln_tp1, ne)
    if not na(ln_tp2)
        line.set_x2(ln_tp2, ne)
    if not na(ln_tp3)
        line.set_x2(ln_tp3, ne)
    if not na(lb_entry)
        label.set_x(lb_entry, nlp)
    if not na(lb_sl)
        label.set_x(lb_sl, nlp)
    if not na(lb_tp1)
        label.set_x(lb_tp1, nlp)
    if not na(lb_tp2)
        label.set_x(lb_tp2, nlp)
    if not na(lb_tp3)
        label.set_x(lb_tp3, nlp)

    bool shouldShow = f_shouldShowTrail()
    if shouldShow
        string trailTypeTxt2 = showTrailType ? "ATR Trail " : "Trail "
        if na(ln_trail)
            ln_trail := line.new(bar_index, trailPrice, ne, trailPrice, color=C_TRAIL, width=1, style=line.style_dotted)
        if na(lb_trail)
            lb_trail := label.new(nlpTrail, trailPrice, trailTypeTxt2 + str.tostring(trailPrice, format.mintick), color=LC_TRAIL, textcolor=color.white, style=label.style_label_left, size=size.small)
        if not na(ln_trail)
            line.set_x2(ln_trail, ne)
            line.set_y1(ln_trail, trailPrice)
            line.set_y2(ln_trail, trailPrice)
        if not na(lb_trail)
            label.set_xy(lb_trail, nlpTrail, trailPrice)
            label.set_text(lb_trail, trailTypeTxt2 + str.tostring(trailPrice, format.mintick))
    else
        if not na(ln_trail)
            line.delete(ln_trail)
            ln_trail := na
        if not na(lb_trail)
            label.delete(lb_trail)
            lb_trail := na

    if showElapsedTime and not na(lb_elapsedTime) and tradeDir != 0
        int barsElapsed = bar_index - entryBar
        if barsElapsed > 0
            label.set_text(lb_elapsedTime, f_elapsedString(barsElapsed))
            float counterY = tradeDir == 1 ? entryPrice + atrVal * 0.3 : entryPrice - atrVal * 0.3
            label.set_xy(lb_elapsedTime, bar_index, counterY)
            bool inProfit = tradeDir == 1 ? close > entryPrice : close < entryPrice
            color counterBg = inProfit ? color.new(THEME_BULL, 60) : color.new(THEME_BEAR, 60)
            label.set_color(lb_elapsedTime, counterBg)

if showTPSL and tp1Hit
    if not na(ln_tp1)
        line.set_color(ln_tp1, C_TP1)
        line.set_style(ln_tp1, line.style_solid)
    if not na(lb_tp1)
        label.set_text(lb_tp1, "TP1 ✓ " + str.tostring(tp1Price, format.mintick))
    if not na(lb_tp1Mark)
        label.set_text(lb_tp1Mark, "✓")

if showTPSL and tp2Hit
    if not na(ln_tp2)
        line.set_color(ln_tp2, C_TP2)
        line.set_style(ln_tp2, line.style_solid)
    if not na(lb_tp2)
        label.set_text(lb_tp2, "TP2 ✓ " + str.tostring(tp2Price, format.mintick))
    if not na(lb_tp2Mark)
        label.set_text(lb_tp2Mark, "✓")

if showTPSL and tp3Hit
    if not na(ln_tp3)
        line.set_color(ln_tp3, C_TP3)
        line.set_style(ln_tp3, line.style_solid)
    if not na(lb_tp3)
        label.set_text(lb_tp3, "TP3 ✓ " + str.tostring(tp3Price, format.mintick))
    if not na(lb_tp3Mark)
        label.set_text(lb_tp3Mark, "✓")

// ══════════════════════════════════════════════════════════════════════════════
// EXIT MARKERS
// ══════════════════════════════════════════════════════════════════════════════
f_exitMarkerSize(string s) =>
    s == "Tiny" ? size.tiny : s == "Small" ? size.small : s == "Large" ? size.large : size.normal

var exitMarkers = array.new_label()

var float exitTrailPrice = na
var float exitEntryPrice = na
var float exitTradeRisk  = na
var int   exitTradeDir   = 0

if trueSLHit or trailProfitExit
    exitTrailPrice := trailPrice
    exitEntryPrice := entryPrice
    exitTradeRisk  := tradeRisk
    exitTradeDir   := exitDirSnapshot

if (trueSLHit or trailProfitExit) and not showExitMarkers
    if array.size(exitMarkers) > 0
        for lbl_old in exitMarkers
            label.delete(lbl_old)
        array.clear(exitMarkers)

if trueSLHit
    color exitColSL = color.new(#D32F2F, 0)
    float dollarLoss = na(posDollarRisk) ? 100.0 : posDollarRisk
    string exitTooltipSL = "TRADE CLOSED — STOP LOSS\nExit: " + str.tostring(close, format.mintick) + "\nLoss: -1.00R\nResult: -$" + str.tostring(math.round(dollarLoss, 0))
    lbl_sl = label.new(bar_index, close, "✗", style=label.style_label_center, color=exitColSL, textcolor=color.white, size=f_exitMarkerSize(exitMarkerSize), tooltip=exitTooltipSL)
    array.push(exitMarkers, lbl_sl)

if trailProfitExit and not na(exitTrailPrice) and not na(exitEntryPrice) and not na(exitTradeRisk) and exitTradeRisk > 0
    float exitR_val = exitTradeDir == 1 ? (exitTrailPrice - exitEntryPrice) / exitTradeRisk : (exitEntryPrice - exitTrailPrice) / exitTradeRisk
    string exitTxtTP = exitR_val > 0.5 ? "✓" : exitR_val > 0 ? "✓" : "="
    color exitColTP = exitR_val > 0.5 ? color.new(#00C853, 0) : exitR_val > 0 ? color.new(#4CAF50, 0) : color.new(#FFB300, 0)
    float dollarGain = na(posDollarRisk) ? 100.0 : posDollarRisk
    string gainStr = exitR_val >= 0 ? "+" : ""
    string exitTooltipTP = "TRADE CLOSED — ATR TRAIL STOP\nExit: " + str.tostring(exitTrailPrice, format.mintick) + "\nR: " + gainStr + str.tostring(math.round(exitR_val, 2)) + "R\nResult: " + gainStr + "$" + str.tostring(math.round(exitR_val * dollarGain, 0))
    lbl_tp = label.new(bar_index, close, exitTxtTP, style=label.style_label_center, color=exitColTP, textcolor=color.white, size=f_exitMarkerSize(exitMarkerSize), tooltip=exitTooltipTP)
    array.push(exitMarkers, lbl_tp)

if showExitMarkers
    while array.size(exitMarkers) > exitMarkerMaxVis
        label.delete(array.shift(exitMarkers))

// ══════════════════════════════════════════════════════════════════════════════
// INFO TABLE (v6.10)
// ══════════════════════════════════════════════════════════════════════════════
f_mtfTextSize(string s) =>
    s == "Tiny" ? size.tiny : s == "Small" ? size.small : s == "Large" ? size.large : size.normal

f_posMap(string p) =>
    p == "Top Right" ? position.top_right : p == "Top Left" ? position.top_left : p == "Bottom Right" ? position.bottom_right : position.bottom_left

// ─── CONTEXT ROW CALCULATIONS ─────────────────────────────────
float ema200Dist    = close - ema200
// ema200DistATR already declared above signal engine (forward declaration)
string ema200Str    = (ema200Dist > 0 ? "▲ +" : "▼ ") + str.tostring(math.round(ema200DistATR, 1)) + " ATR"
color  ema200Col    = math.abs(ema200DistATR) <= 1.0 ? THEME_BULL :
                      math.abs(ema200DistATR) <= 2.0 ? color.yellow :
                      math.abs(ema200DistATR) <= 3.0 ? color.orange : THEME_BEAR

float vwapDist    = close - vwapVal
float vwapDistPct = vwapVal > 0 ? vwapDist / vwapVal * 100 : 0.0
string vwapStr    = (vwapDist > 0 ? "▲ +" : "▼ ") + str.tostring(math.round(vwapDistPct, 2)) + "%"
color  vwapCol    = math.abs(vwapDistPct) <= 0.3 ? THEME_TEXT : vwapDist > 0 ? THEME_BULL : THEME_BEAR

var table infoTable = table.new(f_posMap(tablePos), 2, 42, bgcolor=THEME_BG, border_width=1, border_color=THEME_BORDER, frame_width=1, frame_color=THEME_BORDER)

// ── Sub-function: header + trade status + signal quality ────────────
f_infoBlock1(table t, string infSize) =>
    table.cell(t, 0, 0, "⚡ ALPHAEDGE v6.10 • " + AUTHOR, text_color=THEME_TEXT, text_size=infSize, bgcolor=THEME_HEADER)
    table.merge_cells(t, 0, 0, 1, 0)

    string quickStatus = ""
    color  quickCol    = THEME_TEXT_DIM
    color  quickBg     = THEME_ACCENT_ROW
    if tradeDir == 1 and not na(entryPrice) and not na(tradeRisk) and tradeRisk > 0
        float pnlR_q  = (close - entryPrice) / tradeRisk
        string tpProg = tp3Hit ? "🏆" : tp2Hit ? "[✓✓○]" : tp1Hit ? "[✓○○]" : "[○○○]"
        quickStatus  := "🟢 LONG " + tpProg + "  " + (pnlR_q >= 0 ? "+" : "") + str.tostring(math.round(pnlR_q, 2)) + "R"
        quickCol     := pnlR_q >= 1.0 ? THEME_BULL : pnlR_q >= 0 ? color.new(THEME_BULL, 20) : THEME_BEAR
        quickBg      := color.new(THEME_BULL, 80)
    else if tradeDir == -1 and not na(entryPrice) and not na(tradeRisk) and tradeRisk > 0
        float pnlR_q  = (entryPrice - close) / tradeRisk
        string tpProg = tp3Hit ? "🏆" : tp2Hit ? "[✓✓○]" : tp1Hit ? "[✓○○]" : "[○○○]"
        quickStatus  := "🔴 SHORT " + tpProg + "  " + (pnlR_q >= 0 ? "+" : "") + str.tostring(math.round(pnlR_q, 2)) + "R"
        quickCol     := pnlR_q >= 1.0 ? THEME_BULL : pnlR_q >= 0 ? color.new(THEME_BULL, 20) : THEME_BEAR
        quickBg      := color.new(THEME_BEAR, 80)
    else
        int netLive_q = bullScore - bearScore
        if netLive_q >= 4
            quickStatus := "⏸ WAITING  •  🟢 " + f_finalLabel(compScore)
            quickCol    := THEME_BULL
        else if netLive_q <= -4
            quickStatus := "⏸ WAITING  •  🔴 " + f_finalLabel(compScore)
            quickCol    := THEME_BEAR
        else
            quickStatus := "⏸ WAITING  •  ⚖️ " + f_finalLabel(compScore)
            quickCol    := THEME_ACCENT
        quickBg := THEME_ACCENT_ROW
    table.cell(t, 0, 1, quickStatus, text_color=quickCol, text_size=infSize, bgcolor=quickBg, text_halign=text.align_center)
    table.merge_cells(t, 0, 1, 1, 1)

    table.cell(t, 0, 2, "── SIGNAL QUALITY ──", text_color=THEME_ACCENT, text_size=size.tiny, bgcolor=THEME_HEADER)
    table.merge_cells(t, 0, 2, 1, 2)

    if useSQS
        float sqsLiveBull = nz(sqsBullConfirmed, sqsBull)
        float sqsLiveBear = nz(sqsBearConfirmed, sqsBear)
        float sqsShow     = tradeDir != 0 and not na(activeTradeSQS) ? activeTradeSQS : math.max(sqsLiveBull, sqsLiveBear)
        string sqsTxt     = "🧪 " + str.tostring(math.round(sqsShow)) + "/100 " + f_sqsGrade(sqsShow) + " (" + (sqsLiveBull >= sqsLiveBear ? "BULL" : "BEAR") + ")"
        table.cell(t, 0, 3, "SQS", text_color=THEME_TEXT, text_size=infSize, bgcolor=THEME_BG_ALT)
        table.cell(t, 1, 3, sqsTxt, text_color=f_sqsColor(sqsShow), text_size=infSize, bgcolor=THEME_BG_ALT)

    int sqsRowUsed = useSQS ? 1 : 0
    if showProgressBar
        string bullTrendSfx = f_scoreTrend(bullBuilding, bullFading)
        string bearTrendSfx = f_scoreTrend(bearBuilding, bearFading)
        string bullBar = f_progressBar(bullScore, 12) + "  " + str.tostring(bullScore) + "/12" + bullTrendSfx
        string bearBar = f_progressBar(bearScore, 12) + "  " + str.tostring(bearScore) + "/12" + bearTrendSfx
        table.cell(t, 0, 3 + sqsRowUsed, "🟢 BULL", text_color=THEME_BULL, text_size=infSize, bgcolor=THEME_BG_ALT)
        table.cell(t, 1, 3 + sqsRowUsed, bullBar, text_color=f_scoreTrendColor(bullBuilding, bullFading, true), text_size=infSize, bgcolor=THEME_BG_ALT)
        table.cell(t, 0, 4 + sqsRowUsed, "🔴 BEAR", text_color=THEME_BEAR, text_size=infSize, bgcolor=THEME_BG)
        table.cell(t, 1, 4 + sqsRowUsed, bearBar, text_color=f_scoreTrendColor(bearBuilding, bearFading, false), text_size=infSize, bgcolor=THEME_BG)

    3 + sqsRowUsed + (showProgressBar ? 2 : 0)  // returns rowBase

// ── Sub-function: confluence rows ───────────────────────────────────
f_infoBlock2(table t, string infSize, int rowBase) =>
    table.cell(t, 0, rowBase, "── CONFLUENCE ──", text_color=THEME_ACCENT, text_size=size.tiny, bgcolor=THEME_HEADER)
    table.merge_cells(t, 0, rowBase, 1, rowBase)
    int rb = rowBase + 1

    table.cell(t, 0, rb,     "⚡ AlphaEdge",   text_color=THEME_TEXT, text_size=infSize, bgcolor=THEME_BG_ALT)
    table.cell(t, 1, rb,     uprng ? "▲ Bullish" : "▼ Bearish", text_color=uprng ? THEME_BULL : THEME_BEAR, text_size=infSize, bgcolor=THEME_BG_ALT)
    table.cell(t, 0, rb + 1, "🎯 Supertrend",  text_color=THEME_TEXT, text_size=infSize, bgcolor=THEME_BG)
    table.cell(t, 1, rb + 1, stTrend == 1 ? "▲ Bullish" : "▼ Bearish", text_color=stTrend == 1 ? THEME_BULL : THEME_BEAR, text_size=infSize, bgcolor=THEME_BG)
    table.cell(t, 0, rb + 2, "📊 MACD",        text_color=THEME_TEXT, text_size=infSize, bgcolor=THEME_BG_ALT)
    table.cell(t, 1, rb + 2, macdBull ? "▲ Bullish" : "▼ Bearish", text_color=macdBull ? THEME_BULL : THEME_BEAR, text_size=infSize, bgcolor=THEME_BG_ALT)

    string rsiSt = rsi_ob ? "⚠ Overbought" : rsi_os ? "⚠ Oversold" : rsi_bull ? "▲ Bullish" : "▼ Bearish"
    color  rsiC  = rsi_ob ? color.orange : rsi_os ? THEME_ACCENT : rsi_bull ? THEME_BULL : THEME_BEAR
    table.cell(t, 0, rb + 3, "💹 RSI (" + str.tostring(math.round(rsiVal, 1)) + ")", text_color=THEME_TEXT, text_size=infSize, bgcolor=THEME_BG)
    table.cell(t, 1, rb + 3, rsiSt, text_color=rsiC, text_size=infSize, bgcolor=THEME_BG)

    table.cell(t, 0, rb + 4, "〰️ EMA 50/200",  text_color=THEME_TEXT, text_size=infSize, bgcolor=THEME_BG_ALT)
    table.cell(t, 1, rb + 4, ema_bull_table ? "▲ Bullish" : "▼ Bearish", text_color=ema_bull_table ? THEME_BULL : THEME_BEAR, text_size=infSize, bgcolor=THEME_BG_ALT)

    string adxSt = adxSafe > adxStrong ? "💪 Strong" : adxSafe > adxWeak ? "Moderate" : "Weak"
    color  adxC  = adxSafe > adxStrong ? THEME_BULL : adxSafe > adxWeak ? color.yellow : THEME_BEAR
    table.cell(t, 0, rb + 5, "💪 ADX (" + str.tostring(math.round(adxSafe, 1)) + ")" + (adxGatePassed ? " ✓" : " ✗"), text_color=THEME_TEXT, text_size=infSize, bgcolor=THEME_BG)
    table.cell(t, 1, rb + 5, showADXTable ? adxSt : "—", text_color=showADXTable ? adxC : THEME_TEXT_DIM, text_size=infSize, bgcolor=THEME_BG)

    table.cell(t, 0, rb + 6, "🏔️ HTF Bias",    text_color=THEME_TEXT, text_size=infSize, bgcolor=THEME_BG_ALT)
    table.cell(t, 1, rb + 6, htfBull ? "▲ Bullish" : "▼ Bearish", text_color=htfBull ? THEME_BULL : THEME_BEAR, text_size=infSize, bgcolor=THEME_BG_ALT)

    string mtfGateStr = useMTFGate ? (mtfBlockSell ? "🟢 Longs Only" : mtfBlockBuy ? "🔴 Shorts Only" : "✓ Both OK") : "— Off"
    table.cell(t, 0, rb + 7, "🚪 MTF Gate",    text_color=THEME_TEXT, text_size=infSize, bgcolor=THEME_BG)
    table.cell(t, 1, rb + 7, mtfGateStr, text_color=mtfBlockSell or mtfBlockBuy ? color.orange : THEME_TEXT_DIM, text_size=infSize, bgcolor=THEME_BG)

    // Circuit breaker row (shows when active — hidden when off)
    if consecutiveLosses > 0 or circuitBreakerOn
        int   cbBarsLeft_f  = math.max(0, 10 - (bar_index - circuitBreakerBar))
        string cbRowTxt = circuitBreakerOn ? "🔴 ACTIVE — " + str.tostring(cbBarsLeft_f) + " bars remaining" : "✓ " + str.tostring(consecutiveLosses) + " loss streak (resets on win)"
        color  cbRowCol = circuitBreakerOn ? color.new(#FF1744, 0) : consecutiveLosses >= 2 ? color.orange : THEME_TEXT_DIM
        table.cell(t, 0, rb + 8, "🚨 Circuit Breaker", text_color=THEME_TEXT, text_size=infSize, bgcolor=THEME_BG_ALT, tooltip="Pauses signals after 3 consecutive SL hits.\nResets on next winning trade.")
        table.cell(t, 1, rb + 8, cbRowTxt,             text_color=cbRowCol,   text_size=infSize, bgcolor=THEME_BG_ALT)
        rb + 9  // +1 row used
    else
        rb + 8

// ── Sub-function: context + bias rows ───────────────────────────────
f_infoBlock3(table t, string infSize, int ctxBase) =>
    table.cell(t, 0, ctxBase, "── CONTEXT ──", text_color=THEME_ACCENT, text_size=size.tiny, bgcolor=THEME_HEADER)
    table.merge_cells(t, 0, ctxBase, 1, ctxBase)
    int cb = ctxBase + 1

    string svwapAction = not na(svwapSD) and svwapSD > 0 ? (svwapDistSD > 2.0 ? "🔴 EXTENDED — skip longs" : svwapDistSD > 1.0 ? "⚠️ RISKY — longs stretched" : svwapDistSD >= -0.5 ? "✅ FAIR VALUE — best entries" : svwapDistSD >= -1.5 ? "🟡 PULLBACK ZONE — longs ok" : "🔵 OVERSOLD — mean rev watch") : "—"
    color svwapTxtCol = not na(svwapSD) and svwapSD > 0 ? (svwapDistSD > 2.0 ? color.new(#FF5722, 0) : svwapDistSD > 1.0 ? color.new(#FF9800, 0) : svwapDistSD >= -0.5 ? color.new(#00E676, 0) : svwapDistSD >= -1.5 ? color.new(#FFD700, 0) : color.new(#64B5F6, 0)) : THEME_TEXT_DIM
    color svwapBgCol = not na(svwapSD) and svwapSD > 0 ? (svwapDistSD > 2.0 ? color.new(#FF5722, 90) : svwapDistSD > 1.0 ? color.new(#FF9800, 90) : svwapDistSD >= -0.5 ? color.new(#00E676, 92) : svwapDistSD >= -1.5 ? color.new(#FFD700, 92) : color.new(#64B5F6, 92)) : THEME_BG_ALT
    string svwapPctStr = (svwapDistPct >= 0 ? "▲ +" : "▼ ") + str.tostring(math.round(svwapDistPct, 2)) + "%  " + svwapAction
    table.cell(t, 0, cb, "SVWAP", text_color=THEME_TEXT, text_size=infSize, bgcolor=svwapBgCol, tooltip="Session VWAP action guide:\n✅ FAIR VALUE (±0.5SD) — ideal entry zone\n⚠️ RISKY (+1SD) — longs stretched, reduce size\n🔴 EXTENDED (+2SD) — skip new longs\n🟡 PULLBACK ZONE (-1SD) — longs ok, VWAP magnet above\n🔵 OVERSOLD (-2SD) — watch for reversal, do not short\nResets daily at RTH open.")
    table.cell(t, 1, cb, svwapPctStr, text_color=svwapTxtCol, text_size=infSize, bgcolor=svwapBgCol)

    table.cell(t, 0, cb + 1, "vs EMA200", text_color=THEME_TEXT, text_size=infSize, bgcolor=THEME_BG, tooltip="Distance from EMA200 in ATR units.\n>3 ATR = price is extended, mean reversion risk is elevated.")
    table.cell(t, 1, cb + 1, ema200Str,  text_color=ema200Col,  text_size=infSize, bgcolor=THEME_BG)

    string pocDistLive = not na(pocPrice) and pocPrice > 0 ? " (" + (close >= pocPrice ? "+" : "-") + str.tostring(math.round(math.abs(close - pocPrice) / pocPrice * 100, 1)) + "%)" : ""
    bool   pocDistWarn = not na(pocPrice) and pocPrice > 0 and atrVal > 0 and math.abs(close - pocPrice) / atrVal > maxPOCDistATR
    string pocStr = na(pocPrice) ? "…calc" : str.tostring(math.round(pocPrice, 2)) + pocDistLive
    color  pocC   = na(pocPrice) ? THEME_TEXT_DIM : pocDistWarn ? color.new(#FF9800, 0) : close > pocPrice ? THEME_BULL : THEME_BEAR
    table.cell(t, 0, cb + 2, "◆ POC", text_color=THEME_TEXT, text_size=infSize, bgcolor=THEME_BG_ALT)
    table.cell(t, 1, cb + 2, pocStr,  text_color=pocC,       text_size=infSize, bgcolor=THEME_BG_ALT)

    // SL Mode row — shows which branch of f_calcSL() fired on last entry
    color slModeCol = str.contains(lastSLMode, "Capped") ? color.orange : str.contains(lastSLMode, "Floored") ? color.yellow : THEME_TEXT_DIM
    table.cell(t, 0, cb + 3, "🛡 SL Mode", text_color=THEME_TEXT, text_size=infSize, bgcolor=THEME_BG, tooltip="⚠ Capped = maxSLDistance hit.\n▲ Floored = minSLDistance hit.\n✓ Structure = swing-based SL.")
    table.cell(t, 1, cb + 3, lastSLMode,   text_color=slModeCol,  text_size=infSize, bgcolor=THEME_BG)

    string biasLabel = tradeDir != 0 ? "★ SIGNAL" : "★ BIAS"
    string biasValue = tradeDir != 0 ? frozenDir + " " + frozenGrade + " (" + str.tostring(int(nz(frozenScore, 0))) + "/12)" : f_finalLabel(compScore)
    color  biasCol   = tradeDir != 0 ? (tradeDir == 1 ? THEME_BULL : THEME_BEAR) : f_finalColor(compScore)
    table.cell(t, 0, cb + 4, biasLabel, text_color=THEME_TEXT, text_size=infSize, bgcolor=THEME_HEADER)
    table.cell(t, 1, cb + 4, biasValue, text_color=biasCol,   text_size=infSize, bgcolor=THEME_HEADER)

    cb + 5

// ── Sub-function: active trade + backtest rows ───────────────────────
f_infoBlock4(table t, string infSize, int tradeBase) =>
    table.cell(t, 0, tradeBase, "── ACTIVE TRADE ──", text_color=THEME_ACCENT, text_size=size.tiny, bgcolor=THEME_HEADER)
    table.merge_cells(t, 0, tradeBase, 1, tradeBase)
    int tb = tradeBase + 1

    string scoreDsp  = na(frozenScore) ? "— No Signal" : "Entry " + str.tostring(int(frozenScore)) + "/10 • " + frozenGrade + " " + frozenDir
    string overallSig = ""
    color  sigC       = THEME_TEXT_DIM
    int localBarsSinceSig = bar_index - lastSigBar
    if tradeDir == 1
        overallSig := "🟢 Active Long"
        sigC       := THEME_BULL
    else if tradeDir == -1
        overallSig := "🔴 Active Short"
        sigC       := THEME_BEAR
    else if not na(frozenScore) and localBarsSinceSig <= 5 and lastExitReason != "—"
        overallSig := str.contains(lastExitReason, "SL") ? "⚠ " + lastExitReason : "✅ " + lastExitReason
        sigC       := str.contains(lastExitReason, "SL") ? THEME_BEAR : THEME_BULL
    else
        int netLive = bullScore - bearScore
        if netLive >= 4
            overallSig := "🟢 Bullish Bias"
            sigC       := THEME_BULL
        else if netLive <= -4
            overallSig := "🔴 Bearish Bias"
            sigC       := THEME_BEAR
        else if math.max(bullScore, bearScore) >= 6
            overallSig := "⚡ Building…"
            sigC       := color.yellow
        else
            overallSig := "⚖ Awaiting Setup"
    table.cell(t, 0, tb, scoreDsp,   text_color=THEME_TEXT, text_size=infSize, bgcolor=THEME_ACCENT_ROW)
    table.cell(t, 1, tb, overallSig, text_color=sigC,       text_size=infSize, bgcolor=THEME_ACCENT_ROW)

    string tpTxt = ""
    color  tpCol = THEME_TEXT_DIM
    if tradeActive
        string i1 = tp1Hit ? "✓" : "○"
        string i2 = tp2Hit ? "✓" : "○"
        string i3 = tp3Hit ? "✓" : "○"
        tpTxt := "[" + i1 + "] [" + i2 + "] [" + i3 + "]" + (tp3Hit ? " 🏆 HOME RUN!" : tp2Hit ? " → Trailing" : tp1Hit ? " → Trailing" : " → Live")
        tpCol := tp3Hit ? color.new(#00E676, 0) : tp2Hit ? THEME_BULL : tp1Hit ? color.new(THEME_BULL, 20) : color.new(color.yellow, 10)
    else
        tpTxt := str.contains(tradeStatus, "SL") ? "[✗] [✗] [✗] SL Hit" : str.contains(tradeStatus, "TP3") ? "[✓] [✓] [✓] 🏆 Closed" : str.contains(tradeStatus, "TP2") ? "[✓] [✓] [○] Closed +" : str.contains(tradeStatus, "TP1") ? "[✓] [○] [○] Closed +" : str.contains(tradeStatus, "BE") ? "[✓] [○] [○] BE" : "— Awaiting Setup"
        tpCol := str.contains(tradeStatus, "SL") ? THEME_BEAR : str.contains(tradeStatus, "TP3") ? color.new(#00E676, 0) : str.contains(tradeStatus, "TP") ? THEME_BULL : THEME_TEXT_DIM
    table.cell(t, 0, tb + 1, "Progress", text_color=THEME_TEXT, text_size=infSize, bgcolor=THEME_BG)
    table.cell(t, 1, tb + 1, tpTxt,      text_color=tpCol,      text_size=infSize, bgcolor=THEME_BG)

    string posStr = na(posUnits) ? "— No Setup" : str.tostring(math.round(posUnits, 4)) + "u ($" + str.tostring(math.round(posDollarRisk, 0)) + ")"
    table.cell(t, 0, tb + 2, "💰 Size", text_color=THEME_TEXT,   text_size=infSize, bgcolor=THEME_BG_ALT, tooltip="Position size based on " + str.tostring(accountRiskPct) + "% fixed risk per trade.")
    table.cell(t, 1, tb + 2, posStr,    text_color=THEME_ACCENT, text_size=infSize, bgcolor=THEME_BG_ALT)

    if showPnLRow
        string pnlTxt = "— No Active Trade"
        color  pnlCol = THEME_TEXT_DIM
        if tradeDir != 0 and not na(entryPrice) and not na(tradeRisk) and tradeRisk > 0
            float pnlR   = (tradeDir == 1 ? close - entryPrice : entryPrice - close) / tradeRisk
            float pnlUSD = pnlR * posDollarRisk
            pnlTxt := "Live P&L: " + (pnlR >= 0 ? "+" : "") + str.tostring(math.round(pnlR, 2)) + "R (" + (pnlUSD >= 0 ? "+$" : "-$") + str.tostring(math.round(math.abs(pnlUSD), 0)) + ")"
            pnlCol := pnlR >= 2.0 ? THEME_BULL : pnlR >= 0.5 ? color.new(THEME_BULL, 30) : pnlR >= 0 ? color.new(THEME_BULL, 60) : pnlR >= -0.5 ? color.new(THEME_BEAR, 40) : THEME_BEAR
        table.cell(t, 0, tb + 3, pnlTxt, text_color=pnlCol, text_size=infSize, bgcolor=THEME_ACCENT_ROW)
        table.merge_cells(t, 0, tb + 3, 1, tb + 3)

    int statRow = tb + (showPnLRow ? 4 : 3)
    table.cell(t, 0, statRow, "── BACKTEST ──", text_color=THEME_ACCENT, text_size=size.tiny, bgcolor=THEME_HEADER)
    table.merge_cells(t, 0, statRow, 1, statRow)
    statRow += 1

    if showBTStats
        string btStr    = "📊 " + str.tostring(btTrades) + "T │ WR " + str.tostring(math.round(btWinRate, 0)) + "% │ PF " + str.tostring(math.round(btPF, 2)) + " │ " + (btAvgR >= 0 ? "+" : "") + str.tostring(math.round(btAvgR, 2)) + "R"
        color  btTextCol = btAvgR > 0.5 ? color.new(#00E676, 0) : btAvgR > 0 ? color.new(#66BB6A, 0) : btAvgR > -0.5 ? color.new(#FFA726, 0) : color.new(#FF5252, 0)
        table.cell(t, 0, statRow, btStr, text_color=btTextCol, text_size=infSize, bgcolor=THEME_BG_ALT)
        table.merge_cells(t, 0, statRow, 1, statRow)
        statRow += 1

    if showDrawdown and btTrades > 0
        string ddStr = "📉 MaxDD " + str.tostring(math.round(btMaxDD, 2)) + "R │ Now " + str.tostring(math.round(btCurrentDD, 2)) + "R" + (btActive ? " │ MTM" : "") + " │ Streak W:" + str.tostring(btMaxWinStreak) + " L:" + str.tostring(btMaxLossStreak)
        color  ddCol = btCurrentDD <= 2 ? color.new(#66BB6A, 0) : btCurrentDD <= 5 ? color.new(#FFA726, 0) : color.new(#FF5252, 0)
        table.cell(t, 0, statRow, ddStr, text_color=ddCol, text_size=infSize, bgcolor=THEME_BG, tooltip="DRAWDOWN\nMaxDD: largest peak-to-trough drop\nNow: current DD from peak\nMTM: mark-to-market open position included")
        table.merge_cells(t, 0, statRow, 1, statRow)
        statRow += 1

    if usePerfBreakdown and (trendingTrades > 0 or volatileTrades > 0)
        string regimeWRtxt = "🚀 T:" + str.tostring(trendingTrades) + "/" + str.tostring(math.round(trendingWR, 0)) + "%  ⚡ V:" + str.tostring(volatileTrades) + "/" + str.tostring(math.round(volatileWR, 0)) + "%"
        color regimeWRcol = trendingWR >= 50 and volatileWR >= 50 ? THEME_BULL : trendingWR >= 50 or volatileWR >= 50 ? color.yellow : THEME_BEAR
        table.cell(t, 0, statRow + 1, regimeWRtxt, text_color=regimeWRcol, text_size=infSize, bgcolor=THEME_BG)
        table.merge_cells(t, 0, statRow + 1, 1, statRow + 1)
    if usePerfBreakdown and (aPlusTrades > 0 or aTrades > 0 or bTrades > 0)
        string gradeWRtxt = "A+ " + str.tostring(aPlusTrades) + "/" + str.tostring(math.round(aPlusWR, 0)) + "%  A " + str.tostring(aTrades) + "/" + str.tostring(math.round(aWR, 0)) + "%  B " + str.tostring(bTrades) + "/" + str.tostring(math.round(bWR, 0)) + "%"
        color gradeWRcol = aPlusWR >= 50 or aWR >= 50 ? THEME_BULL : THEME_TEXT_DIM
        table.cell(t, 0, statRow + 2, gradeWRtxt, text_color=gradeWRcol, text_size=infSize, bgcolor=THEME_BG_ALT)
        table.merge_cells(t, 0, statRow + 2, 1, statRow + 2)
// ── COMPACT MODE TABLE ───────────────────────────────────────────────
f_infoCompact(table t, string infSize) =>
    // Row 0: header (always)
    table.cell(t, 0, 0, "⚡ AE v6.10 • COMPACT", text_color=THEME_TEXT, text_size=infSize, bgcolor=THEME_HEADER)
    table.merge_cells(t, 0, 0, 1, 0)

    if tradeDir != 0 and not na(entryPrice) and not na(tradeRisk) and tradeRisk > 0
        // ── ACTIVE TRADE MODE ──────────────────────────────────────────
        // Row 1: direction + live P&L (most important, largest visual)
        float pnlR_c  = tradeDir == 1 ? (close - entryPrice) / tradeRisk : (entryPrice - close) / tradeRisk
        float pnlUSD_c = pnlR_c * nz(posDollarRisk, 0.0)
        string dirEmoji = tradeDir == 1 ? "🟢 LONG" : "🔴 SHORT"
        string pnlSign  = pnlR_c >= 0 ? "+" : ""
        string pnlTxt_c = dirEmoji + "  " + pnlSign + str.tostring(math.round(pnlR_c, 2)) + "R"
        if not na(posDollarRisk)
            pnlTxt_c := pnlTxt_c + "  (" + (pnlUSD_c >= 0 ? "+$" : "-$") + str.tostring(math.round(math.abs(pnlUSD_c), 0)) + ")"
        color pnlBg_c = pnlR_c >= 2.0 ? color.new(THEME_BULL, 70) : pnlR_c >= 0.5 ? color.new(THEME_BULL, 82) : pnlR_c >= 0 ? color.new(THEME_BG, 5) : pnlR_c >= -0.5 ? color.new(THEME_BEAR, 82) : color.new(THEME_BEAR, 70)
        color pnlCol_c = pnlR_c >= 1.0 ? THEME_BULL : pnlR_c >= 0 ? color.new(THEME_BULL, 20) : THEME_BEAR
        table.cell(t, 0, 1, pnlTxt_c, text_color=pnlCol_c, text_size=infSize, bgcolor=pnlBg_c, text_halign=text.align_center)
        table.merge_cells(t, 0, 1, 1, 1)

        // Row 2: TP progress
        string i1_c = tp1Hit ? "✓" : "○"
        string i2_c = tp2Hit ? "✓" : "○"
        string i3_c = tp3Hit ? "✓" : "○"
        string tpProg_c = "TP  [" + i1_c + "] [" + i2_c + "] [" + i3_c + "]" + (tp3Hit ? "  🏆" : tp2Hit ? "  Trailing" : tp1Hit ? "  Trailing" : "  Open")
        color tpCol_c = tp3Hit ? color.new(#00E676, 0) : tp2Hit ? THEME_BULL : tp1Hit ? color.new(THEME_BULL, 30) : THEME_TEXT_DIM
        table.cell(t, 0, 2, tpProg_c, text_color=tpCol_c, text_size=infSize, bgcolor=THEME_BG_ALT)
        table.merge_cells(t, 0, 2, 1, 2)

        // Row 3: Entry / SL / Trail on one line
        string slDistR = not na(slPrice) ? str.tostring(math.round(math.abs(close - slPrice) / tradeRisk, 2)) + "R to SL" : "—"
        string trailTxt_c = (useTrail and not na(trailPrice) and math.abs(trailPrice - entryPrice) > syminfo.mintick * 5) ? "Trail " + str.tostring(trailPrice, format.mintick) : "No trail yet"
        table.cell(t, 0, 3, "Entry " + str.tostring(entryPrice, format.mintick) + "  •  " + slDistR, text_color=THEME_TEXT_DIM, text_size=infSize, bgcolor=THEME_BG)
        table.merge_cells(t, 0, 3, 1, 3)

        // Row 4: Trail price
        color trailRowCol = useTrail and not na(trailPrice) and math.abs(trailPrice - entryPrice) > syminfo.mintick * 5 ? color.new(#FB8C00, 0) : THEME_TEXT_DIM
        table.cell(t, 0, 4, trailTxt_c, text_color=trailRowCol, text_size=infSize, bgcolor=THEME_BG_ALT)
        table.merge_cells(t, 0, 4, 1, 4)

        // Row 5: Score + Grade + SQS for this trade
        string tradeSQStxt = not na(activeTradeSQS) ? "SQS " + str.tostring(math.round(activeTradeSQS)) + " • " + f_sqsGrade(activeTradeSQS) : "—"
        string tradeScoreTxt = "Signal  " + activeTradeGrade + "  " + (tradeDir == 1 ? str.tostring(bullScore) : str.tostring(bearScore)) + "/10  •  " + tradeSQStxt
        table.cell(t, 0, 5, tradeScoreTxt, text_color=THEME_ACCENT, text_size=infSize, bgcolor=THEME_ACCENT_ROW)
        table.merge_cells(t, 0, 5, 1, 5)

        // Row 6: Regime (+ circuit breaker state)
        int   cbBarsLeft_a   = math.max(0, 10 - (bar_index - circuitBreakerBar))
        bool  cbActive_a     = circuitBreakerOn
        string cbSuffix_a    = cbActive_a ? "  🔴 CB " + str.tostring(cbBarsLeft_a) + "b" : ""
        string regimeRowTxt_a = regimeEmoji + "  " + marketRegime + "  •  ADX " + str.tostring(math.round(adxSafe, 0)) + "  •  MTF " + str.tostring(totalMTFBull) + "/12" + cbSuffix_a
        color  regimeRowCol_a = cbActive_a ? color.new(#FF1744, 0) : regimeColor
        table.cell(t, 0, 6, regimeRowTxt_a, text_color=regimeRowCol_a, text_size=infSize, bgcolor=THEME_BG)
        table.merge_cells(t, 0, 6, 1, 6)

    else
        /// Row 1: Composite bias + dominant grade + SQS
        string waitBias  = f_finalLabel(compScore)
        color  waitBiasC = f_finalColor(compScore)
        color  waitBg    = compScore >= 4 ? color.new(THEME_BULL, 82) : compScore <= -4 ? color.new(THEME_BEAR, 82) : THEME_BG_ALT
        int    netWait   = bullScore - bearScore
        string netSign   = netWait >= 0 ? "+" : ""
        bool   bullDom   = bullScore >= bearScore
        float  domSQS    = bullDom ? nz(sqsBullConfirmed, sqsBull) : nz(sqsBearConfirmed, sqsBear)
        string domGrade  = bullDom ? getGrade(bullScore) : getGrade(bearScore)
        string sqsSuffix = useSQS ? "  SQS " + str.tostring(math.round(domSQS)) : ""
        table.cell(t, 0, 1, "⚏ WAITING  •  " + waitBias + " " + domGrade + "  (" + netSign + str.tostring(netWait) + ")" + sqsSuffix, text_color=waitBiasC, text_size=infSize, bgcolor=waitBg, text_halign=text.align_center)
        table.merge_cells(t, 0, 1, 1, 1)

        // Row 2: Bull score | Bear score
        string bullBarC = "● " + f_progressBar(bullScore, 6) + " " + str.tostring(bullScore) + "/12 " + getGrade(bullScore) + f_scoreTrend(bullBuilding, bullFading)
        string bearBarC = "● " + f_progressBar(bearScore, 6) + " " + str.tostring(bearScore) + "/12 " + getGrade(bearScore) + f_scoreTrend(bearBuilding, bearFading)
        table.cell(t, 0, 2, "🟢 " + bullBarC, text_color=f_scoreTrendColor(bullBuilding, bullFading, true),  text_size=infSize, bgcolor=THEME_BG_ALT)
        table.cell(t, 1, 2, "🔴 " + bearBarC, text_color=f_scoreTrendColor(bearBuilding, bearFading, false), text_size=infSize, bgcolor=THEME_BG_ALT)

        // Row 3: SQS Bull | SQS Bear
        float  sqsLB  = nz(sqsBullConfirmed, sqsBull)
        float  sqsLBr = nz(sqsBearConfirmed, sqsBear)
        table.cell(t, 0, 3, "🟢 " + str.tostring(math.round(sqsLB))  + " " + f_sqsGrade(sqsLB),  text_color=f_sqsColor(sqsLB),  text_size=infSize, bgcolor=THEME_BG)
        table.cell(t, 1, 3, "🔴 " + str.tostring(math.round(sqsLBr)) + " " + f_sqsGrade(sqsLBr), text_color=f_sqsColor(sqsLBr), text_size=infSize, bgcolor=THEME_BG)

        // Row 4: TP progress if trade active, otherwise blank/hidden
        if tradeDir != 0 and not na(entryPrice) and not na(tradeRisk) and tradeRisk > 0
            string i1w = tp1Hit ? "✓TP1" : "○TP1"
            string i2w = tp2Hit ? "✓TP2" : "○TP2"
            string i3w = tp3Hit ? "✓TP3" : "○TP3"
            float  pnlRw = tradeDir == 1 ? (close - entryPrice) / tradeRisk : (entryPrice - close) / tradeRisk
            string pnlSignW = pnlRw >= 0 ? "+" : ""
            string tpRowTxt = (tradeDir == 1 ? "🟢" : "🔴") + " " + i1w + " " + i2w + " " + i3w + "  " + pnlSignW + str.tostring(math.round(pnlRw, 2)) + "R"
            color  tpRowCol = tp3Hit ? color.new(#00E676, 0) : tp2Hit ? THEME_BULL : tp1Hit ? color.new(THEME_BULL, 30) : pnlRw >= 0 ? THEME_TEXT : THEME_BEAR
            color  tpRowBg  = tp3Hit ? color.new(THEME_BULL, 75) : tp1Hit ? color.new(THEME_BULL, 88) : THEME_ACCENT_ROW
            table.cell(t, 0, 4, tpRowTxt, text_color=tpRowCol, text_size=infSize, bgcolor=tpRowBg)
            table.merge_cells(t, 0, 4, 1, 4)
        else
            string lastTradeStr = lastExitReason != "—" ? "Last: " + lastExitReason : btTrades > 0 ? "Last: " + str.tostring(btTrades) + " trades completed" : "No trades yet"
            color  lastTradeCol = str.contains(lastExitReason, "SL") ? THEME_BEAR : str.contains(lastExitReason, "TP") or str.contains(lastExitReason, "Trail") or str.contains(lastExitReason, "BE") ? THEME_BULL : THEME_TEXT_DIM
            table.cell(t, 0, 4, lastTradeStr, text_color=lastTradeCol, text_size=infSize, bgcolor=THEME_BG)
            table.merge_cells(t, 0, 4, 1, 4)
            
        // Row 5: Backtest summary + last exit
        string btSummary = btTrades > 0 ? str.tostring(btTrades) + "T  WR" + str.tostring(math.round(btWinRate, 0)) + "%  PF" + str.tostring(math.round(btPF, 2)) + "  DD" + str.tostring(math.round(btMaxDD, 1)) + "R" : "No trades yet"
        string lastRow   = lastExitReason != "—" ? btSummary + "  │ " + lastExitReason : btSummary
        color  lastCol   = str.contains(lastExitReason, "SL") ? THEME_BEAR : str.contains(lastExitReason, "TP") or str.contains(lastExitReason, "Trail") ? THEME_BULL : THEME_TEXT_DIM
        table.cell(t, 0, 5, lastRow, text_color=lastCol, text_size=infSize, bgcolor=THEME_BG)
        table.merge_cells(t, 0, 5, 1, 5)  

// ── MAIN CALL ────────────────────────────────────────────────────────
if barstate.islast
    string infSize = f_mtfTextSize(infoTextSize)
    if compactMode
        f_infoCompact(infoTable, infSize)
    else if showInfoTable
        int rowBase    = f_infoBlock1(infoTable, infSize)
        int ctxBase    = f_infoBlock2(infoTable, infSize, rowBase)
        int tradeBase  = f_infoBlock3(infoTable, infSize, ctxBase)
        f_infoBlock4(infoTable, infSize, tradeBase)
					
// ══════════════════════════════════════════════════════════════════════════════
// MTF DASHBOARD
// ══════════════════════════════════════════════════════════════════════════════
f_tfLabel(string tf) =>
    string result = tf
    if tf == "1"
        result := "1m"
    else if tf == "5"
        result := "5m"
    else if tf == "15"
        result := "15m"
    else if tf == "30"
        result := "30m"
    else if tf == "60"
        result := "1H"
    else if tf == "240"
        result := "4H"
    else if tf == "D" or tf == "1D"
        result := "D"
    else if tf == "W" or tf == "1W"
        result := "W"
    result

f_sigCellBg(string sigStr) =>
    color result = THEME_BG
    if sigStr == "STRONG BUY"
        result := color.new(#00C853, 85)
    else if sigStr == "BUY"
        result := color.new(#00C853, 92)
    else if sigStr == "STRONG SELL"
        result := color.new(#D50000, 85)
    else if sigStr == "SELL"
        result := color.new(#D50000, 92)
    result

var table mtfTable = table.new(f_posMap(mtfTablePos), 6, 7, bgcolor=THEME_BG, border_width=1, border_color=THEME_BORDER, frame_width=1, frame_color=THEME_BORDER)

if showMTF and barstate.islast
    tblSize = f_mtfTextSize(mtfTextSize)

    table.cell(mtfTable, 0, 0, "TF", text_color=THEME_TEXT, text_size=tblSize, bgcolor=THEME_HEADER)
    table.cell(mtfTable, 1, 0, "TREND", text_color=THEME_TEXT, text_size=tblSize, bgcolor=THEME_HEADER)
    table.cell(mtfTable, 2, 0, "SCORE", text_color=THEME_TEXT, text_size=tblSize, bgcolor=THEME_HEADER)
    table.cell(mtfTable, 3, 0, "SIGNAL", text_color=THEME_TEXT, text_size=tblSize, bgcolor=THEME_HEADER)
    table.cell(mtfTable, 4, 0, "POC", text_color=THEME_TEXT, text_size=tblSize, bgcolor=THEME_HEADER)
    table.cell(mtfTable, 5, 0, "DIST", text_color=THEME_TEXT, text_size=tblSize, bgcolor=THEME_HEADER)

    float poc1 = f_getPOCForTF(mtf1)
    float d1 = f_pctDist(poc1)
    table.cell(mtfTable, 0, 1, f_tfLabel(mtf1), text_color=THEME_TEXT, text_size=tblSize, bgcolor=THEME_BG)
    table.cell(mtfTable, 1, 1, f_mtfLabel(mtf1_bull), text_color=f_mtfColor(mtf1_bull), text_size=tblSize, bgcolor=THEME_BG)
    table.cell(mtfTable, 2, 1, f_progressBar(mtf1_bull, 3) + " " + str.tostring(mtf1_bull), text_color=f_mtfColor(mtf1_bull), text_size=tblSize, bgcolor=THEME_BG)
    table.cell(mtfTable, 3, 1, mtf1_signal, text_color=f_mtfSignalColor(mtf1_signal), text_size=tblSize, bgcolor=f_sigCellBg(mtf1_signal))
    table.cell(mtfTable, 4, 1, na(poc1) ? "—" : str.tostring(math.round(poc1, 2)), text_color=THEME_TEXT, text_size=tblSize, bgcolor=THEME_BG)
    table.cell(mtfTable, 5, 1, na(poc1) ? "—" : f_distStr(d1), text_color=na(poc1) ? THEME_TEXT_DIM : f_distColor(d1), text_size=tblSize, bgcolor=THEME_BG)

    float poc2 = f_getPOCForTF(mtf2)
    float d2 = f_pctDist(poc2)
    table.cell(mtfTable, 0, 2, f_tfLabel(mtf2), text_color=THEME_TEXT, text_size=tblSize, bgcolor=THEME_BG_ALT)
    table.cell(mtfTable, 1, 2, f_mtfLabel(mtf2_bull), text_color=f_mtfColor(mtf2_bull), text_size=tblSize, bgcolor=THEME_BG_ALT)
    table.cell(mtfTable, 2, 2, f_progressBar(mtf2_bull, 3) + " " + str.tostring(mtf2_bull), text_color=f_mtfColor(mtf2_bull), text_size=tblSize, bgcolor=THEME_BG_ALT)
    table.cell(mtfTable, 3, 2, mtf2_signal, text_color=f_mtfSignalColor(mtf2_signal), text_size=tblSize, bgcolor=f_sigCellBg(mtf2_signal))
    table.cell(mtfTable, 4, 2, na(poc2) ? "—" : str.tostring(math.round(poc2, 2)), text_color=THEME_TEXT, text_size=tblSize, bgcolor=THEME_BG_ALT)
    table.cell(mtfTable, 5, 2, na(poc2) ? "—" : f_distStr(d2), text_color=na(poc2) ? THEME_TEXT_DIM : f_distColor(d2), text_size=tblSize, bgcolor=THEME_BG_ALT)

    float poc3 = f_getPOCForTF(mtf3)
    float d3 = f_pctDist(poc3)
    table.cell(mtfTable, 0, 3, f_tfLabel(mtf3), text_color=THEME_TEXT, text_size=tblSize, bgcolor=THEME_BG)
    table.cell(mtfTable, 1, 3, f_mtfLabel(mtf3_bull), text_color=f_mtfColor(mtf3_bull), text_size=tblSize, bgcolor=THEME_BG)
    table.cell(mtfTable, 2, 3, f_progressBar(mtf3_bull, 3) + " " + str.tostring(mtf3_bull), text_color=f_mtfColor(mtf3_bull), text_size=tblSize, bgcolor=THEME_BG)
    table.cell(mtfTable, 3, 3, mtf3_signal, text_color=f_mtfSignalColor(mtf3_signal), text_size=tblSize, bgcolor=f_sigCellBg(mtf3_signal))
    table.cell(mtfTable, 4, 3, na(poc3) ? "—" : str.tostring(math.round(poc3, 2)), text_color=THEME_TEXT, text_size=tblSize, bgcolor=THEME_BG)
    table.cell(mtfTable, 5, 3, na(poc3) ? "—" : f_distStr(d3), text_color=na(poc3) ? THEME_TEXT_DIM : f_distColor(d3), text_size=tblSize, bgcolor=THEME_BG)

    // MTF row 4
    float poc4 = f_getPOCForTF(mtf4)
    float d4 = f_pctDist(poc4)
    table.cell(mtfTable, 0, 4, f_tfLabel(mtf4), text_color=THEME_TEXT, text_size=tblSize, bgcolor=THEME_BG_ALT)
    table.cell(mtfTable, 1, 4, f_mtfLabel(mtf4_bull), text_color=f_mtfColor(mtf4_bull), text_size=tblSize, bgcolor=THEME_BG_ALT)
    table.cell(mtfTable, 2, 4, f_progressBar(mtf4_bull, 3) + " " + str.tostring(mtf4_bull), text_color=f_mtfColor(mtf4_bull), text_size=tblSize, bgcolor=THEME_BG_ALT)
    table.cell(mtfTable, 3, 4, mtf4_signal, text_color=f_mtfSignalColor(mtf4_signal), text_size=tblSize, bgcolor=f_sigCellBg(mtf4_signal))
    table.cell(mtfTable, 4, 4, na(poc4) ? "—" : str.tostring(math.round(poc4, 2)), text_color=THEME_TEXT, text_size=tblSize, bgcolor=THEME_BG_ALT)
    table.cell(mtfTable, 5, 4, na(poc4) ? "—" : f_distStr(d4), text_color=na(poc4) ? THEME_TEXT_DIM : f_distColor(d4), text_size=tblSize, bgcolor=THEME_BG_ALT)

    // Weekly POC macro row
    if showPOCWeekly and not na(pocWeekly)
        float dW = f_pctDist(pocWeekly)
        color weeklyBg = color.new(THEME_ACCENT, 85)
        table.cell(mtfTable, 0, 5, "W ★", text_color=THEME_ACCENT, text_size=tblSize, bgcolor=weeklyBg, tooltip="Weekly POC — macro anchor")
        table.cell(mtfTable, 1, 5, "Macro", text_color=THEME_TEXT_DIM, text_size=tblSize, bgcolor=weeklyBg)
        table.cell(mtfTable, 2, 5, "—", text_color=THEME_TEXT_DIM, text_size=tblSize, bgcolor=weeklyBg)
        table.cell(mtfTable, 3, 5, "—", text_color=THEME_TEXT_DIM, text_size=tblSize, bgcolor=weeklyBg)
        table.cell(mtfTable, 4, 5, str.tostring(math.round(pocWeekly, 2)), text_color=THEME_ACCENT, text_size=tblSize, bgcolor=weeklyBg)
        table.cell(mtfTable, 5, 5, f_distStr(dW), text_color=f_distColor(dW), text_size=tblSize, bgcolor=weeklyBg)

    // NOW row
    int curBull = (uprng ? 1 : 0) + (rsiVal > 50 ? 1 : 0) + (close > ema50 ? 1 : 0)
    string curSignal = f_finalLabel(compScore)
    table.cell(mtfTable, 0, 6, "► NOW", text_color=THEME_ACCENT, text_size=tblSize, bgcolor=THEME_ACCENT_ROW)
    table.cell(mtfTable, 1, 6, f_mtfLabel(curBull), text_color=f_mtfColor(curBull), text_size=tblSize, bgcolor=THEME_ACCENT_ROW)
    table.cell(mtfTable, 2, 6, f_progressBar(curBull, 3) + " " + str.tostring(curBull), text_color=f_mtfColor(curBull), text_size=tblSize, bgcolor=THEME_ACCENT_ROW)
    table.cell(mtfTable, 3, 6, curSignal, text_color=f_finalColor(compScore), text_size=tblSize, bgcolor=THEME_ACCENT_ROW)
    table.cell(mtfTable, 4, 6, na(pocPrice) ? "—" : str.tostring(math.round(pocPrice, 2)), text_color=THEME_ACCENT, text_size=tblSize, bgcolor=THEME_ACCENT_ROW)
    table.cell(mtfTable, 5, 6, "—", text_color=THEME_TEXT_DIM, text_size=tblSize, bgcolor=THEME_ACCENT_ROW)

// ══════════════════════════════════════════════════════════════════════════════
// LIVE DIRECTIONAL BIAS ARROW (v6.10 — optimized: emoji + bias + MTF bar only)
// ══════════════════════════════════════════════════════════════════════════════
var label biasArrow = na
var label biasShape = na
var line  biasLine  = na

if showDirArrow and barstate.islast
    label.delete(biasArrow)
    label.delete(biasShape)
    line.delete(biasLine)

    string headerEmoji = ""
    string trailEmoji  = ""
    string biasTxt     = ""
    color  arrowCol    = THEME_TEXT_DIM
    color  textCol     = color.white
    string shapeStyle  = "diamond"

    if compScore >= 9
        headerEmoji := "🚀"
        trailEmoji  := "🔥"
        biasTxt     := "STRONG LONG"
        arrowCol    := color.new(#00E676, 0)
        textCol     := color.black
        shapeStyle  := "arrow_up"
    else if compScore >= 4
        headerEmoji := "🟢"
        trailEmoji  := "📈"
        biasTxt     := "LONG"
        arrowCol    := color.new(#66BB6A, 10)
        textCol     := color.black
        shapeStyle  := "arrow_up"
    else if compScore >= -3
        headerEmoji := "⚖️"
        trailEmoji  := "💤"
        biasTxt     := "NEUTRAL"
        arrowCol    := color.new(#9575CD, 25)
        textCol     := color.white
        shapeStyle  := "diamond"
    else if compScore >= -8
        headerEmoji := "🔴"
        trailEmoji  := "📉"
        biasTxt     := "SHORT"
        arrowCol    := color.new(#EC407A, 10)
        textCol     := color.white
        shapeStyle  := "arrow_down"
    else
        headerEmoji := "💀"
        trailEmoji  := "❄️"
        biasTxt     := "STRONG SHORT"
        arrowCol    := color.new(#D81B60, 0)
        textCol     := color.white
        shapeStyle  := "arrow_down"

    int mtfFilled = math.max(0, math.min(12, totalMTFBull))
    string mtfBar = ""
    for i = 0 to mtfFilled - 1
        mtfBar := mtfBar + "█"
    for i = 0 to 11 - mtfFilled
        mtfBar := mtfBar + "░"

    // v6.10: Simplified — emoji + bias text + MTF bar only
    // Removed: score breakdown, bull/bear split, SQS (all redundant with info table)
    string line1 = headerEmoji + "  " + biasTxt + "  " + trailEmoji
    string line2 = "MTF " + mtfBar + " " + str.tostring(totalMTFBull) + "/12"
    string richTxt = line1 + "\n" + line2

    int shapeX = bar_index + 5
    int lineEndX = bar_index + labelOffset + biasArrowOffset
    int labelX = bar_index + labelOffset + biasArrowOffset + 3

    biasLine := line.new(shapeX, close, lineEndX, close, color=color.new(arrowCol, 50), width=1, style=line.style_arrow_right)
    string arrowTxt = shapeStyle == "arrow_up" ? "▲" : shapeStyle == "arrow_down" ? "▼" : "◆"
    biasShape := label.new(shapeX, close, arrowTxt, style=label.style_none, color=color.new(color.black, 100), textcolor=arrowCol, size=size.huge)
    biasArrow := label.new(labelX, close, richTxt, style=label.style_label_left, color=color.new(arrowCol, 30), textcolor=textCol, size=size.small, tooltip="LIVE DIRECTIONAL BIAS\nComposite Score: " + str.tostring(math.round(compScore, 2)) + "\nBull: " + str.tostring(bullScore) + "/12\nBear: " + str.tostring(bearScore) + "/12\nMTF Sum: " + str.tostring(totalMTFBull) + "/12")
// ══════════════════════════════════════════════════════════════════════════════
// WATERMARK (v6.10 — text kept, animation removed)
// ══════════════════════════════════════════════════════════════════════════════
f_watermarkSize(string s) =>
    s == "Tiny" ? size.tiny : s == "Small" ? size.small : s == "Large" ? size.large : s == "Huge" ? size.huge : size.normal

var table wmTable = table.new(position.bottom_center, 1, 2, bgcolor=color.new(#000000, 5), border_width=1, border_color=color.new(#000000, 0), frame_width=2, frame_color=color.new(THEME_ACCENT, 70))

if showWatermark and barstate.islast
    // v6.10: Fixed transparency — no sine-wave animation
    color wmMainCol = color.new(THEME_ACCENT, 20)
    color wmSubCol  = color.new(THEME_TEXT_DIM, 35)

    string wmMain = "⚡ AlphaEdge " + VERSION + "  •  " + AUTHOR + " 🚀"
    table.cell(wmTable, 0, 0, wmMain, text_color=wmMainCol, text_size=f_watermarkSize(watermarkSize), text_halign=text.align_left, bgcolor=color.new(#000000, 5))

    string wmSub = "◦ " + timeframe.period + " ◦ " + str.tostring(btTrades) + " trades ◦ " + regimeEmoji + " " + marketRegime
    table.cell(wmTable, 0, 1, wmSub, text_color=wmSubCol, text_size=size.tiny, text_halign=text.align_left, bgcolor=color.new(#000000, 5))

// ══════════════════════════════════════════════════════════════════════════════
// REGIME BADGE
// ══════════════════════════════════════════════════════════════════════════════
f_regimePos(string p) =>
    switch p
        "Top Center"    => position.top_center
        "Top Right"     => position.top_right
        "Top Left"      => position.top_left
        "Middle Right"  => position.middle_right
        "Middle Left"   => position.middle_left
        "Bottom Center" => position.bottom_center
        "Bottom Left"   => position.bottom_left
        "Bottom Right"  => position.bottom_right
        => position.top_center

var int regimeChangeBar = 0
if marketRegime != marketRegime[1]
    regimeChangeBar := bar_index

int barsSinceChange = bar_index - regimeChangeBar
bool isPulsing = barsSinceChange <= 5
int pulseTransp = isPulsing ? int(barsSinceChange * 4) : 20
int glowIntensity = isPulsing ? int(barsSinceChange * 8) : 40
color borderGlow = color.new(regimeColor, glowIntensity)
color frameGlow = color.new(regimeColor, math.min(85, glowIntensity + 30))

table regimeTable = table.new(f_regimePos(regimeBadgePos), 1, 2, bgcolor=color.new(color.black, 100), border_width=2, border_color=borderGlow, frame_width=3, frame_color=frameGlow)

if useRegime and barstate.islast
    string pulseIcon = isPulsing ? "✨" : ""
    string regimeTxt = pulseIcon + " " + regimeEmoji + "  " + marketRegime + "  " + regimeEmoji + " " + pulseIcon
    string regimeSub = "ADX " + str.tostring(math.round(adxSafe, 0)) + "  •  ATR " + str.tostring(math.round(volRatio, 2)) + "×"

    color mainBg = color.new(regimeColor, pulseTransp)
    color mainTextGlow = isPulsing ? color.new(color.white, 0) : color.white

    table.cell(regimeTable, 0, 0, regimeTxt, text_color=mainTextGlow, text_size=size.normal, bgcolor=mainBg, tooltip="MARKET REGIME\n🚀 TRENDING\n⚡ VOLATILE\n🔄 RANGING\n💤 QUIET\n🔀 TRANSITIONAL")

    color subBg = color.new(regimeColor, 55)
    table.cell(regimeTable, 0, 1, regimeSub, text_color=color.new(color.white, 15), text_size=size.tiny, bgcolor=subBg)

