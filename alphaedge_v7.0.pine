cvdLen    = input.int(20, "CVD Divergence Lookback", group=G_CVD, minval=5, maxval=50)

useTimeFilter  = input.bool(false, "Enable Time Filter",          group=G_TIME)
blockOpen      = input.bool(true,  "Block First 30min (9:30 ET)", group=G_TIME)
blockClose     = input.bool(true,  "Block Last 15min (3:45 ET)",  group=G_TIME)
skipWeekends   = input.bool(true,  "Skip Weekends",               group=G_TIME)
allowedStart   = input.int(9,      "Allowed Start Hour (ET)",     group=G_TIME, minval=0, maxval=23)
allowedEnd     = input.int(16,     "Allowed End Hour (ET)",       group=G_TIME, minval=0, maxval=23)

usePerfBreakdown = input.bool(true, "Show Grade-Level Stats", group=G_PERF)
showDrawdown     = input.bool(true, "Show Drawdown Stats", group=G_PERF, tooltip="v6.10: Tracks max drawdown and current drawdown in R-multiples including open trade mark-to-market.")

useLiqSweep    = input.bool(false, "Detect Liquidity Sweeps", group=G_LIQ)
liqSwingLen    = input.int(15, "Swing Lookback for Sweep", group=G_LIQ, minval=5, maxval=50)
liqWickRatio   = input.float(0.5, "Min Wick Ratio", group=G_LIQ, step=0.05, minval=0.2, maxval=0.9)
liqMinGap      = input.int(5, "Min Bars Between Sweeps", group=G_LIQ, minval=1, maxval=50)
liqShowBox     = input.bool(true, "Highlight Sweep Zone Box", group=G_LIQ)
liqBullColor   = input.color(color.new(#00E676, 70), "Bull Sweep Color", group=G_LIQ)
liqBearColor   = input.color(color.new(#FF1744, 70), "Bear Sweep Color", group=G_LIQ)
liqBonusScore  = input.bool(true, "Add +1 to Confluence on Sweep", group=G_LIQ)

useRegime       = input.bool(true, "Show Regime Badge", group=G_REGIME)
regimeAdxTrend  = input.int(22, "Trending ADX Threshold", group=G_REGIME, minval=15, maxval=40)
regimeAdxRange  = input.int(20, "Ranging ADX Threshold", group=G_REGIME, minval=10, maxval=30)
regimeVolHigh   = input.float(1.5, "Volatile ATR Ratio", group=G_REGIME, step=0.1, minval=1.1, maxval=3.0)
regimeVolLow    = input.float(0.7, "Quiet ATR Ratio", group=G_REGIME, step=0.05, minval=0.3, maxval=0.9)
regimeBadgePos  = input.string("Top Center", "Badge Position", group=G_REGIME, options=["Top Center","Top Right","Top Left","Middle Right","Middle Left","Bottom Center","Bottom Left","Bottom Right"])

useDynamicRR     = input.bool(false,  "Use Dynamic R:R by ATR Regime",      group=G_DYNR)
// VOLATILE regime TPs (wider — ride momentum, IREN/XRP benefit most)
dynVolTP1Mult    = input.float(1.5,   "VOLATILE TP1 Mult",                  group=G_DYNR, step=0.1, minval=0.5,  maxval=3.0)
dynVolTP2Mult    = input.float(2.5,   "VOLATILE TP2 Mult",                  group=G_DYNR, step=0.1, minval=1.0,  maxval=5.0)
dynVolTP3Mult    = input.float(4.0,   "VOLATILE TP3 Mult",                  group=G_DYNR, step=0.5, minval=2.0,  maxval=8.0)
dynRRSLHighMult  = input.float(2.5,   "VOLATILE SL Mult",                   group=G_DYNR, step=0.25, minval=1.0, maxval=5.0)
// QUIET regime TPs (tighter — grab profit fast, don't let winners fade)
dynQtTP1Mult     = input.float(0.8,   "QUIET TP1 Mult",                     group=G_DYNR, step=0.1, minval=0.3,  maxval=1.5)
dynQtTP2Mult     = input.float(1.5,   "QUIET TP2 Mult",                     group=G_DYNR, step=0.1, minval=0.5,  maxval=3.0)
dynQtTP3Mult     = input.float(2.0,   "QUIET TP3 Mult",                     group=G_DYNR, step=0.25, minval=1.0, maxval=4.0)
dynRRSLLowMult   = input.float(1.5,   "QUIET SL Mult",                      group=G_DYNR, step=0.25, minval=0.5, maxval=3.0)

// ══════════════════════════════════════════════════════════════════════════════
// 🔔 ALERT COOLDOWN
// ══════════════════════════════════════════════════════════════════════════════
useAlertCooldown  = input.bool(true, "Enable Alert Cooldown", group=G_ALERT)
alertCooldownBars = input.int(10, "Cooldown Bars", group=G_ALERT, minval=1, maxval=100)

// ── MOMENTUM / BIG MOVER ALERT ───────────────────────────────────────────────
useMomoAlert     = input.bool(true,  "Big Mover Alert (day % move)", group=G_ALERT,
                   tooltip="Fires an alert when the stock moves more than X% from prior day close.\nCompletely separate from signal engine — works even when EMA gate blocks entries.\nDesigned for MU/NVDA/IREN type gap-and-go days.")
momoThreshPct    = input.float(5.0,  "Min % Move to Trigger Alert", group=G_ALERT,
                   step=0.5, minval=1.0, maxval=20.0,
                   tooltip="5.0 = alert fires when stock is up or down 5%+ from yesterday's close.\nSet to 3.0 for more sensitive. Set to 8.0 for only extreme moves.")
momoAlertOnce    = input.bool(true,  "Alert Only Once Per Day", group=G_ALERT,
                   tooltip="Prevents repeated alerts on the same move.\nON = fires once when threshold first crossed.\nOFF = fires every bar while above threshold.")
momoDirectional  = input.bool(true,  "Bull moves only (uncheck for both directions)", group=G_ALERT,
                   tooltip="ON = only alerts on UP moves (long bias system).\nOFF = alerts on both up and down moves.")
// ══════════════════════════════════════════════════════════════════════════════
// 🎯 SMART RE-ENTRY
// ══════════════════════════════════════════════════════════════════════════════
useReEntry         = input.bool(false, "Enable Smart Re-Entry",                group=G_REENTRY)
reEntryPullbackPct = input.float(0.5,  "Pullback % of TP1-Entry distance",    group=G_REENTRY, step=0.1, minval=0.2, maxval=0.9)
reEntryMinScore    = input.int(6,      "Min Score for Re-Entry",               group=G_REENTRY, minval=4, maxval=10)
useReEntryGate     = input.bool(false, "Apply Quality Gate to Re-Entries",     group=G_REENTRY, tooltip="Requires regime + ST + VWAP to still agree at re-entry bar.\nOFF by default — may eliminate most re-entries.\nBacktest before enabling.")

// ══════════════════════════════════════════════════════════════════════════════
// VALIDATION
// ══════════════════════════════════════════════════════════════════════════════
tp1MultSafe = tp1Mult
tp2MultSafe = math.max(tp2Mult, tp1Mult + 0.1)
tp3MultSafe = math.max(tp3Mult, tp2MultSafe + 0.1)

// ══════════════════════════════════════════════════════════════════════════════
// THEME ENGINE (5 Themes)
