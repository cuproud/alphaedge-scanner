//@version=6
// ════════════════════════════════════════════════════════
// ALPHAEDGE v7.0 | Author: VAMSI | Updated: June 30 2026
// 5-pillar confluence signal system for US equities + crypto
// P1: HTF trend (3pts) P2: Momentum (2pts) P3: Volume (3pts)
// P4: Regime (2pts) P5: Candle body (2pts) — max 12pts
// + v7.0 RS bonus (+1pt if outperforming SPY 5d), score capped at 12
// Regime gate: TRENDING + VOLATILE (+ TRANSITIONAL on 15m only)
// SL: structure-based, staged (5.0×ATR initial → tightens to 3.0×ATR after +0.5R)
// TP1/2/3: 1R / 2R / 3.5R | Early BE at 0.75R
// ATR trail engages after TP1 on 1H, after early BE on 15m/30m
// Stage-aware trail: 1.8× base → 1.5× after TP1 → 1.0× after TP2 → 0.6× after TP3
// SQS 0-100: Regime 30% | Confluence 25% | MTF 20% | Vol 15% | Volatility 10%
//          + time-of-day multiplier (1.05× during 10-11/14-15 ET, 0.90× during lunch)
// Gates: POC distance (ATR-based) | EMA200 extension | HTF/LTF conflict
//        (consolidated severity-weighted check) | Pillar purity (3-of-5 min)
//        | Choppiness Index (30m+ now, v7.0) | Direction-aware chop/cooldown filter
// TF-aware tuning:
//   - AE range filter length: 100 (15m) / 150 (30m) / 200 (1H+)
//   - EMA200 slope floor: 0.003 (15m) / 0.005 (30m) / 0.006 (1H+)
//   - Regime ADX floor: 15 (15m) / 20 (30m) / 22 (1H+)
//   - Grade filter: 15m hardcoded score≥7 (bypasses dropdown, includes B-grade)
//                   30m respects Grade Filter input (currently B and better)
//                   1H+ hardcoded score≥9 (A+/A only)
//   - Min bars between signals: 1 (15m, no cooldown) / input value (30m+)
// Circuit breaker: pauses new entries after 3 consecutive losses; cooldown
//   escalates +10 bars per loss beyond the 3rd
// Features: Volume Profile + Multi-TF POC, Order Blocks, FVGs, BOS/CHoCH,
//   Anchored VWAP, CVD, Liquidity sweeps, MTF dashboard, Signal Quality Score,
//   Smart Re-Entry, Gate Funnel audit table (diagnostic, zero effect on signal)
// Backtest: grade-level WR (A+/A/B) | regime WR (Trending/Volatile) |
//   drawdown (MaxDD/current, mark-to-market) | position sizing
// Themes: 5 only (Ice Diamond, Bloomberg Classic, Honey Gold, Guntur Karam,
//   Arctic Aurora)
// Alerts: disabled (TradingView alerts are a paid feature not in use;
//   Telegram delivery handled separately via AlphaEdge GitHub Actions repo)
//
// v7.0 CHANGES (June 30 2026 — vs v6.10):
//   • I1: P2 Momentum AND-logic — MACD+RSI both true=2pts, either=1pt, neither=0
//   • I1: P3 Volume AND-logic — high vol+CVD both=3pts, either=1pt, neither=0
//   • I3: Staged SL — tightens from initial 5.0×ATR to 3.0×ATR after +0.5R move
//   • I4: Stage-aware trail mult — 1.8 base → 1.5 after TP1 → 1.0 after TP2 → 0.6 after TP3
//   • I6: Choppiness gate now on 30m+ (was 1H+ only) — preserves 15m trade count
//   • I7: Time-of-day SQS multiplier — boost 10-11AM/2-3PM, penalize 11:30-1:30 lunch
//   • I8: RS vs SPY 5d confluence bonus (+1pt if outperforming, capped at 12)
//   • Removed Pulse Animation (kept from v6.10)
//   • Removed Label Glow Effects (kept from v6.10)
//   • Removed Gradient TP/SL Lines (kept from v6.10)
//   • Live Bias Arrow optimized (kept from v6.10)
//   • Theme Engine (5 themes): kept as-is
//
// EXPECTED v7.0a IMPACT:
//   PF: 1.5-1.8 → 2.2-2.4 (estimated)
//   A-grade WR: 55-65% → 60-70%
//   B-grade WR: 40-50% → 45-55%
//   MaxDD: ~7R → ~5R (staged SL cap)
//   Trade count: -5% to -10% (cleaner gates)
// ════════════════════════════════════════════════════════

indicator("AlphaEdge v7.0 by VAMSI", overlay=true, shorttitle="AE v7.0", max_labels_count=500, max_lines_count=500, max_boxes_count=500, max_bars_back=2000)
import wbburgin/wbburgin_utils/2 as utils

// ─── VERSION CONSTANTS ──────────────────────────────────────
VERSION      = "v7.0"
VERSION_FULL = "AlphaEdge v7.0"
AUTHOR       = "VAMSI"

// ─── GROUP CONSTANTS ────────────────────────────────────────
G_THEME  = "🎨 Theme & Visual Style"
G_PT     = "⚡ AlphaEdge Core"
G_FIL    = "🔬 Signal Filters"
G_RISK   = "🛡️ Risk Management"
G_MACD   = "📈 MACD Overlay"
G_ST     = "🎯 Supertrend"
G_EMA    = "〰️ EMA 50/200"
G_RSI    = "💹 RSI"
G_ADX    = "📊 ADX Strength"
G_SR     = "🧱 Support & Resistance"
G_VOL    = "🌡️ Volume Profile"
G_MTF    = "🗂️ Multi-Timeframe Table"
G_INFO   = "📋 Info & Backtest"
G_DISP   = "🎨 Display"
G_SMC    = "🧠 Smart Money Concepts"
G_AVWAP  = "⚓ Anchored VWAP"
G_CVD    = "📉 CVD (Volume Delta)"
G_TIME   = "🕒 Time Filter"
G_PERF   = "📈 Performance Analytics"
G_LIQ    = "🎣 Liquidity Sweeps"
G_REGIME = "🏷️ Market Regime Badge"
G_DYNR   = "🎯 Dynamic ATR Regime TP/SL"
G_ALERT  = "🔔 Alert Management"
G_REENTRY = "🎯 Smart Re-Entry"
G_MPOC   = "🎯 Multi-TF POC"
G_SQS    = "🧪 Signal Quality Score"
G_SVWAP  = "📊 Session VWAP Bands"
// ══════════════════════════════════════════════════════════════════════════════
// THEME SELECTION (5 themes)
// ══════════════════════════════════════════════════════════════════════════════
themeChoice = input.string("❄️ Arctic Aurora", "Theme", group=G_THEME, options=["💎 Ice Diamond", "🎯 Bloomberg Classic", "🍯 Honey Gold", "🌶️ Guntur Karam", "❄️ Arctic Aurora"])
compactMode       = input.bool(true,  "Compact Mode (hides tables when idle/active)", group=G_DISP, tooltip="When ON: info table shows only the most critical rows.\n• Active trade → Status + Progress + P&L + Trail only\n• Waiting → Score bars + Bias + Last exit only\nTurn OFF for the full dashboard view.")
showDirArrow    = input.bool(true, "Show Live Bias Arrow", group=G_THEME)
showProgressBar = input.bool(true, "Show Confluence Progress Bars", group=G_THEME)
enrichedAlerts  = input.bool(true, "Enriched Alert Messages", group=G_THEME)
biasArrowOffset = input.int(20, "Bias Arrow Right Offset (bars)", group=G_THEME, minval=5, maxval=300)

// ══════════════════════════════════════════════════════════════════════════════
// 📱 MOBILE QUICK TOGGLES
// ══════════════════════════════════════════════════════════════════════════════
showInfoTable    = input.bool(true,  "📋 Show Info Table (TOP)",     group=G_THEME)
showMTF          = input.bool(false,  "🗂️ Show MTF Table (TOP)",      group=G_THEME)
showWatermark    = input.bool(false,  "💧 Show Watermark (TOP)",      group=G_THEME)

// ══════════════════════════════════════════════════════════════════════════════
// 🧪 SIGNAL QUALITY SCORE
// ══════════════════════════════════════════════════════════════════════════════
useSQS        = input.bool(true, "Show Signal Quality Score (0-100)", group=G_SQS)
sqsMinForAlert    = input.int(75, "Min SQS for Alert (15m/30m)", group=G_SQS, minval=0, maxval=100, tooltip="On 1H and above this threshold is raised by 5 automatically (75→80).\nFilters the weakest signals that dilute TSLA/MU 1H results.\nSet to 70 to loosen if 1H trade count drops too low.")
usePOCDistGate    = input.bool(true, "POC Distance Gate", group=G_SQS, tooltip="Blocks signals when price is too far from POC.\nNow ATR-based — scales with volatility rather than fixed percentage.\n3.0 ATR = typical for 30m. 3.5 ATR = typical for 1H.\nDisable for crypto or very high-beta names.")
maxPOCDistATR     = input.float(3.5, "Max POC Distance (×ATR) to Allow Signal", group=G_SQS, step=0.25, minval=1.0, maxval=10.0, tooltip="Maximum distance from POC measured in ATR units.\n3.5 ATR covers normal trend extension without allowing blow-off entries.\nRaise to 5.0 for high-beta names like IREN during strong trends.")

// ══════════════════════════════════════════════════════════════════════════════
// SESSION VWAP BANDS
// ══════════════════════════════════════════════════════════════════════════════
showSVWAP       = input.bool(false,  "Show Session VWAP",              group=G_SVWAP)
showSVWAPBands  = input.bool(false,  "Show ±1SD and ±2SD Bands",       group=G_SVWAP)
svwapLineWidth  = input.int(1,      "VWAP Line Width",                 group=G_SVWAP, minval=1, maxval=4)
svwapCol        = input.color(color.new(#FFD700, 0),   "VWAP Color",  group=G_SVWAP)
svwap1SDCol     = input.color(color.new(#00BCD4, 40),  "±1SD Color",  group=G_SVWAP)
svwap2SDCol     = input.color(color.new(#FF5722, 50),  "±2SD Color",  group=G_SVWAP)
svwapFillBands  = input.bool(true,  "Fill Between Bands",             group=G_SVWAP)

// ══════════════════════════════════════════════════════════════════════════════
// CORE AE INPUTS
// ══════════════════════════════════════════════════════════════════════════════
l = input.int(200, "AE Length (1H base)", group=G_PT, tooltip="Base AE range filter length used on 1H and above.\nOn 30m this is scaled to 150 bars automatically.\nOn 15m and below it is scaled to 100 bars.\nShorter length = narrower band = more crossovers on lower TFs.")

useADXGate    = input.bool(true, "ADX Hard Gate", group=G_FIL)
adxGateLevel  = input.int(20, "ADX Gate Threshold", group=G_FIL, minval=10, maxval=40)
useADXScore   = input.bool(true, "ADX as Confluence Point", group=G_FIL)
lengthadx     = input.int(14, "ADX Length", group=G_FIL)

useRSIDiv    = input.bool(true, "RSI Divergence Filter", group=G_FIL)
rsiDivLook   = input.int(5, "Divergence Pivot Length", group=G_FIL, minval=2, maxval=15)
rsiDivFloor  = input.int(25, "RSI Bull Div Min Floor", group=G_FIL, minval=10, maxval=45)
rsiBearCeil  = input.int(75, "RSI Bear Div Max Ceiling", group=G_FIL, minval=55, maxval=90)

useSqueeze = input.bool(true, "BB/KC Squeeze Score", group=G_FIL)
sqBBMult   = input.float(2.0, "BB Multiplier", group=G_FIL, step=0.1)
sqKCMult   = input.float(1.5, "KC Multiplier", group=G_FIL, step=0.1)

useHTF             = input.bool(true,  "HTF Trend Bias",                         group=G_FIL)
htfTF              = input.timeframe("240", "HTF Timeframe",                      group=G_FIL)

ema200SlopeMin15m  = input.float(0.003, "EMA200 Min Slope Threshold ×ATR/bar (15m)",  group=G_FIL, step=0.001, minval=0.001, maxval=0.15, tooltip="Slope threshold for 15m only.\nEMA200 moves fewer ticks per bar on 15m vs 30m — 0.003 is the calibrated floor.\nRaise to 0.005 if you want to match 30m selectivity on 15m.")
ema200SlopeMin     = input.float(0.005, "EMA200 Min Slope Threshold ×ATR/bar (30m)",  group=G_FIL, step=0.005, minval=0.001, maxval=0.15, tooltip="Slope threshold for 30m timeframe.\nEMA200 moves slowly on short TFs — 0.005 is the calibrated floor.\n0.02+ = daily chart level, will block most intraday signals.")
ema200SlopeMin1H   = input.float(0.004, "EMA200 Min Slope Threshold ×ATR/bar (1H+)",  group=G_FIL, step=0.005, minval=0.001, maxval=0.15, tooltip="Slope threshold for 60m and above.\nEMA200 moves more meaningfully per bar on longer TFs.\n0.010 restores the pre-v6.10 selectivity on 1H that was lost when the global was relaxed to 0.005.")

useEMA200ExtGate   = input.bool(true,  "EMA200 Extension Gate",                   group=G_FIL, tooltip="Blocks signals when price is too many ATRs from EMA200.\nDefault 5.0 ATR — IREN was +4.5 ATR, MU was +8.8 ATR at entry, both stopped immediately.\nIncrease for high-beta names. Disable for crypto.")
maxEMA200ExtATR    = input.float(8.0,  "Max EMA200 Distance (×ATR) to Allow",    group=G_FIL, step=0.25, minval=1.0, maxval=15.0)

usehl    = input.bool(false, "Range ST Filter", group=G_FIL, inline="HL")
lengthhl = input.int(14, title="Lookback", group=G_FIL, inline="HL")
showhl   = input.bool(false, "Plot", group=G_FIL, inline="HL")

usevwma    = input.bool(false, "VWMA Filter", group=G_FIL, inline="VW")
lengthvwma = input.int(200, title="", group=G_FIL, inline="VW")
showvwma   = input.bool(false, "Plot", group=G_FIL, inline="VW")

minConfScore   = input.int(7,     "Min Confluence Score (0-12)",             group=G_FIL, minval=0, maxval=12, tooltip="v6.10: Max score is now 12 (P5 candle pillar adds 2 points).\nDefault raised from 6 to 7 to maintain same selectivity.")
useCandleGate  = input.bool(true, "P5: Candle Body Confirmation (+2 score)", group=G_FIL, tooltip="Adds 2 points when entry bar has a strong directional close.\nBull: close > open, body > 50% of bar range.\nBear: close < open, body > 50% of bar range.\nDoji / indecision = 0 points.")

gradeFilter  = input.string("B and better", "Grade Filter", group=G_FIL, options=["All (incl C)","B and better","A+ and A","A+ Only"])

minBarsBetween   = input.int(6,    "Min Bars Between Signals (30m/1H default)", group=G_FIL, minval=1, maxval=20, tooltip="On 15m this value is halved automatically (6→3) to avoid 90-min cooldowns blocking valid resumption setups.\nOn 30m and above the value is used as-is.")

useVolSpikeGate  = input.bool(false, "Volume Spike Gate on Entry Bar",          group=G_FIL, tooltip="Requires volume > multiplier × avg on signal bar.\nEliminates thin-volume false breakouts (OKLO pattern).\nTest OFF first — reduces trade count.")
volSpikeMult     = input.float(1.2, "Vol Spike Min Multiplier (×avg)",          group=G_FIL, step=0.1, minval=0.5, maxval=3.0)

useGapFilter      = input.bool(false,  "Gap Risk Filter (MU/NVDA type symbols)", group=G_FIL, tooltip="Blocks signals when any of the last 3 bars opened with a gap >threshold% from prior close.\nLeave OFF for IREN/OKLO/TSLA/QBTS.\nEnable only on earnings-gap-prone symbols like MU, NVDA, AMD.\nDefault 3.0% catches earnings gaps without blocking normal intraday moves.")
gapRiskThreshold  = input.float(3.0,   "Max Gap % to Allow Signal (last 3 bars)", group=G_FIL, step=0.5, minval=1.0, maxval=10.0, tooltip="3.0% = blocks entries after any recent gap >3%.\nRaise to 5.0 for crypto where 3% gaps are normal.\nLower to 2.0 for tighter gap sensitivity on low-beta names.")

adxReversalBypass = input.bool(true, "High-Score ADX Bypass", group=G_FIL)
adxBypassMinScore = input.int(5, "ADX Bypass Min Score", group=G_FIL, minval=4, maxval=10)

useTrendGradeFilter = input.bool(true, "Block Counter-Trend B/A Grade", group=G_FIL)

useChopFilter      = input.bool(true,  "Chop Filter (direction-aware)",          group=G_FIL)
chopAtrMult        = input.float(1.0,  "Min ATR Move Since Last Signal",         group=G_FIL, step=0.1, minval=0.3, maxval=5.0)
useRegimeChopScale = input.bool(true,  "Scale Chop Filter by Regime",            group=G_FIL, tooltip="VOLATILE: threshold × 1.5 (stops thin-air IREN entries).\nTRENDING: threshold × 0.8 (allows tighter pullback entries).\nRANGING/QUIET: unchanged.")

useChopIndex   = input.bool(true,  "Choppiness Index Gate (CHOP < 61.8)",    group=G_FIL, tooltip="Blocks signals when CHOP ≥ 61.8 (ranging/choppy market).\nCHOP < 61.8 = trending conditions.\nCHOP formula: 100 × log10(ATR_sum_14 / (highest_14 - lowest_14)) / log10(14)\nDirectly targets MU/TSLA 1H chop without touching momentum logic.")
chopIndexLen   = input.int(14,     "CHOP Length",                             group=G_FIL, minval=7, maxval=30)
chopIndexThresh = input.float(61.8, "CHOP Threshold (block above)",           group=G_FIL, step=0.5, minval=50.0, maxval=70.0, tooltip="61.8 is the standard trending/ranging divide.\nRaise to 64 to loosen (allow more signals).\nLower to 58 to tighten (trending only).")

useMTFGate  = input.bool(true, "MTF Composite Gate", group=G_FIL)
mtfGateBull = input.int(9, "MTF Bull Threshold (block SELL above)", group=G_FIL, minval=6, maxval=12)
mtfGateBear = input.int(3, "MTF Bear Threshold (block BUY below)", group=G_FIL, minval=0, maxval=6)

allowFlipAllTF = input.bool(false, "Range-Flip Trigger on All TFs", group=G_FIL)

// ══════════════════════════════════════════════════════════════════════════════
// RISK MANAGEMENT
// ══════════════════════════════════════════════════════════════════════════════
useStructSL     = input.bool(true, "Structure-Based SL", group=G_RISK)
swingLookback   = input.int(10, "Swing Lookback", group=G_RISK, minval=3, maxval=30)
atrLen          = input.int(14, "ATR Length", group=G_RISK)
slMult          = input.float(2.0, "SL ATR Multiplier", group=G_RISK, step=0.1)
structBuffer    = input.float(0.3, "Structure SL Buffer (×ATR)", group=G_RISK, step=0.05, minval=0.0, maxval=1.0)
minSLDistance   = input.float(0.8, "Min SL Distance (×ATR)", group=G_RISK, step=0.05, minval=0.1, maxval=2.0)
maxSLDistance   = input.float(5.0, "Max SL Distance (×ATR)",  group=G_RISK, step=0.1,  minval=1.0, maxval=8.0, tooltip="Raised from 4.0 to 5.0 — 4.0 ATR cap was still clipping structure SL short of the actual swing on OKLO/IREN/TSLA 30m, all three of which carried the worst MaxDD (6.96–7.39R) and showed 'Capped' SL Mode.\n5.0 ATR lets structure SL reach the real swing before being capped.")

maxSLDistVol    = input.float(5.0, "Max SL Distance VOLATILE (×ATR)", group=G_RISK, step=0.1, minval=1.0, maxval=8.0, tooltip="Wider SL cap for VOLATILE regime only.\nRaised from 4.0 to 5.0 ATR — IREN/OKLO in VOLATILE regime have natural swings of 2.5–3.5 ATR.\nTRENDING/other regimes use the standard Max SL Distance above.")
tp1Mult         = input.float(1.0, "TP1 R:R", group=G_RISK, step=0.1)
tp2Mult         = input.float(2.0, "TP2 R:R", group=G_RISK, step=0.1)
tp3Mult         = input.float(3.5, "TP3 R:R", group=G_RISK, step=0.5)
useTrail        = input.bool(true, "Trailing Stop", group=G_RISK)
trailAtrMult    = input.float(1.8, "Trail ATR Multiplier", group=G_RISK, step=0.1, minval=0.5, maxval=5.0, tooltip="v6.10 NEW: ATR multiplier for the dynamic trailing stop.\n\nSeparate from SL Multiplier:\n• SL Mult = initial stop at entry\n• Trail Mult = how tight the ATR trail tracks price\n\nSmaller = tighter trail, faster profit lock\nLarger = wider trail, more room on pullbacks\n\nDefault 1.8 trails tighter than SL to lock gains faster.\n\nStep minimums still apply as floors:\n• After TP1: trail floor = entry + 0.5R (breakeven+)\n• After TP2: trail floor = TP1 price\n• After TP3: trail floor = TP2 price")
showTrailType   = input.bool(true, "Show Trail Type in Label", group=G_RISK, tooltip="v6.10: Shows 'ATR Trail' label to indicate dynamic trail is active.")
showTPSL        = input.bool(true, "Show TP/SL Lines", group=G_RISK)
labelOffset     = input.int(30, "Label Offset (bars)", group=G_RISK, minval=5, maxval=80)
accountRiskPct  = input.float(1.0, "Account Risk % per Trade", group=G_RISK, step=0.1, minval=0.1, maxval=10.0)
accountSize     = input.float(10000, "Account Size ($)", group=G_RISK, step=100, minval=100)

showEntryMarker  = input.bool(true, "Show Entry Origin Marker", group=G_RISK)
entryMarkerSize  = input.string("Huge", "Entry Circle Size", group=G_RISK, options=["Small","Normal","Large","Huge"])
showElapsedTime  = input.bool(false, "Show Elapsed Time Counter", group=G_RISK)
elapsedTimeStyle = input.string("Bars + Time", "Elapsed Counter Style", group=G_RISK, options=["Bars Only","Time Only","Bars + Time"])
showTPSLMarkers  = input.bool(true, "Show Diamond Dots at SL/TP Points", group=G_RISK)
showExitMarkers  = input.bool(false, "Show Historical Exit Markers", group=G_RISK)
exitMarkerSize   = input.string("Small", "Exit Marker Size", group=G_RISK, options=["Tiny","Small","Normal","Large"])
exitMarkerMaxVis = input.int(3, "Max Visible Exit Markers (when ON)", group=G_RISK, minval=1, maxval=20)

// ══════════════════════════════════════════════════════════════════════════════
// MACD, ST, EMA, RSI, ADX, SR
// ══════════════════════════════════════════════════════════════════════════════
showMACD = input.bool(true, "Show MACD Overlay", group=G_MACD)
showSMA  = input.bool(false, "Show SMA 89 Line", group=G_MACD)
fa       = input.int(12, "Fast", group=G_MACD)
sa       = input.int(26, "Slow", group=G_MACD)
sig      = input.int(9, "Signal", group=G_MACD)
smaLen   = input.int(89, "SMA Length", group=G_MACD)

showST         = input.bool(true, "Show Supertrend Lines", group=G_ST)
showSTSig      = input.bool(true, "Show ST ▲/▼ on ST Line", group=G_ST)
showSTHL       = input.bool(false, "ST Highlighter", group=G_ST)
stPeriods      = input.int(10, "ATR Period", group=G_ST)
stSrc          = input.source(hl2, "Source", group=G_ST)
stMultiplier   = input.float(3.0, "ATR Multiplier", step=0.1, group=G_ST)
changeATR      = input.bool(true, "Use ATR (vs SMA of TR)", group=G_ST)
stLineWidth    = input.int(1, "ST Line Width", group=G_ST, minval=1, maxval=4)
stBaseTransp   = input.int(40, "ST Base Transparency", group=G_ST, minval=0, maxval=80)
fadeSTOld      = input.bool(true, "Fade Old Supertrend Segments", group=G_ST)
fadeSTAfterBars = input.int(50, "Fade ST Older Than (bars)", group=G_ST, minval=10, maxval=500)

showEMA      = input.bool(false, "Show EMA 50/200", group=G_EMA)
showEMACross = input.bool(true, "Golden/Death Cross", group=G_EMA)

rsiLen    = input.int(14, "RSI Length", group=G_RSI)

showADXTable = input.bool(true, "Show ADX in Table", group=G_ADX)
adxStrong    = input.int(25, "Strong Level", group=G_ADX)
adxWeak      = input.int(20, "Weak Level", group=G_ADX)

showSR     = input.bool(false, "Show S/R Levels", group=G_SR)
srLookback = input.int(20, "Lookback", group=G_SR)
srExtend   = input.int(50, "Extend (bars)", group=G_SR)

// ══════════════════════════════════════════════════════════════════════════════
// VOLUME PROFILE
// ══════════════════════════════════════════════════════════════════════════════
showVP       = input.bool(true, "Show Volume Profile", group=G_VOL)
vpDepth      = input.string("Balanced", "Profile Depth", group=G_VOL, options=["Shallow","Balanced","Deep"])
vpWidth      = input.int(20, "VP Visual Width (bars)", group=G_VOL, minval=10, maxval=100)
vpBullCol    = input.color(color.new(color.green, 70), "Below Price Color", group=G_VOL)
vpBearCol    = input.color(color.new(color.red, 70), "Above Price Color", group=G_VOL)
vpHideActive = input.bool(true, "Hide Color on Active Candle", group=G_VOL)
showPOCLine  = input.bool(true, "Show POC Price Line", group=G_VOL)

// ══════════════════════════════════════════════════════════════════════════════
// MULTI-TF POC
// ══════════════════════════════════════════════════════════════════════════════
useMultiPOC  = input.bool(true, "Show Multi-TF POC Lines", group=G_MPOC)
showPOC15m   = input.bool(false, "Show 15m POC", group=G_MPOC, inline="P1")
color15m     = input.color(color.new(#FF5252, 0), "", group=G_MPOC, inline="P1")
showPOC1H    = input.bool(false, "Show 1H POC", group=G_MPOC, inline="P2")
color1H      = input.color(color.new(#FF9800, 0), "", group=G_MPOC, inline="P2")
showPOC4H    = input.bool(false, "Show 4H POC", group=G_MPOC, inline="P3")
color4H      = input.color(color.new(#FFEB3B, 0), "", group=G_MPOC, inline="P3")
showPOCDaily = input.bool(false, "Show Daily POC", group=G_MPOC, inline="P4")
colorDaily   = input.color(color.new(#4CAF50, 0), "", group=G_MPOC, inline="P4")
showPOCWeekly= input.bool(false, "Show Weekly POC", group=G_MPOC, inline="P5")
colorWeekly  = input.color(color.new(#2196F3, 0), "", group=G_MPOC, inline="P5")
pocLineWidth = input.int(1, "Line Width", group=G_MPOC, minval=1, maxval=4)
pocLabelSize = input.string("Small", "Label Size", group=G_MPOC, options=["Tiny","Small","Normal","Large"])
pocExtendRight = input.int(20, "Extend Right (bars)", group=G_MPOC, minval=5, maxval=100)
hidePOCCurrentTF = input.bool(true, "Hide Same-TF POC", group=G_MPOC)
showPOCDistance = input.bool(true, "Show % Distance From Price", group=G_MPOC)

// ══════════════════════════════════════════════════════════════════════════════
// MTF
// ══════════════════════════════════════════════════════════════════════════════
mtf1    = input.timeframe("15", "TF1", group=G_MTF)
mtf2    = input.timeframe("60", "TF2", group=G_MTF)
mtf3    = input.timeframe("240", "TF3", group=G_MTF)
mtf4    = input.timeframe("D", "TF4", group=G_MTF)
mtfTextSize = input.string("Small", "MTF Table Text Size", group=G_MTF, options=["Tiny","Small","Normal","Large"])

// ══════════════════════════════════════════════════════════════════════════════
// INFO / DISPLAY
// ══════════════════════════════════════════════════════════════════════════════
showBTStats   = input.bool(true, "Show Backtest Stats", group=G_INFO)
tablePos      = input.string("Top Right", "Info Table Pos", group=G_INFO, options=["Top Right","Top Left","Bottom Right","Bottom Left"])
infoTextSize  = input.string("Small", "Info Table Text Size", group=G_INFO, options=["Tiny","Small","Normal","Large"])
mtfTablePos   = input.string("Bottom Left", "MTF Table Pos", group=G_MTF, options=["Top Right","Top Left","Bottom Right","Bottom Left"])

// ══════════════════════════════════════════════════════════════════════════════
// DISPLAY
// ══════════════════════════════════════════════════════════════════════════════
highlighting  = input.bool(true, "AE Highlighting", group=G_DISP)
barcolors     = input.bool(true, "Bar Colors", group=G_DISP)
showPTLabels  = input.bool(true, "AE Buy/Sell Labels", group=G_DISP)
showGrade     = input.bool(true, "Signal Grade Label", group=G_DISP)
showTrailLine = input.bool(true, "Trailing Stop Line", group=G_DISP)
watermarkSize = input.string("Normal", "Watermark Text Size", group=G_DISP, options=["Tiny","Small","Normal","Large","Huge"])
labelAtrClear = input.float(4.0, "Label ATR Clearance", group=G_DISP, step=0.5, minval=0.5, maxval=10.0)

fadeOldSignals    = input.bool(true, "Fade Old Signal Labels", group=G_DISP)
fadeAfterBars     = input.int(50, "Fade Signals Older Than (bars)", group=G_DISP, minval=5, maxval=200)
highlightEntryBar = input.bool(true, "Highlight Entry Bar", group=G_DISP)
showGXDate        = input.bool(true, "Show Date on GX/DX Labels", group=G_DISP)
showPnLRow        = input.bool(true, "Show P&L Row in Info Table", group=G_DISP)
colorCodePOCDist  = input.bool(true, "Color-Code MTF POC Distance", group=G_DISP)
showMiniMarker    = input.bool(false, "Show Mini Score Marker", group=G_DISP)
gxMaxVisible      = input.int(5, "Max GX/DX Labels on Chart", group=G_DISP, minval=1, maxval=30)
showHistoricalSignals = input.bool(false, "Show Historical Signal Labels", group=G_DISP)
showSignalAudit       = input.bool(false, "Show Signal Audit Tags (why it fired)", group=G_DISP, tooltip="Adds a small tag below each signal label showing which gates were active at entry.\nShows: Regime | SQS | Purity | Conflict | POC | EMA Ext\nUseful for backtesting filter combinations.")
